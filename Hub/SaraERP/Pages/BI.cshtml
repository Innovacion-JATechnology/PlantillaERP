@page
@model SaraERP.Pages.BIModel
@{
    Layout = null;
    ViewData["Title"] = "BI - En Construcción";
}


<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

<style>
html, body {
    margin: 0;
    padding: 0;
    height: 100%;
    font-family: 'Segoe UI', system-ui, sans-serif;
    background: linear-gradient(135deg, #7AB5F8, #7AB5F8);
}

/* Container */
.bi-container {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
}

/* Card */
.bi-card {
    position: relative;
    background: #ffffff;
    border-radius: 18px;
    max-width: 960px;
    width: 100%;
    padding: 45px;
    box-shadow: 0 35px 80px rgba(0,0,0,.35);
    animation: fadeUp .6s ease-out;
    overflow: hidden;
}

/* Fade animation */
@@keyframes fadeUp {
    from { opacity: 0; transform: translateY(25px); }
    to { opacity: 1; transform: translateY(0); }
}

/* Ribbon */
.ribbon {
    position: absolute;
    top: 40px;
    right: -70px;
    background: linear-gradient(135deg, #667eea, #7AB5F8);
    color: #fff;
    padding: 12px 90px;
    transform: rotate(45deg);
    font-weight: 800;
    letter-spacing: .12em;
    box-shadow: 0 10px 30px rgba(0,0,0,.35);
}

/* Header */
.bi-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 25px;
}

.bi-title {
    font-size: 2.2rem;
    font-weight: 800;
    color: #7AB5F8;
}

.bi-subtitle {
    font-size: 1.05rem;
    color: #6c757d;
}

/* Animated Gears */
.bi-icon {
    width: 80px;
    height: 80px;
    position: relative;
}

.gear {
    position: absolute;
    color: #7AB5F8;
    transform-origin: center;
}

.gear.big {
    font-size: 78px;
    top: 25px;
    left: -130px;
    animation: spin 6s linear infinite;
}

.gear.small {
    font-size: 44px;
    top: -5;
    left: -90px;
    animation: spinReverse 4s linear infinite;
}

@@keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

@@keyframes spinReverse {
    from { transform: rotate(0deg); }
    to { transform: rotate(-360deg); }
}

/* Construction box */
.construction-box {
    background: linear-gradient(135deg, rgba(102,126,234,.15), rgba(118,75,162,.12));
    border-left: 5px solid #667eea;
    padding: 22px 26px;
    border-radius: 12px;
    margin-bottom: 30px;
}

.construction-box h2 {
    margin: 0 0 6px;
    font-size: 1.5rem;
    color: #667eea;
}

.construction-box p {
    margin: 0;
    color: #495057;
    font-size: .95rem;
}

/* KPIs */
.kpis {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
    opacity: .9;
}

.kpi {
    background: #f8f9fa;
    border-radius: 12px;
    padding: 20px;
    box-shadow: inset 0 0 0 1px rgba(0,0,0,.05);
    animation: pulse 2.5s infinite;
}

.kpi h3 {
    font-size: .85rem;
    color: #6c757d;
    margin-bottom: 6px;
}

.kpi span {
    font-size: 1.8rem;
    font-weight: 700;
    color: #667eea;
}

@@keyframes pulse {
    0%, 100% { opacity: .6; }
    50% { opacity: 1; }
}

/* Chart */
.chart {
    background: #f8f9fa;
    border-radius: 14px;
    padding: 25px;
    opacity: .78;
}

.chart-title {
    font-size: .9rem;
    color: #6c757d;
    margin-bottom: 14px;
}

.bars {
    display: flex;
    align-items: flex-end;
    gap: 10px;
    height: 150px;
}

.bar {
    flex: 1;
    background: linear-gradient(180deg, #667eea, #7AB5F8);
    border-radius: 6px 6px 0 0;
    animation: loading 1.4s infinite alternate;
}

.bar:nth-child(1) { height: 30%; }
.bar:nth-child(2) { height: 55%; animation-delay: .2s; }
.bar:nth-child(3) { height: 45%; animation-delay: .4s; }
.bar:nth-child(4) { height: 70%; animation-delay: .6s; }
.bar:nth-child(5) { height: 40%; animation-delay: .8s; }

@@keyframes loading {
    from { transform: scaleY(.6); }
    to { transform: scaleY(1); }
}

/* Footer */
.bi-footer {
    margin-top: 35px;
    text-align: center;
}

.bi-footer p {
    font-size: .95rem;
    color: #6c757d;
    margin-bottom: 18px;
}

.bi-footer a {
    display: inline-block;
    padding: 12px 28px;
    border-radius: 10px;
    background: linear-gradient(135deg, #667eea, #7AB5F8);
    color: white;
    font-weight: 600;
    text-decoration: none;
    transition: all .2s ease;
}

.bi-footer a:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 30px rgba(102,126,234,.5);
}

 .btn-bi-back {
    display: inline-block;
    padding: 12px 28px;
    border-radius: 10px;
    background: linear-gradient(135deg, #667eea, #7AB5F8);
    color: white;
    font-weight: 600;
    text-decoration: none;
}

</style>

<div class="bi-container">
    <div class="bi-card">

        <div class="ribbon"> - - -  - - EN CONSTRUCCIÓN</div>

        <div class="bi-header">
            <div>
                <div class="bi-title">Business Intelligence</div>
                <div class="bi-subtitle">Dashboards · KPIs · Analítica</div>
            </div>
            <div class="bi-icon">
                <i class="fas fa-cog gear big"></i>
                <i class="fas fa-cog gear small"></i>
            </div>
        </div>

        <div class="construction-box">
            <h2>🚧 Módulo en desarrollo</h2>
            <p>
                El módulo de Inteligencia de Negocio se encuentra actualmente en construcción.
                Próximamente contará con dashboards interactivos, KPIs estratégicos,
                reportes dinámicos y visualización avanzada.
            </p>
        </div>

        <div class="kpis">
            <div class="kpi"><h3>Ingresos</h3><span>--</span></div>
            <div class="kpi"><h3>Órdenes</h3><span>--</span></div>
            <div class="kpi"><h3>Margen</h3><span>--</span></div>
            <div class="kpi"><h3>Tendencia</h3><span>--</span></div>
        </div>

        <div class="chart"> 
            <div class="bars">
                <div class="bar"></div>
                <div class="bar"></div>
                <div class="bar"></div>
                <div class="bar"></div>
                <div class="bar"></div>
            </div>
        </div>

        
<div class="bi-footer">
    <p>
        Este módulo se habilitará una vez completadas las integraciones
        de datos, validaciones y controles de seguridad.
    </p>

    <a href="/" class="btn-bi-back">
        <i class="fas fa-arrow-left me-2"></i> Volver al Portal
    </a>
</div>


    </div>
</div>