@page "/compras"
@model WebApp.Pages.ComprasPageModel
@{
    ViewData["Title"] = "Gestión de Compras";
}

<div class="container-fluid px-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Compras</h1>
        </div>
        <div class="col-md-4 text-end">
            @if (Model.CanCreate)
            {
                <form method="post" asp-page-handler="Create" style="display: inline;">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Nueva Compra
                    </button>
                </form>
            }
            else
            {
                <button type="button" class="btn btn-primary" disabled title="No tienes permiso para crear">
                    <i class="fas fa-plus"></i> Nueva Compra
                </button>
            }
        </div>
    </div>

    @if (Model.UserPermissions.Count == 0)
    {
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-triangle"></i>
            No tienes permisos en este módulo.
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>Tus permisos:</strong> @string.Join(", ", Model.UserPermissions)
        </div>

        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Descripción</th>
                        <th>Fecha</th>
                        <th>Monto</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Aquí van las filas de compras -->
                    <tr>
                        <td>1</td>
                        <td>Compra de materiales</td>
                        <td>2024-01-15</td>
                        <td>$5,000.00</td>
                        <td>
                            @if (Model.CanEdit)
                            {
                                <form method="post" asp-page-handler="Edit" asp-route-id="1" style="display: inline;">
                                    <button type="submit" class="btn btn-sm btn-warning">
                                        <i class="fas fa-edit"></i> Editar
                                    </button>
                                </form>
                            }
                            @if (Model.CanDelete)
                            {
                                <form method="post" asp-page-handler="Delete" asp-route-id="1" style="display: inline;" 
                                      onsubmit="return confirm('¿Estás seguro?');">
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        <i class="fas fa-trash"></i> Eliminar
                                    </button>
                                </form>
                            }
                            <a href="#" class="btn btn-sm btn-info">
                                <i class="fas fa-eye"></i> Ver
                            </a>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    button[disabled] {
        opacity: 0.6;
        cursor: not-allowed;
    }
</style>
