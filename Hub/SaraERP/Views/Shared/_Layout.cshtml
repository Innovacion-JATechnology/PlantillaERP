@using UserRoles.Identity.Services
@using UserRoles.Identity.Constants
@using Microsoft.AspNetCore.Identity
@inject SignInManager<UserRoles.Identity.Models.Users> SignInManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@ViewData["Title"] - ERP</title>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/custom-sidebar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sidebar-collapse.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tables-common.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/productos-custom.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/fullscreen.css" asp-append-version="true" />
    <!-- Dynamic Colors from Database -->
    <link rel="stylesheet" href="@Url.Action("GetDynamicColors", "Settings")" />
    <link rel="stylesheet" href="~/lib/fontawesome/css/all.min.css" />

    
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
<meta http-equiv="Pragma" content="no-cache" />
<meta http-equiv="Expires" content="0" />

</head>

<body class="sb-nav-fixed">

    
    @if (!User.Identity.IsAuthenticated  && !Context.Request.Path.StartsWithSegments("/Account"))
{
    <script>
        window.location.replace('/Account/Login');
    </script>
}

    <!-- Top Navigation Bar -->
    <nav class="sb-topnav navbar navbar-expand navbar-dark d-flex align-items-center">
        <a class="navbar-brand ps-3 flex-shrink-0" asp-area="" asp-controller="Home" asp-action="Index">
            <img src="~/images/saralogo.png" alt="Sara Logo" style="height: 40px; width: auto;" />
            <span class="brand-text ms-2"> ERP</span>
        </a>

        <!-- Hamburger Menu (Collapse/Expand Sidebar) -->
        <button class="btn btn-link btn-sm order-lg-0 ms-2" id="sidebarCollapseToggle" title="Mostrar/Ocultar menú">
            <i class="fas fa-bars" style="color: white; font-size: 1.5rem;"></i>
        </button>

        <!-- Breadcrumb Navigation -->
        @await Html.PartialAsync("_Breadcrumb")

        <!-- Fullscreen Button -->
        <button class="btn btn-link btn-sm ms-2" id="fullscreenToggle" data-bs-toggle="tooltip" title="Pantalla completa" data-fullscreen-state="exited" style="color: white;">
            <i class="fas fa-maximize" style="font-size: 1.2rem; display: inline-block;"></i>
        </button>

        <!-- User Menu Dropdown -->
        <div class="navbar-menu-container ms-auto">
            @if (SignInManager.IsSignedIn(User))
            {
                <div class="dropdown">
                    <button class="navbar-menu-btn dropdown-toggle" type="button" id="userMenuDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="fas fa-user-circle"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenuDropdown">
                        <li><a class="dropdown-item" href="javascript:void(0);"><i class="fas fa-cog"></i> Configuración</a></li>
                        <li><a class="dropdown-item" asp-action="ColorSettings" asp-controller="Settings"><i class="fas fa-palette"></i> Colores</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="javascript:void(0);" onclick="logout();"><i class="fas fa-sign-out-alt"></i> Salir</a></li>
                    </ul>
                </div>
            }
            else
            {
                <a class="nav-link text-light" asp-page="/Account/Login">
                    <i class="fas fa-sign-in-alt"></i> Ingresar
                </a>
            }
        </div>
    </nav>

    <!-- Layout Container with Sidebar -->
    <div id="layoutSidenav"> 
        <div id="layoutSidenav_nav"> 
            <nav class="sb-sidenav accordion sb-sidenav-dark" id="sidenavAccordion"> 

                @inject IPermissionService PermissionService
                @using System.Security.Claims
            @using UserRoles.Identity.Constants

@{
                    var userId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
                    var userModules = userId != null
                        ? await PermissionService.GetUserModulesAsync(userId)
                        : new List<string>();
                }

                <div class="sb-sidenav-menu">
                    <div class="nav">
                        <!-- Módulos disponibles para el usuario -->
                        @{
                            var moduleIcons = new Dictionary<string, string>
                            {
                                { "Administracion", "fas fa-sliders-h" },
                                { "Compras", "fas fa-shopping-cart" },
                                { "Finanzas", "fas fa-money-bill" },
                                { "Inventario", "fas fa-boxes" },
                                { "Mantenimiento", "fas fa-wrench" },
                                { "Produccion", "fas fa-industry" },
                                { "Proyectos", "fas fa-briefcase" },
                                { "Reporteador", "fas fa-chart-line" },
                                { "RRHH", "fas fa-users" }
                            };

                            var allModules = new List<string>
                            {
                                "Administracion", "Compras", "Finanzas", "Inventario",
                                "Mantenimiento", "Produccion", "Proyectos", "Reporteador", "RRHH"
                            };
                        }

                        @foreach (var module in allModules)
                        {
                            var iconClass = moduleIcons.ContainsKey(module) ? moduleIcons[module] : "fas fa-folder";
                            var hasAccess = userModules.Contains(module);

                            @if (hasAccess)
                            {
                                <a class="nav-link" asp-action="@module" asp-controller="Modules" 
                                   title="@module" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-trigger="hover">
                                    <div class="sb-nav-link-icon">
                                        <i class="@iconClass"></i>
                                    </div>
                                    <span>@module</span>
                                </a>
                            }
                            else
                            {
                                <div class="nav-link nav-link-disabled" title="Sin permiso para acceder" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-trigger="hover">
                                    <div class="sb-nav-link-icon">
                                        <i class="@iconClass"></i>
                                    </div>
                                    <span>@module</span>
                                </div>
                            }
                        }
                    </div>
                </div>


                <div class="sb-sidenav-footer">
                    <div class="small">Conectado como:</div>
                    <div>
                        @{
                            var userEmail = User?.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "No disponible";
                            var userRoles = User?.Claims
                                .Where(c => c.Type == System.Security.Claims.ClaimTypes.Role)
                                .Select(c => c.Value)
                                .FirstOrDefault() ?? "Rol: N/A";
                        }
                        <strong>@userEmail</strong><br />
                        <small style="opacity: 0.8;">@userRoles</small>
                    </div>
                </div>
            </nav>
        </div>

        <div id="layoutSidenav_content">
            <main>
                <div class="container-fluid px-4">
                    @RenderBody()
                </div>
            </main>

            <footer class="border-top footer text-muted">
                <div class="container">
                    &copy; 2026 JA Technology - ERP 
                </div>
            </footer>
        </div>
    </div>

    <!-- Hidden form for Anti-Forgery Token -->
    <form id="logoutTokenForm" style="display:none;">
        @Html.AntiForgeryToken()
    </form>

    <script src="~/lib/jquery/jquery.min.js"></script>
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Logout function - Opción A: Una sola confirmación, logout directo
        function logout() {
            if (confirm('¿Está seguro de que desea cerrar sesión?')) {
                // Crear form para hacer POST directo al logout
                var form = document.createElement('form');
                form.method = 'post';
                form.action = '/Account/Logout';

                // Obtener el token anti-forgery si existe
                var token = document.querySelector('input[name="__RequestVerificationToken"]');
                if (token) {
                    var tokenInput = document.createElement('input');
                    tokenInput.type = 'hidden';
                    tokenInput.name = '__RequestVerificationToken';
                    tokenInput.value = token.value;
                    form.appendChild(tokenInput);
                }

                document.body.appendChild(form);
                form.submit();
            }
        }

        // Initialize tooltips and fullscreen button
        function initializePageElements() {
            console.log('🚀 initializePageElements() called');

            // Initialize all tooltips
            const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            console.log('📌 Found', tooltipTriggerList.length, 'tooltip elements');
            tooltipTriggerList.map(tooltipTriggerEl => new bootstrap.Tooltip(tooltipTriggerEl));

            // Initialize fullscreen button
            const fullscreenToggle = document.getElementById('fullscreenToggle');
            console.log('🔘 fullscreenToggle element:', fullscreenToggle);

            if (fullscreenToggle) {
                console.log('✅ fullscreenToggle found, attaching click listener');
                fullscreenToggle.addEventListener('click', function(e) {
                    e.preventDefault();
                    console.log('🖱️ Fullscreen button clicked!');
                    toggleFullscreen();
                });

                // Listen for fullscreen changes (all variants)
                document.addEventListener('fullscreenchange', () => {
                    console.log('📡 fullscreenchange event fired');
                    updateFullscreenIcon();
                });
                document.addEventListener('webkitfullscreenchange', () => {
                    console.log('📡 webkitfullscreenchange event fired');
                    updateFullscreenIcon();
                });
                document.addEventListener('mozfullscreenchange', () => {
                    console.log('📡 mozfullscreenchange event fired');
                    updateFullscreenIcon();
                });
                document.addEventListener('msfullscreenchange', () => {
                    console.log('📡 msfullscreenchange event fired');
                    updateFullscreenIcon();
                });

                // Initialize icon on page load
                console.log('🎨 Initializing icon on page load');
                updateFullscreenIcon();
            } else {
                console.error('❌ fullscreenToggle button NOT found');
            }
        }

        // Run initialization when DOM is ready, or immediately if already loaded
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initializePageElements);
        } else {
            initializePageElements();
        }

        // Fullscreen functionality
        function updateFullscreenIcon(isFullscreen) {
            const fullscreenToggle = document.getElementById('fullscreenToggle');
            if (!fullscreenToggle) {
                console.warn('❌ fullscreenToggle button not found');
                return;
            }

            // Use the passed state parameter or detect it
            if (isFullscreen === undefined) {
                isFullscreen = !!(
                    document.fullscreenElement ||
                    document.webkitFullscreenElement ||
                    document.mozFullScreenElement ||
                    document.msFullscreenElement
                );
            }

            console.log('🔄 updateFullscreenIcon called with isFullscreen:', isFullscreen);

            if (isFullscreen) {
                console.log('✅ Setting to MINIMIZE state');
                // Replace entire icon HTML - Font Awesome v6 converts <i> to <svg>, so we need to set the HTML directly
                fullscreenToggle.innerHTML = '<i class="fas fa-minimize" style="font-size: 1.2rem;"></i>';
                fullscreenToggle.title = 'Salir de pantalla completa';
                fullscreenToggle.setAttribute('data-bs-original-title', 'Salir de pantalla completa');
                fullscreenToggle.setAttribute('data-fullscreen-state', 'entered');
                fullscreenToggle.setAttribute('aria-label', 'Salir de pantalla completa');

                // Update tooltip by getting the instance and updating it
                const tooltipInstance = bootstrap.Tooltip.getInstance(fullscreenToggle);
                if (tooltipInstance) {
                    console.log('✅ Updating tooltip text');
                    tooltipInstance.dispose();
                    new bootstrap.Tooltip(fullscreenToggle, { title: 'Salir de pantalla completa' });
                }
            } else {
                console.log('✅ Setting to MAXIMIZE state');
                // Replace entire icon HTML - Font Awesome v6 converts <i> to <svg>, so we need to set the HTML directly
                fullscreenToggle.innerHTML = '<i class="fas fa-maximize" style="font-size: 1.2rem;"></i>';
                fullscreenToggle.title = 'Pantalla completa';
                fullscreenToggle.setAttribute('data-bs-original-title', 'Pantalla completa');
                fullscreenToggle.setAttribute('data-fullscreen-state', 'exited');
                fullscreenToggle.setAttribute('aria-label', 'Pantalla completa');

                // Update tooltip by getting the instance and updating it
                const tooltipInstance = bootstrap.Tooltip.getInstance(fullscreenToggle);
                if (tooltipInstance) {
                    console.log('✅ Updating tooltip text');
                    tooltipInstance.dispose();
                    new bootstrap.Tooltip(fullscreenToggle, { title: 'Pantalla completa' });
                }
            }
        }

        function toggleFullscreen() {
            const elem = document.documentElement;

            // Verificar estado actual
            const isCurrentlyFullscreen = !!(
                document.fullscreenElement ||
                document.webkitFullscreenElement ||
                document.mozFullScreenElement ||
                document.msFullscreenElement
            );

            console.log('🖱️ Toggle button clicked. Currently fullscreen?', isCurrentlyFullscreen);

            if (!isCurrentlyFullscreen) {
                // Entrar a fullscreen
                console.log('📺 Attempting to enter fullscreen...');
                if (elem.requestFullscreen) {
                    elem.requestFullscreen()
                        .then(() => {
                            console.log('✅ Fullscreen promise resolved, scheduling icon update...');
                            // Small delay to ensure browser updates fullscreenElement
                            setTimeout(() => {
                                console.log('⏰ Timeout fired, calling updateFullscreenIcon(true)');
                                updateFullscreenIcon(true);
                            }, 10);
                        })
                        .catch(err => console.error('❌ Fullscreen error:', err));
                } else if (elem.webkitRequestFullscreen) {
                    console.log('🔧 Using webkit fullscreen');
                    elem.webkitRequestFullscreen();
                    setTimeout(() => updateFullscreenIcon(true), 50);
                } else if (elem.mozRequestFullScreen) {
                    console.log('🔧 Using moz fullscreen');
                    elem.mozRequestFullScreen();
                    setTimeout(() => updateFullscreenIcon(true), 50);
                } else if (elem.msRequestFullscreen) {
                    console.log('🔧 Using ms fullscreen');
                    elem.msRequestFullscreen();
                    setTimeout(() => updateFullscreenIcon(true), 50);
                }
            } else {
                // Salir de fullscreen
                console.log('📺 Attempting to exit fullscreen...');
                if (document.exitFullscreen) {
                    document.exitFullscreen()
                        .then(() => {
                            console.log('✅ Exit fullscreen promise resolved, scheduling icon update...');
                            // Small delay to ensure browser updates fullscreenElement
                            setTimeout(() => {
                                console.log('⏰ Timeout fired, calling updateFullscreenIcon(false)');
                                updateFullscreenIcon(false);
                            }, 10);
                        })
                        .catch(err => console.error('❌ Exit fullscreen error:', err));
                } else if (document.webkitExitFullscreen) {
                    console.log('🔧 Using webkit exit fullscreen');
                    document.webkitExitFullscreen();
                    setTimeout(() => updateFullscreenIcon(false), 50);
                } else if (document.mozCancelFullScreen) {
                    console.log('🔧 Using moz cancel fullscreen');
                    document.mozCancelFullScreen();
                    setTimeout(() => updateFullscreenIcon(false), 50);
                } else if (document.msExitFullscreen) {
                    console.log('🔧 Using ms exit fullscreen');
                    document.msExitFullscreen();
                    setTimeout(() => updateFullscreenIcon(false), 50);
                }
            }
        }
      

        </script>
    <script src="~/js/sidebar-collapse.js" asp-append-version="true"></script>
    <script>
        window.addEventListener('pageshow', function (event) {
        if (event.persisted) {
        // Page was restored from back-forward cache
        window.location.reload();
        }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>



</html>
