@using System.Security.Claims
@using UserRoles.Identity.Constants
@using UserRoles.Identity.Services
@inject IPermissionService PermissionService

@{
    ViewData["Title"] = "Inicio";
    var userId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

    // Define which sub-modules belong to each parent module
    var moduleSubmodules = new Dictionary<string, List<string>>
    {
        { ModuleNames.Compras, new List<string> { ModuleNames.Compras } },
        { ModuleNames.Inventario, new List<string> { ModuleNames.Inventario } },
        { ModuleNames.Finanzas, new List<string> { ModuleNames.Finanzas } },
        { ModuleNames.Mantenimiento, new List<string> { ModuleNames.Mantenimiento } },
        { ModuleNames.Produccion, new List<string> { ModuleNames.Produccion } },
        { ModuleNames.RRHH, new List<string> { ModuleNames.RRHH } },
        { ModuleNames.Proyectos, new List<string> { ModuleNames.Proyectos } },
        { ModuleNames.Reporteador, new List<string> { ModuleNames.Reporteador } },
        { ModuleNames.Administracion, new List<string> { ModuleNames.Administracion } }
    };

    // Helper function to check if user has access to module or any of its sub-modules
    async Task<bool> UserCanAccessModule(string moduleName)
    {
        if (string.IsNullOrEmpty(userId))
            return false;

        // Admin users have access to all modules
        if (User.IsInRole("Admin"))
            return true;

        // Check if user has access to the module itself
        if (await PermissionService.UserHasModuleAccessAsync(userId, moduleName))
            return true;

        // For now, just check the module itself (can be extended if needed)
        return false;
    }
}

<div class="modules-container">


    <div class="modules-grid">
        <!-- Compras Module -->
        @{
            var comprasAccess = await UserCanAccessModule(ModuleNames.Compras);
        }
        @if (comprasAccess)
        {
            <a asp-action="Compras" asp-controller="Modules" class="module-card compras">
                <div class="module-icon">
                    <i class="fas fa-shopping-cart"></i>
                </div>
                <h3 class="module-title">Compras</h3>
                <p class="module-description">Gestión de compras e importaciones</p>
            </a>
        }
        else
        {
