@{
    ViewData["Title"] = "Control de Calidad";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Producción", Url.Action("Produccion", "Modules")),
        ("Control de Calidad", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-check-circle"></i>
            Control de Calidad
        </h1>
        <p>Verifica y garantiza la calidad de los productos antes de la distribución</p>
    </div>

    <!-- Toolbar con botón de acción -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-primary">
            <i class="fas fa-plus"></i>
            Nueva Inspección
        </button>
    </div>

    <!-- Tarjetas de Estadísticas -->
    <div class="stats-container">
        <div class="row g-4">
            <div class="col-lg-3 col-md-6">
                <div class="stat-card stat-info">
                    <div class="card-body">
                        <div class="stat-label">Inspeccionadas</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-clipboard-check stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="stat-card stat-success">
                    <div class="card-body">
                        <div class="stat-label">Aprobadas</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-thumbs-up stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="stat-card stat-warning">
                    <div class="card-body">
                        <div class="stat-label">En Revisión</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-hourglass-half stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="stat-card stat-danger">
                    <div class="card-body">
                        <div class="stat-label">Rechazadas</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-thumbs-down stat-icon"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de Inspecciones -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-list"></i>
                Inspecciones de Calidad
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>N° Inspección</th>
                        <th>Producto</th>
                        <th>Lote</th>
                        <th>Fecha Inspección</th>
                        <th>Inspector</th>
                        <th>Resultado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="fas fa-check-circle"></i>
                                <h5>No hay inspecciones disponibles</h5>
                                <p>Registra tus primeras inspecciones de calidad para comenzar</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
