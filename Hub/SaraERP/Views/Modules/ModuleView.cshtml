@using System.Security.Claims
@using SaraERP.Models
@using UserRoles.Identity.Constants;
@using UserRoles.Identity.Services
@inject IPermissionService PermissionService

@{
    ViewData["Title"] = (string)ViewData["Title"];
    var moduleOptions = (List<Dictionary<string, string>>)ViewData["ModuleOptions"];
    var userId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

    var processedOptions = new List<ModuleOptionView>();

    if (moduleOptions != null && moduleOptions.Count > 0)
    {
        foreach (var option in moduleOptions)
        {
            var submoduleName = option.GetValueOrDefault("Action", "Opción");
            
            var moduleName = option.GetValueOrDefault("Controller", "Opción");

            var submoduleNameKey = moduleName + "." + submoduleName; 

            var hasAccess = !string.IsNullOrEmpty(userId) &&
                (User.IsInRole("Admin") 
                ||
                 await PermissionService.UserHasPermissionAsync(userId, submoduleNameKey, PermissionNames.View)
                ||
                 await PermissionService.UserHasPermissionAsync(userId, submoduleNameKey, PermissionNames.Create)
                ||
                 await PermissionService.UserHasPermissionAsync(userId, submoduleNameKey, PermissionNames.Edit)
                ||
                 await PermissionService.UserHasPermissionAsync(userId, submoduleNameKey, PermissionNames.Delete));

            processedOptions.Add(new ModuleOptionView
            {
                Data = option,
                HasAccess = hasAccess
            });
        }
    }
}

<div class="container-fluid">
@if (processedOptions.Count > 0)
{
    <div class="row">
        <div class="col-md-12">
            <div class="modules-grid">
                @foreach (var item in processedOptions)
                {
                    var option = item.Data;
                    var hasAccess = item.HasAccess;

                    var moduleName = option.GetValueOrDefault("Name", "Opción");
                    var action = option.GetValueOrDefault("Action", "#");
                    var controller = option.GetValueOrDefault("Controller", "Modules");
                    var icon = option.GetValueOrDefault("Icon", "fas fa-folder");
                    var description = option.GetValueOrDefault("Description", "");
                    var cssClass = option.GetValueOrDefault("CssClass", ""); 
                    
                        @if (hasAccess)                           
                        {
                                <a asp-action="@action" asp-controller="@controller" class="module-card @cssClass">
                                    <div class="module-icon">
                                        <i class="@icon"></i>
                                    </div>
                                    <h3 class="module-title">@moduleName</h3>
                                    <p class="module-description">@description</p>
                                </a>
                            }
else
{
    <div class="module-card @cssClass module-card-disabled"
         title="No tienes acceso a este módulo">
        <div class="module-icon">
            <i class="@icon"></i>
        </div>
        <h3 class="module-title">@moduleName</h3>
                                <p class="module-description">@description</p>
                                <span class="module-locked-indicator">
                                    <i class="fas fa-lock"></i> Bloqu k k k k eado
                                </span>
    </div>
}


                }
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-info">
        <i class="fas fa-info-circle me-2"></i>
        Este módulo aún no tiene opciones disponibles.
    </div>
}
</div>
