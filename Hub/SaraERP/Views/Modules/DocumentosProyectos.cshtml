@{
    ViewData["Title"] = "Documentos de Proyectos";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Proyectos", Url.Action("Proyectos", "Modules")),
        ("Documentos", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-file-contract"></i>
            Documentos de Proyectos
        </h1>
        <p>Gestiona y organiza toda la documentación de tus proyectos</p>
    </div>

    <!-- Toolbar con botón de acción -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-primary">
            <i class="fas fa-upload"></i>
            Subir Documento
        </button>
    </div>

    <!-- Tarjetas de Estadísticas -->
    <div class="stats-container">
        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <div class="stat-card stat-info">
                    <div class="card-body">
                        <div class="stat-label">Total Documentos</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-file stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="stat-card stat-danger">
                    <div class="card-body">
                        <div class="stat-label">PDF</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-file-pdf stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="stat-card stat-warning">
                    <div class="card-body">
                        <div class="stat-label">Word</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-file-word stat-icon"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de Documentos -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-table"></i>
                Documentos Registrados
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Tipo</th>
                        <th>Proyecto</th>
                        <th>Fecha Carga</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="5">
                            <div class="empty-state">
                                <i class="fas fa-file-alt"></i>
                                <h5>No hay documentos disponibles</h5>
                                <p>Sube tu primer documento del proyecto</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
