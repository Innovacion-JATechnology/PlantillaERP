@{
    ViewData["Title"] = "Equipos";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Mantenimiento", Url.Action("Mantenimiento", "Modules")),
        ("Equipos", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-cogs"></i>
            Gestión de Equipos
        </h1>
        <p>Administra y controla todos los equipos y maquinaria de la empresa</p>
    </div>

    <!-- Toolbar con botón de acción -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-primary">
            <i class="fas fa-plus"></i>
            Registrar Equipo
        </button>
    </div>

    <!-- Tabla de Equipos -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-tools"></i>
                Equipos Disponibles
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Nombre</th>
                        <th>Tipo</th>
                        <th>Ubicación</th>
                        <th>Estado</th>
                        <th>Último Mantenimiento</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="fas fa-wrench"></i>
                                <h5>No hay equipos registrados</h5>
                                <p>Registra tu primer equipo para comenzar</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
