@{
    ViewData["Title"] = "Almacenes";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Inventario", Url.Action("Inventario", "Modules")),
        ("Almacenes", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-warehouse"></i>
            Gestión de Almacenes
        </h1>
        <p>Administra la ubicación y capacidad de tus almacenes</p>
    </div>

    <!-- Toolbar con botón de acción -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-primary">
            <i class="fas fa-plus"></i>
            Nuevo Almacén
        </button>
    </div>

    <!-- Tabla de Almacenes -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-building"></i>
                Almacenes del Sistema
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Nombre</th>
                        <th>Ubicación</th>
                        <th>Capacidad Total</th>
                        <th>Ocupación</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="fas fa-warehouse"></i>
                                <h5>No hay almacenes registrados</h5>
                                <p>Crea tu primer almacén para comenzar la gestión de inventario</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
