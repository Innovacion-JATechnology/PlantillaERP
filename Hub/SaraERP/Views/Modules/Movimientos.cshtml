@{
    ViewData["Title"] = "Movimientos de Inventario";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Inventario", Url.Action("Inventario", "Modules")),
        ("Movimientos", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-exchange-alt"></i>
            Movimientos de Inventario
        </h1>
        <p>Consulta y registra todos los movimientos de entrada y salida</p>
    </div>

    <!-- Toolbar con botón de acción -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-primary">
            <i class="fas fa-plus"></i>
            Registrar Movimiento
        </button>
    </div>

    <!-- Tabla de Movimientos -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-list-alt"></i>
                Historial de Movimientos
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Tipo Movimiento</th>
                        <th>Producto</th>
                        <th>Almacén</th>
                        <th>Cantidad</th>
                        <th>Usuario</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="fas fa-boxes"></i>
                                <h5>No hay movimientos registrados</h5>
                                <p>Los movimientos de inventario aparecerán aquí</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
