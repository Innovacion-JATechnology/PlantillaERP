@{
    ViewData["Title"] = "Órdenes de Producción";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Producción", Url.Action("Produccion", "Modules")),
        ("Órdenes", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-industry"></i>
            Órdenes de Producción
        </h1>
        <p>Gestiona y controla todas las órdenes de producción de tu empresa</p>
    </div>

    <!-- Toolbar con botón de acción -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-primary">
            <i class="fas fa-plus"></i>
            Nueva Orden
        </button>
    </div>

    <!-- Tarjetas de Estadísticas -->
    <div class="stats-container">
        <div class="row g-4">
            <div class="col-lg-3 col-md-6">
                <div class="stat-card stat-info">
                    <div class="card-body">
                        <div class="stat-label">Pendientes</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-hourglass-half stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="stat-card stat-warning">
                    <div class="card-body">
                        <div class="stat-label">En Proceso</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-cogs stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="stat-card stat-success">
                    <div class="card-body">
                        <div class="stat-label">Completadas</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-check-circle stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="stat-card stat-danger">
                    <div class="card-body">
                        <div class="stat-label">Canceladas</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-times-circle stat-icon"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de Órdenes -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-list"></i>
                Órdenes Registradas
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>N° Orden</th>
                        <th>Producto</th>
                        <th>Cantidad</th>
                        <th>Fecha Inicio</th>
                        <th>Fecha Fin</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="fas fa-industry"></i>
                                <h5>No hay órdenes disponibles</h5>
                                <p>Crea tu primera orden de producción para comenzar</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
