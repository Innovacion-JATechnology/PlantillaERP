@{
    ViewData["Title"] = "Reportes de Inventario";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Inventario", Url.Action("Inventario", "Modules")),
        ("Reportes", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-chart-bar"></i>
            Reportes de Inventario
        </h1>
        <p>Analiza datos detallados sobre stock, movimientos y valuación de inventario</p>
    </div>

    <!-- Tarjetas de Estadísticas -->
    <div class="stats-container">
        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <div class="stat-card stat-info">
                    <div class="card-body">
                        <div class="stat-label">Productos Totales</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-box stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="stat-card stat-warning">
                    <div class="card-body">
                        <div class="stat-label">Stock Bajo</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-exclamation-circle stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="stat-card stat-success">
                    <div class="card-body">
                        <div class="stat-label">Valor Inventario</div>
                        <div class="stat-value">$0</div>
                        <i class="fas fa-coins stat-icon"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Reportes Disponibles -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-chart-line"></i>
                Reportes Disponibles
            </h6>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="report-card">
                        <div class="report-header stat-info">
                            <i class="fas fa-boxes"></i>
                        </div>
                        <div class="report-body">
                            <h6>Reporte de Stock Actual</h6>
                            <p class="text-muted">Estado actual del inventario por ubicación y categoría</p>
                            <button class="professional-btn professional-btn-primary professional-btn-sm">
                                <i class="fas fa-download"></i>
                                Generar
                            </button>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="report-card">
                        <div class="report-header stat-warning">
                            <i class="fas fa-bell"></i>
                        </div>
                        <div class="report-body">
                            <h6>Productos con Bajo Stock</h6>
                            <p class="text-muted">Productos que requieren reorden inmediato</p>
                            <button class="professional-btn professional-btn-warning professional-btn-sm">
                                <i class="fas fa-download"></i>
                                Generar
                            </button>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="report-card">
                        <div class="report-header stat-success">
                            <i class="fas fa-chart-pie"></i>
                        </div>
                        <div class="report-body">
                            <h6>Valuación de Inventario</h6>
                            <p class="text-muted">Valor total del inventario y análisis por categoría</p>
                            <button class="professional-btn professional-btn-success professional-btn-sm">
                                <i class="fas fa-download"></i>
                                Generar
                            </button>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="report-card">
                        <div class="report-header stat-danger">
                            <i class="fas fa-exchange-alt"></i>
                        </div>
                        <div class="report-body">
                            <h6>Reporte de Movimientos</h6>
                            <p class="text-muted">Entrada, salida y ajustes de inventario en período seleccionado</p>
                            <button class="professional-btn professional-btn-danger professional-btn-sm">
                                <i class="fas fa-download"></i>
                                Generar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.report-card {
    border: 1px solid #e9ecef;
    border-radius: 8px;
    overflow: hidden;
    transition: all 0.3s ease;
    height: 100%;
}

.report-card:hover {
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
}

.report-header {
    padding: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    color: white;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.report-header.stat-info {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.report-header.stat-success {
    background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
}

.report-header.stat-warning {
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.report-header.stat-danger {
    background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
}

.report-body {
    padding: 20px;
}

.report-body h6 {
    margin-bottom: 8px;
    font-weight: 600;
    color: #2d3748;
}

.report-body p {
    margin-bottom: 16px;
    font-size: 13px;
}
</style>
