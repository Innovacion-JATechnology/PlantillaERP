@{
    ViewData["Title"] = "Permisos y Vacaciones";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("RRHH", Url.Action("RRHH", "Modules")),
        ("Permisos y Vacaciones", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-umbrella-beach"></i>
            Permisos y Vacaciones
        </h1>
        <p>Gestiona las solicitudes de permisos y períodos vacacionales</p>
    </div>

    <!-- Toolbar con botón de acción -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-primary">
            <i class="fas fa-plus"></i>
            Nueva Solicitud
        </button>
    </div>

    <!-- Tabla de Permisos -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-calendar-alt"></i>
                Solicitudes Registradas
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>Empleado</th>
                        <th>Tipo</th>
                        <th>Fecha Desde</th>
                        <th>Fecha Hasta</th>
                        <th>Días</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="fas fa-calendar-times"></i>
                                <h5>No hay solicitudes disponibles</h5>
                                <p>Las solicitudes de permisos y vacaciones aparecerán aquí</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
