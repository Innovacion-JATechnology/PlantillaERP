@{
    ViewData["Title"] = "Contratos";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Compras", Url.Action("Compras", "Modules")),
        ("Contratos", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-file-signature"></i>
            Gestión de Contratos
        </h1>
        <p>Administra los contratos con proveedores y clientes</p>
    </div>

    <!-- Toolbar con botón de acción -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-primary">
            <i class="fas fa-plus"></i>
            Nuevo Contrato
        </button>
    </div>

    <!-- Tabla de Contratos -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-file-contract"></i>
                Contratos Registrados
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>N° Contrato</th>
                        <th>Tipo</th>
                        <th>Proveedor/Cliente</th>
                        <th>Fecha Inicio</th>
                        <th>Fecha Vencimiento</th>
                        <th>Valor</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="8">
                            <div class="empty-state">
                                <i class="fas fa-file-alt"></i>
                                <h5>No hay contratos disponibles</h5>
                                <p>Registra tu primer contrato para comenzar</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
