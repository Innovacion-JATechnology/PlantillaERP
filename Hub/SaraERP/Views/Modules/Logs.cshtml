@{
    ViewData["Title"] = "Logs";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Administración", Url.Action("Administracion", "Modules")),
        ("Logs", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-file-lines"></i>
            Registro de Eventos del Sistema
        </h1>
        <p>Monitorea y analiza todos los eventos registrados en el sistema</p>
    </div>

    <!-- Toolbar con filtros -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-outline">
            <i class="fas fa-filter"></i>
            Filtrar Eventos
        </button>
    </div>

    <!-- Tarjetas de Estadísticas -->
    <div class="stats-container">
        <div class="row g-4">
            <div class="col-lg-3 col-md-6">
                <div class="stat-card stat-info">
                    <div class="card-body">
                        <div class="stat-label">Total Eventos</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-list stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="stat-card stat-success">
                    <div class="card-body">
                        <div class="stat-label">Informativos</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-info-circle stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="stat-card stat-warning">
                    <div class="card-body">
                        <div class="stat-label">Advertencias</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-exclamation-triangle stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="stat-card stat-danger">
                    <div class="card-body">
                        <div class="stat-label">Errores</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-times-circle stat-icon"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de Logs -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-list"></i>
                Registro de Eventos
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>Fecha y Hora</th>
                        <th>Nivel</th>
                        <th>Mensaje</th>
                        <th>Origen</th>
                        <th>Usuario</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="6">
                            <div class="empty-state">
                                <i class="fas fa-file-lines"></i>
                                <h5>No hay eventos registrados</h5>
                                <p>Los eventos del sistema aparecerán aquí</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
