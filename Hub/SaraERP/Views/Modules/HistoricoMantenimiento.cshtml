@{
    ViewData["Title"] = "Histórico de Mantenimiento";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Mantenimiento", Url.Action("Mantenimiento", "Modules")),
        ("Histórico", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-history"></i>
            Histórico de Mantenimiento
        </h1>
        <p>Consulta el historial completo de trabajos y actividades de mantenimiento realizados</p>
    </div>

    <!-- Toolbar con botón de acción -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-primary">
            <i class="fas fa-download"></i>
            Exportar Reporte
        </button>
    </div>

    <!-- Tarjetas de Estadísticas -->
    <div class="stats-container">
        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <div class="stat-card stat-info">
                    <div class="card-body">
                        <div class="stat-label">Total Trabajos</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-tools stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="stat-card stat-success">
                    <div class="card-body">
                        <div class="stat-label">Preventivo</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-shield-alt stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="stat-card stat-warning">
                    <div class="card-body">
                        <div class="stat-label">Correctivo</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-wrench stat-icon"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de Histórico -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-table"></i>
                Historial de Trabajos
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Equipo</th>
                        <th>Tipo</th>
                        <th>Técnico</th>
                        <th>Duración</th>
                        <th>Costo</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="fas fa-inbox"></i>
                                <h5>Sin registros disponibles</h5>
                                <p>El historial de trabajos de mantenimiento aparecerá aquí</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
