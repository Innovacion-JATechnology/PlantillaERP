                    function getUserFormState() {
            const data = {};

            $('#formCompra')
                .find('input, select, textarea')
                .not('#formMode, #isDirty, #hfOriginalId')
                .each(function () {
                    const $el = $(this);
                    const name = $el.attr('id');

                    if (!name) return;

                    data[name] = $el.val() ?? '';
                });
                 
            return JSON.stringify(data);
        }

            function mostrarMensaje(mensaje, tipo) {
                var alertDiv = $('#mensajeAlert');
                alertDiv.removeClass('d-none alert-success alert-danger alert-warning alert-info');
                alertDiv.addClass('alert-' + tipo);
                alertDiv.html('<strong>' + (tipo === 'success' ? '<i class="fas fa-check-circle me-2"></i>' : '<i class="fas fa-exclamation-circle me-2"></i>') + '</strong>' + mensaje);

                $('html, body').animate({
                    scrollTop: 0
                }, 300);

                setTimeout(function () {
                    alertDiv.addClass('d-none');
                }, 5000);
            }
        });
    </script>
