            // ============= MANEJO DE PERMISOS =============
            // Mostrar alerta si intenta hacer clic en botón deshabilitado
            $(document).on('click', '.btn-editar:disabled, .btn-nueva-compra:disabled', function(e) {
                e.preventDefault();
                var mensaje = 'No tienes permiso para realizar esta acción';
                mostrarMensaje(mensaje, 'warning');
                return false;
            });
 

            // Manejar eliminación desde la tabla
            $(document).on('click', '.btn-eliminar', function () {
                var id = $(this).data('id');
                var contract = $(this).data('contract');

                if (!id) return;

                if (confirm('¿Está seguro de que desea eliminar la compra ' + contract + '?')) {
                    $.ajax({
                        url: '@Url.Action("EliminarCompra", "Compras")',
                        type: 'POST',
                        data: { id: id },
                        success: function (response) {
                            if (response.success) {
                                mostrarMensaje(response.message, 'success');
                                setTimeout(function () {
                                    window.location.reload();
                                }, 1500);
                            } else {
                                mostrarMensaje(response.message, 'danger');
                            }
                        },
                        error: function () {
                            mostrarMensaje('Error al eliminar la compra.', 'danger');
                        }
                    });
                }
            });

            
             
