@section Scripts {
    <script>

    function loadFiles(contract) {
    if (!contract) return;
    const isReadonly = $('#formMode').val() === 'readonly';
    $.ajax({
    url: '@Url.Action("GetFiles", "Compras")',
    type: 'GET',
    cache: false,              // ✅ IMPORTANT
    data: { contract },
    success: function (files) {
        const tbody = $('#filesTable tbody');
        tbody.empty();

        if (!files.length) {
            tbody.append(`
                <tr>
                    <td colspan="3" class="text-center text-muted">No hay archivos</td>
                </tr>
            `);
            return;
        }

        const isReadonly = $('#formMode').val() === 'readonly';

        files.forEach(f => {
            tbody.append(`
                <tr>
                    <td>
                        <a href="${f.url}" target="_blank">${f.name}</a>
                    </td>
                    <td>${(f.size / 1024).toFixed(1)}</td>
                    <td class="text-center">
                        ${isReadonly
                            ? '<span class="text-muted">—</span>'
                            : `
                                <button class="btn btn-sm btn-danger btn-delete-file"
                                        data-file="${f.name}">
                                    <i class="fas fa-trash"></i>
                                </button>
                              `}
                    </td>
                </tr>
            `);
        });
    }
});
   
     }

     $(document).on('click', '.btn-delete-file', function () {
    const fileName = $(this).data('file'); 
    const contract = $('#txtContract').val().trim();


    if (!confirm('¿Eliminar archivo?')) return;

    $.post('@Url.Action("DeleteFile", "Compras")', {
        contract,
        fileName
    }).done(function () {
        loadFiles(contract);
    });
});

   $('#btnUploadFile').click(function () {
    console.log("UPLOAD CLICK");

    const fileInput = $('#fileUpload')[0];
    const contract = $('#txtContract').val().trim();
    const id = $('#hfOriginalId').val();

    if (!id) {
        mostrarMensaje('Guarde la compra antes de subir archivos', 'warning');
        return;
    }

    if (!fileInput.files.length) return;

    const data = new FormData();
    data.append('file', fileInput.files[0]);
    data.append('contract', contract);

    $.ajax({
        url: '@Url.Action("UploadFile", "Compras")',
        type: 'POST',
        data: data,
        contentType: false,
        processData: false,
        success: function (res) {
            if (!res.success) {
                mostrarMensaje(res.message, 'danger');
                return;
            }

            mostrarMensaje('Archivo subido correctamente', 'success');

            $('#fileUpload').val('');
            $('#btnUploadFile').prop('disabled', true);

            // ✅ This WILL now run
            renderFiles(res.files);
        },
        error: function () {
            mostrarMensaje('Error al subir el archivo', 'danger');
        }
    });
});

    function renderFiles(files) {
    const tbody = $('#filesTable tbody');
    tbody.empty();

    if (!files || !files.length) {
        tbody.append(`
            <tr>
                <td colspan="3" class="text-center text-muted">No hay archivos</td>
            </tr>
        `);
        return;
    }

    const isReadonly = $('#formMode').val() === 'readonly';

    files.forEach(f => {
        tbody.append(`
            <tr>
                <td><a href="${f.url}" target="_blank">${f.name}</a></td>
                <td>${(f.size / 1024).toFixed(1)}</td>
                <td class="text-center">
                    ${isReadonly ? '<span class="text-muted">—</span>' : `
                        <button class="btn btn-sm btn-danger btn-delete-file"
                                data-file="${f.name}">
                            <i class="fas fa-trash"></i>
                        </button>`}
                </td>
            </tr>
        `);
    });
}
    

