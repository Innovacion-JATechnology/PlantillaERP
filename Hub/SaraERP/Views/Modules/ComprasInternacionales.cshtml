        function confirmDiscardChanges() {
            const isDirty = $('#isDirty').val() === 'true';
            const mode = $('#formMode').val();

            if (!mode || mode === 'idle') return true;

            if ((mode === 'edit' || mode === 'create') && isDirty) {
                return confirm('Hay cambios sin guardar. ¿Desea continuar sin guardar?');
            }

            return true;
        }


            
