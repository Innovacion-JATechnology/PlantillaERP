@{
    ViewData["Title"] = "Ajustes de Inventario";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Inventario", Url.Action("Inventario", "Modules")),
        ("Ajustes", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-sliders-h"></i>
            Ajustes de Inventario
        </h1>
        <p>Realiza y controla los ajustes en el inventario de productos</p>
    </div>

    <!-- Toolbar con botón de acción -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-primary">
            <i class="fas fa-plus"></i>
            Nuevo Ajuste
        </button>
    </div>

    <!-- Tabla de Ajustes -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-edit"></i>
                Ajustes Realizados
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Producto</th>
                        <th>Almacén</th>
                        <th>Tipo Ajuste</th>
                        <th>Cantidad</th>
                        <th>Motivo</th>
                        <th>Usuario</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="8">
                            <div class="empty-state">
                                <i class="fas fa-balance-scale"></i>
                                <h5>No hay ajustes disponibles</h5>
                                <p>Los ajustes de inventario aparecerán aquí</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
