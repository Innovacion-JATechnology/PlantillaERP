@{
    ViewData["Title"] = "Evaluaciones";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("RRHH", Url.Action("RRHH", "Modules")),
        ("Evaluaciones", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-star"></i>
            Evaluaciones de Desempeño
        </h1>
        <p>Realiza y consulta evaluaciones del desempeño de tu equipo</p>
    </div>

    <!-- Toolbar con botón de acción -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-primary">
            <i class="fas fa-plus"></i>
            Nueva Evaluación
        </button>
    </div>

    <!-- Tabla de Evaluaciones -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-chart-line"></i>
                Evaluaciones del Desempeño
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>Empleado</th>
                        <th>Período</th>
                        <th>Evaluador</th>
                        <th>Puntuación</th>
                        <th>Fecha</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="fas fa-clipboard-check"></i>
                                <h5>No hay evaluaciones disponibles</h5>
                                <p>Crea tu primera evaluación de desempeño</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
