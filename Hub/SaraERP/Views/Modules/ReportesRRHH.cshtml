@{
    ViewData["Title"] = "Reportes RRHH";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Recursos Humanos", Url.Action("RRHH", "Modules")),
        ("Reportes", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-chart-pie"></i>
            Reportes de Recursos Humanos
        </h1>
        <p>Accede a reportes analíticos sobre tu personal y nómina</p>
    </div>

    <!-- Reportes Cards -->
    <div class="reports-grid">
        <div class="row g-4">
            <div class="col-lg-6 col-md-12">
                <div class="stat-card stat-info">
                    <div class="card-body">
                        <h6><i class="fas fa-users me-2"></i>Nómina de Personal</h6>
                        <p>Listado completo de empleados activos e inactivos</p>
                        <button class="professional-btn professional-btn-info professional-btn-sm">
                            <i class="fas fa-download me-1"></i>Generar
                        </button>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 col-md-12">
                <div class="stat-card stat-success">
                    <div class="card-body">
                        <h6><i class="fas fa-chart-bar me-2"></i>Análisis de Recursos</h6>
                        <p>Estadísticas de personal y distribución por áreas</p>
                        <button class="professional-btn professional-btn-success professional-btn-sm">
                            <i class="fas fa-download me-1"></i>Generar
                        </button>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 col-md-12">
                <div class="stat-card stat-warning">
                    <div class="card-body">
                        <h6><i class="fas fa-stopwatch me-2"></i>Ausentismo y Tardanzas</h6>
                        <p>Análisis de asistencia y puntualidad</p>
                        <button class="professional-btn professional-btn-warning professional-btn-sm">
                            <i class="fas fa-download me-1"></i>Generar
                        </button>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 col-md-12">
                <div class="stat-card stat-danger">
                    <div class="card-body">
                        <h6><i class="fas fa-coins me-2"></i>Costo de Nómina</h6>
                        <p>Análisis de gastos en recursos humanos</p>
                        <button class="professional-btn professional-btn-danger professional-btn-sm">
                            <i class="fas fa-download me-1"></i>Generar
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
