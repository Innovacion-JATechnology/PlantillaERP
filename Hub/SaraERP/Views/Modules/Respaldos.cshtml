@{
    ViewData["Title"] = "Respaldos";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Administración", Url.Action("Administracion", "Modules")),
        ("Respaldos", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-database"></i>
            Gestión de Respaldos
        </h1>
        <p>Administra las copias de seguridad del sistema</p>
    </div>

    <!-- Toolbar con botón de acción -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-primary">
            <i class="fas fa-plus"></i>
            Crear Respaldo
        </button>
    </div>

    <!-- Tabla de Respaldos -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-backup"></i>
                Copias de Seguridad
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>Fecha de Respaldo</th>
                        <th>Tamaño</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="4">
                            <div class="empty-state">
                                <i class="fas fa-inbox"></i>
                                <h5>No hay respaldos disponibles</h5>
                                <p>Crea tu primer respaldo para proteger los datos</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
