@{
    ViewData["Title"] = "Flujo de Caja";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Finanzas", Url.Action("Finanzas", "Modules")),
        ("Flujo de Caja", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-chart-line"></i>
            Flujo de Caja
        </h1>
        <p>Analiza y proyecta el flujo de efectivo de tu empresa</p>
    </div>

    <!-- Toolbar con botón de acción -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-primary">
            <i class="fas fa-file-export"></i>
            Exportar Reporte
        </button>
    </div>

    <!-- Tarjetas de Estadísticas -->
    <div class="stats-container">
        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <div class="stat-card stat-success">
                    <div class="card-body">
                        <div class="stat-label">Ingresos Proyectados</div>
                        <div class="stat-value">$0</div>
                        <i class="fas fa-arrow-up stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="stat-card stat-danger">
                    <div class="card-body">
                        <div class="stat-label">Egresos Proyectados</div>
                        <div class="stat-value">$0</div>
                        <i class="fas fa-arrow-down stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="stat-card stat-info">
                    <div class="card-body">
                        <div class="stat-label">Flujo Neto</div>
                        <div class="stat-value">$0</div>
                        <i class="fas fa-balance-scale stat-icon"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de Flujo -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-water"></i>
                Análisis de Flujo de Caja
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>Período</th>
                        <th>Saldo Inicial</th>
                        <th>Ingresos</th>
                        <th>Egresos</th>
                        <th>Flujo Neto</th>
                        <th>Saldo Final</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="fas fa-chart-area"></i>
                                <h5>No hay datos disponibles</h5>
                                <p>Los registros de flujo de caja aparecerán aquí</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
