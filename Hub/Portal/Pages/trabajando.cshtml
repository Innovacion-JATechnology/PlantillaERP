
@page
@model Portal.Pages.trabajandoModel
@{
    Layout = null;
    ViewData["Title"] = "CRM - En Construcción";
}

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      crossorigin="anonymous" />

<style>
html, body {
    margin: 0;
    padding: 0;
    height: 100%;
    font-family: 'Segoe UI', system-ui, sans-serif;
    background: linear-gradient(135deg, #667eea, #764ba2);
}

/* Container */
.crm-container {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
}

/* Card */
.crm-card {
    position: relative;
    background: #ffffff;
    border-radius: 18px;
    max-width: 980px;
    width: 100%;
    padding: 45px;
    box-shadow: 0 35px 80px rgba(0,0,0,.35);
    animation: fadeUp .6s ease-out;
    overflow: hidden;
}

/* Animations */
@@keyframes fadeUp {
    from { opacity: 0; transform: translateY(25px); }
    to   { opacity: 1; transform: translateY(0); }
}

@@keyframes spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
}

@@keyframes spinReverse {
    from { transform: rotate(0deg); }
    to   { transform: rotate(-360deg); }
}

@@keyframes pulse {
    0%, 100% { opacity: .6; }
    50% { opacity: 1; }
}

/* Ribbon */
.ribbon {
    position: absolute;
    top: 38px;
    right: -80px;
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: #fff;
    padding: 14px 100px;
    transform: rotate(45deg);
    font-weight: 800;
    letter-spacing: .15em;
    box-shadow: 0 10px 30px rgba(0,0,0,.35);
}

/* Header */
.crm-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
}

.crm-title {
    font-size: 2.3rem;
    font-weight: 800;
    color: #667eea;
}

.crm-subtitle {
    font-size: 1.05rem;
    color: #6c757d;
}

/* Gears */
.crm-icon {
    width: 140px;
    height: 140px;
    position: relative;
}

.gear {
    position: absolute;
    color: #667eea;
    transform-origin: center;
}

.gear.big {
    font-size: 90px;
    top: 35px;
    left: 10px;
    animation: spin 6s linear infinite;
    filter: drop-shadow(0 8px 18px rgba(102,126,234,.4));
}

.gear.small {
    font-size: 52px;
    top: 0;
    left: 75px;
    animation: spinReverse 4s linear infinite;
    opacity: .85;
}

/* Construction box */
.construction-box {
    background: linear-gradient(
        135deg,
        rgba(102,126,234,.15),
        rgba(118,75,162,.12)
    );
    border-left: 5px solid #667eea;
    padding: 22px 26px;
    border-radius: 12px;
    margin-bottom: 32px;
}

.construction-box h2 {
    margin: 0 0 8px;
    font-size: 1.5rem;
    color: #667eea;
}

.construction-box p {
    margin: 0;
    color: #495057;
    font-size: .95rem;
    line-height: 1.6;
}

/* KPIs */
.kpis {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
}

.kpi {
    background: #f8f9fa;
    border-radius: 12px;
    padding: 20px;
    box-shadow: inset 0 0 0 1px rgba(0,0,0,.05);
    animation: pulse 2.8s infinite;
    text-align: center;
}

.kpi h3 {
    font-size: .85rem;
    color: #6c757d;
    margin-bottom: 6px;
}

.kpi span {
    font-size: 1.7rem;
    font-weight: 700;
    color: #667eea;
}

/* CRM Pipeline */
.pipeline {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 18px;
    margin-bottom: 35px;
}

.stage {
    background: linear-gradient(
        135deg,
        rgba(102,126,234,.18),
        rgba(118,75,162,.15)
    );
    border-radius: 14px;
    padding: 20px;
    text-align: center;
    box-shadow: inset 0 0 0 1px rgba(0,0,0,.05);
    animation: pulse 3s infinite;
}

.stage-title {
    display: block;
    font-size: .85rem;
    font-weight: 600;
    color: #6c757d;
    margin-bottom: 6px;
}

.stage-count {
    display: block;
    font-size: 1.6rem;
    font-weight: 800;
    color: #667eea;
}

/* Footer */
.crm-footer {
    text-align: center;
}

.crm-footer p {
    font-size: .95rem;
    color: #6c757d;
    margin-bottom: 18px;
}

.btn-back {
    display: inline-block;
    padding: 12px 28px;
    border-radius: 10px;
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: #fff;
    font-weight: 600;
    text-decoration: none;
    transition: all .2s ease;
}

.btn-back:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 30px rgba(102,126,234,.5);
}

/* CRM Pipeline Flow */
.pipeline {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 14px;
    margin-bottom: 35px;
}

/* Pipeline stage */
.stage {
    background: linear-gradient(
        135deg,
        rgba(102,126,234,.18),
        rgba(118,75,162,.15)
    );
    border-radius: 14px;
    padding: 18px 20px;
    min-width: 140px;
    text-align: center;
    box-shadow: inset 0 0 0 1px rgba(0,0,0,.05);
    animation: pulse 3s infinite;
}

/* Arrow between stages */
.arrow {
    font-size: 1.6rem;
    color: #667eea;
    animation: arrowMove 1.6s infinite ease-in-out;
}

/* Arrow animation */
@@keyframes arrowMove {
    0%   { transform: translateX(0); opacity: .4; }
    50%  { transform: translateX(6px); opacity: 1; }
    100% { transform: translateX(0); opacity: .4; }
}

/* Responsive: vertical flow */
@@media (max-width: 768px) {
    .pipeline {
        flex-direction: column;
    }

    .arrow {
        transform: rotate(90deg);
    }
}

</style>

<div class="crm-container">
    <div class="crm-card">

        <div class="ribbon"> - - - -  EN CONSTRUCCIÓN - </div>

        <div class="crm-header">
            <div>
                <div class="crm-title">Customer Relationship Management</div>
                <div class="crm-subtitle">Clientes · Oportunidades · Seguimiento</div>
            </div>
            <div class="crm-icon">
                <i class="fas fa-cog gear big"></i>
                <i class="fas fa-cog gear small"></i>
            </div>
        </div>

        <div class="construction-box">
            <h2>🚧 Módulo CRM en desarrollo</h2>
            <p>
                El módulo de <strong>Customer Relationship Management (CRM)</strong> se encuentra actualmente
                en construcción. Este espacio estará diseñado para centralizar la gestión de clientes,
                oportunidades comerciales y el seguimiento del ciclo de ventas.
                <br /><br />
                Próximamente se habilitarán funcionalidades como la administración de prospectos,
                seguimiento de oportunidades, control de actividades y pipeline comercial.
            </p>
        </div>

        

      <div class="pipeline">
    <div class="stage"> 
        <span class="stage-title">Prospectos</span>
        <span class="stage-count">--</span>
    </div>

    <div class="arrow">
        <i class="fas fa-arrow-right"></i>
    </div>

    <div class="stage">
        <span class="stage-title">Contactados</span>
        <span class="stage-count">--</span>
    </div>

    <div class="arrow">
        <i class="fas fa-arrow-right"></i>
    </div>

    <div class="stage">
        <span class="stage-title">Propuestas</span>
        <span class="stage-count">--</span>
    </div>

    <div class="arrow">
        <i class="fas fa-arrow-right"></i>
    </div>

    <div class="stage">
        <span class="stage-title">Negociación</span>
        <span class="stage-count">--</span>
    </div>

    <div class="arrow">
        <i class="fas fa-arrow-right"></i>
    </div>

    <div class="stage">
        <span class="stage-title">Cerrados</span>
        <span class="stage-count">--</span>
    </div>
</div>



        <div class="crm-footer">
            <p>
                Este módulo se habilitará una vez completadas las integraciones,
                validaciones funcionales y controles de seguridad correspondientes.
            </p>

            <a href="/" class="btn-back">
                <i class="fas fa-arrow-left me-2"></i> Volver al Portal
            </a>
        </div>

    </div>
</div>
