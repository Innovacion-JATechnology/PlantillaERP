@page
@model Portal.Pages.trabajandoModel
@{
    Layout = null;
    ViewData["Title"] = "SaraCRM - En construcción";
}

<style>
    html, body {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100%;
    }

    .coming-soon-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 20px;
    }

    .coming-soon-card {
        background: #ffffff;
        max-width: 540px;
        width: 100%;
        border-radius: 16px;
        padding: 50px 40px;
        box-shadow: 0 25px 60px rgba(0,0,0,.2);
        text-align: center;
        animation: fadeUp .5s ease-out;
    }

    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .module-icon {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea, #764ba2);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 28px;
        font-weight: 700;
        margin: 0 auto 20px;
    }

    .title {
        font-size: 2rem;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 10px;
    }

    .subtitle {
        font-size: 1.1rem;
        color: #6c757d;
        margin-bottom: 20px;
    }

    .message {
        font-size: .95rem;
        color: #495057;
        line-height: 1.6;
        margin-bottom: 25px;
    }

    .features {
        text-align: left;
        list-style: none;
        padding: 0;
        margin: 0 0 30px;
    }

    .features li {
        padding-left: 24px;
        margin-bottom: 10px;
        position: relative;
        font-size: .95rem;
        color: #343a40;
    }

    .features li::before {
        content: "✓";
        position: absolute;
        left: 0;
        color: #667eea;
        font-weight: bold;
    }

    .progress {
        height: 10px;
        border-radius: 6px;
        overflow: hidden;
        background: #e9ecef;
        margin-bottom: 30px;
    }

    .progress-bar {
        width: 35%;
        background: linear-gradient(135deg, #667eea, #764ba2);
    }

    .actions {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .actions a {
        text-decoration: none;
        font-weight: 600;
        border-radius: 8px;
        padding: 12px;
        transition: all .2s ease;
    }

    .btn-primary {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
    }

    .btn-primary:hover {
        opacity: .9;
    }

    .btn-secondary {
        background: #f1f3f5;
        color: #343a40;
    }

    .btn-secondary:hover {
        background: #e9ecef;
    }
</style>

<div class="coming-soon-container">
    <div class="coming-soon-card">

        <div class="module-icon">CRM</div>

        <h1 class="title">SaraCRM</h1>
        <p class="subtitle">Módulo en construcción</p>

        <p class="message">
            Estamos desarrollando el módulo de gestión de clientes y ventas
            para integrarlo de forma nativa con SaraERP.
        </p>

        <ul class="features">
            <li>Gestión de clientes y contactos</li>
            <li>Seguimiento de oportunidades</li>
            <li>Historial de interacciones</li>
            <li>Reportes comerciales y métricas</li>
        </ul>

        <div class="progress">
            <div class="progress-bar"></div>
        </div>

        <div class="actions">
            <a href="/" class="btn-primary">Volver al Portal</a>
           
        </div>

    </div>
</div>