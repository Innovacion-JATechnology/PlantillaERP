<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@ViewData["Title"] - ERP</title>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/custom-sidebar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sidebar-collapse.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tables-common.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/productos-custom.css" asp-append-version="true" />
    <!-- Dynamic Colors from Database -->
    <link rel="stylesheet" href="@Url.Action("GetDynamicColors", "Settings")" />
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>
</head>
<body class="sb-nav-fixed">
    <!-- Top Navigation Bar -->
    <nav class="sb-topnav navbar navbar-expand navbar-dark d-flex align-items-center">
        <a class="navbar-brand ps-3 flex-shrink-0" asp-area="" asp-controller="Home" asp-action="Index">
            <img src="~/images/saralogo.png" alt="Sara Logo" style="height: 40px; width: auto;" />
            <span class="brand-text ms-2"> ERP</span>
        </a>

        <!-- Breadcrumb Navigation -->
        @await Html.PartialAsync("_Breadcrumb")

        <!-- User Menu Dropdown -->
        <div class="navbar-menu-container ms-auto">
            <div class="dropdown">
                <button class="navbar-menu-btn dropdown-toggle" type="button" id="userMenuDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="fas fa-user-circle"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenuDropdown">
                    <li><a class="dropdown-item" href="javascript:void(0);"><i class="fas fa-cog"></i> Configuración</a></li>
                    <li><a class="dropdown-item" asp-action="ColorSettings" asp-controller="Settings"><i class="fas fa-palette"></i> Colores</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item" href="javascript:void(0);" onclick="logout();"><i class="fas fa-sign-out-alt"></i> Salir</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Layout Container with Sidebar -->
    <div id="layoutSidenav"> 
        <div id="layoutSidenav_nav"> 
            <nav class="sb-sidenav accordion sb-sidenav-dark" id="sidenavAccordion">
                <div class="sb-sidenav-menu">

                    <button class="btn btn-link btn-sm text-white" id="sidebarCollapseToggle"
                    type="button" title="Contraer/Expandir sidebar">
                        <i class="fas fa-bars"></i>
                    </button>

                     



                    <div class="nav">

                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index" data-bs-toggle="tooltip" data-bs-placement="right" title="Inicio">
                            <div class="sb-nav-link-icon"><i class="fas fa-home"></i></div>
                            <span>Inicio</span>
                        </a>


                        <div class="sb-sidenav-menu-heading">Módulos</div>

                        <!-- Compras Module -->
                        <a class="nav-link module-compras" asp-action="Compras" asp-controller="Modules" data-bs-toggle="tooltip" data-bs-placement="right" title="Compras">
                            <div class="sb-nav-link-icon"><i class="fas fa-shopping-cart"></i></div>
                            <span>Compras</span>
                        </a>

                        <!-- Inventario Module -->
                        <a class="nav-link module-inventario" asp-action="Inventario" asp-controller="Modules" data-bs-toggle="tooltip" data-bs-placement="right" title="Inventario">
                            <div class="sb-nav-link-icon"><i class="fas fa-box"></i></div>
                            <span>Inventario</span>
                        </a>

                        <!-- Finanzas Module -->
                        <a class="nav-link module-finanzas" asp-action="Finanzas" asp-controller="Modules" data-bs-toggle="tooltip" data-bs-placement="right" title="Finanzas">
                            <div class="sb-nav-link-icon"><i class="fas fa-money-bill-wave"></i></div>
                            <span>Finanzas</span>
                        </a>

                        <!-- Mantenimiento Module -->
                        <a class="nav-link module-mantenimiento" asp-action="Mantenimiento" asp-controller="Modules" data-bs-toggle="tooltip" data-bs-placement="right" title="Mantenimiento">
                            <div class="sb-nav-link-icon"><i class="fas fa-wrench"></i></div>
                            <span>Mantenimiento</span>
                        </a>

                        <!-- Produccion Module -->
                        <a class="nav-link module-produccion" asp-action="Produccion" asp-controller="Modules" data-bs-toggle="tooltip" data-bs-placement="right" title="Produccion">
                            <div class="sb-nav-link-icon"><i class="fas fa-cog"></i></div>
                            <span>Produccion</span>
                        </a>

                        <!-- RRHH Module -->
                        <a class="nav-link module-rrhh" asp-action="RRHH" asp-controller="Modules" data-bs-toggle="tooltip" data-bs-placement="right" title="RRHH">
                            <div class="sb-nav-link-icon"><i class="fas fa-users"></i></div>
                            <span>RRHH</span>
                        </a>

                        <!-- Proyectos Module -->
                        <a class="nav-link module-proyectos" asp-action="Proyectos" asp-controller="Modules" data-bs-toggle="tooltip" data-bs-placement="right" title="Proyectos">
                            <div class="sb-nav-link-icon"><i class="fas fa-building"></i></div>
                            <span>Proyectos</span>
                        </a>

                        <!-- Reporteador Module -->
                        <a class="nav-link module-reporteador" asp-action="Reporteador" asp-controller="Modules" data-bs-toggle="tooltip" data-bs-placement="right" title="Reporteador">
                            <div class="sb-nav-link-icon"><i class="fas fa-chart-line"></i></div>
                            <span>Reporteador</span>
                        </a>

                        <!-- Administracion Module -->
                        <a class="nav-link module-administracion" asp-action="Administracion" asp-controller="Modules" data-bs-toggle="tooltip" data-bs-placement="right" title="Administracion">
                            <div class="sb-nav-link-icon"><i class="fas fa-sliders-h"></i></div>
                            <span>Administración</span>
                        </a>

                        
                    </div>
                </div>
                <div class="sb-sidenav-footer">
                    <div class="small">Conectado como:</div>
                    <div>Administrador</div>
                </div>
            </nav>
        </div>

        <div id="layoutSidenav_content">
            <main>
                <div class="container-fluid px-4">
                    @RenderBody()
                </div>
            </main>

            <footer class="border-top footer text-muted">
                <div class="container">
                    &copy; 2026 JATechnology - ERP - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                </div>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/jquery.min.js"></script>
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Logout function
        function logout() {
            if (confirm('¿Está seguro de que desea cerrar sesión?')) {
                window.location.href = '@Url.Action("Index", "Home")';
            }
        }

        // Initialize tooltips only
        document.addEventListener('DOMContentLoaded', function() {
            const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(tooltipTriggerEl => new bootstrap.Tooltip(tooltipTriggerEl));
        });
    </script>
    <script src="~/js/sidebar-collapse.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
