@{
    var breadcrumbs = ViewData["Breadcrumbs"] as List<(string Title, string Url)> ?? new List<(string, string)>();
    var inicioUrl = Url.Page("/Index") ?? "/";

    // Verificar si el primer elemento ya es "Inicio"
    var primerEsInicio = breadcrumbs.Count > 0 && breadcrumbs[0].Title.Equals("Inicio", StringComparison.OrdinalIgnoreCase);
}

<div class="breadcrumb-nav">
    <nav aria-label="breadcrumb">
        <!-- Siempre mostrar Inicio como enlace si no está en la lista -->
        @if (!primerEsInicio)
        {
            <a href="@inicioUrl" class="breadcrumb-link">Inicio</a>
            @if (breadcrumbs.Count > 0)
            {
                <span class="breadcrumb-separator"> › </span>
            }
        }

        @for (int i = 0; i < breadcrumbs.Count; i++)
        {
            var breadcrumb = breadcrumbs[i];

            @if (i < breadcrumbs.Count - 1)
            {
                <a href="@breadcrumb.Url" class="breadcrumb-link">@breadcrumb.Title</a>
                <span class="breadcrumb-separator"> › </span>
            }
            else
            {
                <span class="breadcrumb-active">@breadcrumb.Title</span>
            }
        }
    </nav>
</div>
