@{
    ViewData["Title"] = "Mantenimiento Correctivo";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Mantenimiento", Url.Action("Mantenimiento", "Modules")),
        ("Mantenimiento Correctivo", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-wrench"></i>
            Mantenimiento Correctivo
        </h1>
        <p>Registra y gestiona las reparaciones y mantenimientos correctivos</p>
    </div>

    <!-- Toolbar con botón de acción -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-danger">
            <i class="fas fa-plus"></i>
            Nueva Reparación
        </button>
    </div>

    <!-- Tabla de Reparaciones -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-hammer"></i>
                Reparaciones y Correctivos
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>Equipo</th>
                        <th>Problema Detectado</th>
                        <th>Fecha Reporte</th>
                        <th>Técnico Asignado</th>
                        <th>Prioridad</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="fas fa-tools"></i>
                                <h5>No hay reparaciones disponibles</h5>
                                <p>Las reparaciones y mantenimientos correctivos aparecerán aquí</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
