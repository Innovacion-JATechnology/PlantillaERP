@{
    ViewData["Title"] = "Cuentas por Pagar";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Finanzas", Url.Action("Finanzas", "Modules")),
        ("Cuentas por Pagar", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-credit-card"></i>
            Cuentas por Pagar
        </h1>
        <p>Administra y controla las obligaciones de pago de tu empresa</p>
    </div>

    <!-- Toolbar con botón de acción -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-primary">
            <i class="fas fa-plus"></i>
            Nueva Cuenta
        </button>
    </div>

    <!-- Tarjetas de Estadísticas -->
    <div class="stats-container">
        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <div class="stat-card stat-danger">
                    <div class="card-body">
                        <div class="stat-label">Total Adeudado</div>
                        <div class="stat-value">$0</div>
                        <i class="fas fa-hand-holding-usd stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="stat-card stat-warning">
                    <div class="card-body">
                        <div class="stat-label">Vencidas</div>
                        <div class="stat-value">$0</div>
                        <i class="fas fa-exclamation-triangle stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="stat-card stat-info">
                    <div class="card-body">
                        <div class="stat-label">Próximas a Vencer</div>
                        <div class="stat-value">$0</div>
                        <i class="fas fa-calendar-alt stat-icon"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de Cuentas -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-file-invoice"></i>
                Cuentas por Pagar
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>Proveedor</th>
                        <th>N° Documento</th>
                        <th>Fecha Emisión</th>
                        <th>Fecha Vencimiento</th>
                        <th>Monto</th>
                        <th>Saldo Pendiente</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="8">
                            <div class="empty-state">
                                <i class="fas fa-file-contract"></i>
                                <h5>No hay cuentas disponibles</h5>
                                <p>Las cuentas por pagar aparecerán aquí</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
