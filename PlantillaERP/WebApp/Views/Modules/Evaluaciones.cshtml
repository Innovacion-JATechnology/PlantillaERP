@{
    ViewData["Title"] = "Evaluaciones";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("RRHH", Url.Action("RRHH", "Modules")),
        ("Evaluaciones", Url.Action("Evaluaciones", "Modules"))
    };
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">@ViewData["Title"]</h1>
        <button class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Nueva Evaluación
        </button>
    </div>

    <div class="card shadow">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">
                <i class="fas fa-star me-2"></i>Evaluaciones del Desempeño
            </h6>
        </div>
        <div class="card-body">
            <div class="alert alert-info">Sin evaluaciones disponibles</div>
        </div>
    </div>
</div>
