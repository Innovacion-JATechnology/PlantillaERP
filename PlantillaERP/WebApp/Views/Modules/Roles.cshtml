@model List<Microsoft.AspNetCore.Identity.IdentityRole>

@{
    ViewData["Title"] = "Roles";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Administración", Url.Action("Administracion", "Modules")),
        ("Roles", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-shield-alt"></i>
            Gestión de Roles
        </h1>
        <p>Administra los roles del sistema y sus características</p>
    </div>

    <!-- Toolbar con botón de acción -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-primary" data-bs-toggle="modal" data-bs-target="#modalNuevoRol">
            <i class="fas fa-plus"></i>
            Nuevo Rol
        </button>
    </div>

    <!-- Tabla de Roles -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-list"></i>
                Nómina de Roles
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table" id="tablaRoles">
                <thead>
                    <tr>
                        <th>Nombre del Rol</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        @foreach (var rol in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@rol.Name</strong>
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        @if (rol.Name != "Admin" && rol.Name != "Manager" && rol.Name != "User")
                                        {
                                            <button type="button" class="btn btn-sm btn-info" 
                                                    onclick="editarPermisos('@rol.Id', '@rol.Name')">
                                                <i class="fas fa-cog"></i>
                                            </button>
                                            <button type="button" class="btn btn-sm btn-warning" 
                                                    onclick="reasignarRol('@rol.Id', '@rol.Name')"
                                                    title="Reasignar usuarios de este rol a otro">
                                                <i class="fas fa-exchange-alt"></i>
                                            </button>
                                            <button type="button" class="btn btn-sm btn-danger" 
                                                    onclick="eliminarRol('@rol.Id', '@rol.Name')">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-sm btn-info" 
                                                    onclick="editarPermisos('@rol.Id', '@rol.Name')">
                                                <i class="fas fa-cog"></i>
                                            </button>
                                            <button type="button" class="btn btn-sm btn-warning" 
                                                    onclick="reasignarRol('@rol.Id', '@rol.Name')"
                                                    title="Reasignar usuarios de este rol a otro">
                                                <i class="fas fa-exchange-alt"></i>
                                            </button>
                                            <span class="badge bg-secondary" title="Este rol no puede ser eliminado">
                                                <i class="fas fa-lock"></i> Sistema
                                            </span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="2">
                                <div class="empty-state">
                                    <i class="fas fa-user-shield"></i>
                                    <h5>No hay roles registrados</h5>
                                    <p>Comienza agregando el primer rol al sistema</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Nuevo Rol -->
<div class="modal fade" id="modalNuevoRol" tabindex="-1" aria-labelledby="modalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalLabel">
                    <i class="fas fa-plus-circle"></i> Nuevo Rol
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="formularioRol">
                    @Html.AntiForgeryToken()
                    
                    <div class="mb-3">
                        <label for="nombreRol" class="form-label">Nombre del Rol *</label>
                        <input type="text" class="form-control" id="nombreRol" name="nombreRol" required>
                        <small class="text-muted">Ejemplo: Contador, Vendedor, Almacenista</small>
                    </div>

                    <div class="alert alert-info" id="mensajeError" style="display:none;">
                        <i class="fas fa-exclamation-circle"></i>
                        <span id="textoError"></span>
                    </div>

                    <div class="alert alert-success" id="mensajeExito" style="display:none;">
                        <i class="fas fa-check-circle"></i>
                        <span id="textoExito"></span>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" onclick="guardarRol()">
                    <i class="fas fa-save"></i> Guardar Rol
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Editar Permisos -->
<div class="modal fade" id="modalEditarPermisos" tabindex="-1" aria-labelledby="modalPermisosLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalPermisosLabel">
                    <i class="fas fa-key"></i> Gestionar Permisos - <span id="roleName"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="formularioPermisos">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="roleIdPermiso" value="">

                    <div id="permisosContainer">
                        <!-- Se cargará dinámicamente -->
                    </div>

                    <div class="alert alert-info" id="mensajeErrorPermisos" style="display:none;">
                        <i class="fas fa-exclamation-circle"></i>
                        <span id="textoErrorPermisos"></span>
                    </div>

                    <div class="alert alert-success" id="mensajeExitoPermisos" style="display:none;">
                        <i class="fas fa-check-circle"></i>
                        <span id="textoExitoPermisos"></span>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" onclick="guardarPermisos()">
                    <i class="fas fa-save"></i> Guardar Permisos
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Reasignar Rol -->
<div class="modal fade" id="modalReasignarRol" tabindex="-1" aria-labelledby="modalReasignarLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-warning bg-opacity-10">
                <h5 class="modal-title" id="modalReasignarLabel">
                    <i class="fas fa-exchange-alt"></i> Reasignar Usuarios - Rol: <span id="rolOrigenNombre"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="formularioReasignar">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="rolOrigenId" value="">

                    <div class="mb-4">
                        <h6 class="mb-3">
                            <i class="fas fa-users"></i> Usuarios a Reasignar
                        </h6>
                        <div id="containerUsuarios" style="max-height: 250px; overflow-y: auto; border: 1px solid #dee2e6; border-radius: 4px; padding: 1rem;">
                            <!-- Se cargará dinámicamente -->
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="rolDestinoId" class="form-label">
                            <i class="fas fa-arrow-right"></i> <strong>Rol de Destino *</strong>
                        </label>
                        <select class="form-control" id="rolDestinoId" required>
                            <option value="">Selecciona un rol...</option>
                        </select>
                        <small class="text-muted">Selecciona a cuál rol deseas reasignar estos usuarios</small>
                    </div>

                    <div class="alert alert-info">
                        <i class="fas fa-info-circle"></i>
                        <strong>Nota:</strong> Los usuarios serán removidos del rol actual y asignados al rol de destino.
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-warning" onclick="guardarReasignacion()">
                    <i class="fas fa-exchange-alt"></i> Reasignar Usuarios
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .empty-state {
        padding: 60px 20px;
        text-align: center;
        color: #7f8c8d;
    }

    .empty-state i {
        font-size: 3rem;
        color: #bdc3c7;
        margin-bottom: 20px;
    }

    .btn-group .btn {
        margin: 0 2px;
    }

    .badge {
        font-size: 0.85rem;
        padding: 0.5rem 0.75rem;
    }

    .module-section {
        margin-bottom: 2rem;
        padding: 1.5rem;
        background-color: #f8f9fa;
        border-left: 4px solid #007bff;
        border-radius: 4px;
    }

    .module-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #333;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .permissions-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 1rem;
    }

    .permission-item {
        display: flex;
        align-items: center;
        padding: 0.75rem;
        background: white;
        border-radius: 4px;
        border: 1px solid #dee2e6;
    }

    .permission-item input[type="checkbox"] {
        margin-right: 0.75rem;
        cursor: pointer;
    }

    .permission-item label {
        cursor: pointer;
        margin: 0;
        flex: 1;
    }

    .permission-description {
        font-size: 0.85rem;
        color: #6c757d;
        margin-top: 0.25rem;
    }

    /* Estilos para Modal de Reasignación */
    .usuarios-list {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .usuario-item {
        padding: 0.75rem;
        background: white;
        border-radius: 4px;
        border: 1px solid #dee2e6;
        transition: all 0.2s ease;
    }

    .usuario-item:hover {
        background-color: #f8f9fa;
        border-color: #ffc107;
    }

    .usuario-item input[type="checkbox"] {
        margin-right: 0.75rem;
        cursor: pointer;
    }

    .usuario-item label {
        cursor: pointer;
        margin: 0;
        flex: 1;
    }

    .modal-header.bg-warning {
        border-bottom: 2px solid #ffc107;
    }
</style>

<script>
    // Obtener token antiforgery
    function getAntiForgeryToken() {
        const tokenField = document.querySelector('input[name="__RequestVerificationToken"]');
        if (tokenField) {
            return tokenField.value;
        }
        return null;
    }

    // Crear nuevo rol
    function guardarRol() {
        const nombreRol = document.getElementById('nombreRol').value.trim();

        if (!nombreRol) {
            mostrarError('El nombre del rol es requerido');
            return;
        }

        const datos = {
            nombreRol: nombreRol
        };

        const token = getAntiForgeryToken();
        if (!token) {
            mostrarError('Token de seguridad no encontrado');
            return;
        }

        fetch('@Url.Action("CrearRol", "Roles")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            body: JSON.stringify(datos)
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                mostrarExito(data.message);
                setTimeout(() => {
                    location.reload();
                }, 1500);
            } else {
                mostrarError(data.message);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            mostrarError('Error al crear el rol');
        });
    }

    // Eliminar rol
    function eliminarRol(id, nombreRol) {
        if (confirm(`¿Está seguro de que desea eliminar el rol "${nombreRol}"?`)) {
            const token = getAntiForgeryToken();
            if (!token) {
                alert('Token de seguridad no encontrado');
                return;
            }

            fetch(`@Url.Action("EliminarRol", "Roles")?id=${id}`, {
                method: 'DELETE',
                headers: {
                    'RequestVerificationToken': token
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert(data.message);
                    location.reload();
                } else {
                    alert(data.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error al eliminar el rol');
            });
        }
    }

    // Mostrar mensaje de error
    function mostrarError(mensaje) {
        const errorDiv = document.getElementById('mensajeError');
        const textoError = document.getElementById('textoError');
        textoError.textContent = mensaje;
        errorDiv.style.display = 'block';
    }

    // Mostrar mensaje de éxito
    function mostrarExito(mensaje) {
        const exitoDiv = document.getElementById('mensajeExito');
        const textoExito = document.getElementById('textoExito');
        textoExito.textContent = mensaje;
        exitoDiv.style.display = 'block';
    }

    // Editar permisos de un rol
    async function editarPermisos(roleId, roleName) {
        document.getElementById('roleIdPermiso').value = roleId;
        document.getElementById('roleName').textContent = roleName;

        const modal = new bootstrap.Modal(document.getElementById('modalEditarPermisos'));

        try {
            // Obtener todos los permisos disponibles
            const permisosResponse = await fetch('@Url.Action("ObtenerPermisos", "Roles")');
            const permisosData = await permisosResponse.json();

            // Obtener permisos asignados al rol
            const permisosRolResponse = await fetch(`@Url.Action("ObtenerPermisosRol", "Roles")?roleId=${roleId}`);
            const permisosRolData = await permisosRolResponse.json();

            const permisosAsignados = permisosRolData.data || [];

            // Construir HTML
            let html = '';
            if (permisosData.data) {
                permisosData.data.forEach(module => {
                    html += `<div class="module-section">
                        <div class="module-title">
                            <i class="fas fa-cube"></i> ${module.module}
                        </div>
                        <div class="permissions-grid">`;

                    module.permissions.forEach(permission => {
                        const isChecked = permisosAsignados.includes(permission.id);
                        html += `<div class="permission-item">
                            <input type="checkbox" id="perm_${permission.id}" value="${permission.id}" 
                                   class="permission-checkbox" ${isChecked ? 'checked' : ''}>
                            <label for="perm_${permission.id}">
                                <strong>${permission.name}</strong>
                                <div class="permission-description">${permission.description}</div>
                            </label>
                        </div>`;
                    });

                    html += `</div></div>`;
                });
            }

            document.getElementById('permisosContainer').innerHTML = html;
            modal.show();
        } catch (error) {
            console.error('Error:', error);
            mostrarErrorPermisos('Error al cargar los permisos');
        }
    }

    // Guardar permisos de un rol
    function guardarPermisos() {
        const roleId = document.getElementById('roleIdPermiso').value;
        const checkboxes = document.querySelectorAll('.permission-checkbox:checked');
        const permissionIds = Array.from(checkboxes).map(cb => parseInt(cb.value));

        const datos = {
            roleId: roleId,
            permissionIds: permissionIds
        };

        const token = getAntiForgeryToken();
        if (!token) {
            mostrarErrorPermisos('Token de seguridad no encontrado');
            return;
        }

        fetch('@Url.Action("AsignarPermisos", "Roles")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            body: JSON.stringify(datos)
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                mostrarExitoPermisos(data.message);
                setTimeout(() => {
                    location.reload();
                }, 1500);
            } else {
                mostrarErrorPermisos(data.message);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            mostrarErrorPermisos('Error al guardar permisos');
        });
    }

    // Mostrar mensaje de error en permisos
    function mostrarErrorPermisos(mensaje) {
        const errorDiv = document.getElementById('mensajeErrorPermisos');
        const textoError = document.getElementById('textoErrorPermisos');
        textoError.textContent = mensaje;
        errorDiv.style.display = 'block';
    }

    // Mostrar mensaje de éxito en permisos
    function mostrarExitoPermisos(mensaje) {
        const exitoDiv = document.getElementById('mensajeExitoPermisos');
        const textoExito = document.getElementById('textoExitoPermisos');
        textoExito.textContent = mensaje;
        exitoDiv.style.display = 'block';
    }

    // Reasignar usuarios de un rol a otro
    function reasignarRol(roleId, roleName) {
        document.getElementById('rolOrigenId').value = roleId;
        document.getElementById('rolOrigenNombre').textContent = roleName;
        document.getElementById('containerUsuarios').innerHTML = '<div class="text-center"><span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Cargando usuarios...</div>';
        document.getElementById('rolDestinoId').innerHTML = '<option value="">Cargando roles...</option>';

        // Cargar usuarios del rol origen
        fetch(`@Url.Action("ObtenerUsuariosRol", "Roles")?roleId=${roleId}`)
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Mostrar usuarios
                    if (data.usuarios && data.usuarios.length > 0) {
                        let html = '<div class="usuarios-list">';
                        data.usuarios.forEach(usuario => {
                            html += `<div class="form-check usuario-item">
                                <input class="form-check-input usuario-checkbox" type="checkbox" value="${usuario.id}" id="usuario_${usuario.id}" checked>
                                <label class="form-check-label" for="usuario_${usuario.id}">
                                    <strong>${usuario.email}</strong><br>
                                    <small class="text-muted">${usuario.nombre}</small>
                                </label>
                            </div>`;
                        });
                        html += '</div>';
                        document.getElementById('containerUsuarios').innerHTML = html;
                    } else {
                        document.getElementById('containerUsuarios').innerHTML = '<div class="alert alert-info m-0"><i class="fas fa-info-circle"></i> No hay usuarios asignados a este rol</div>';
                    }
                } else {
                    alert('Error: ' + data.message);
                    return;
                }

                // Cargar roles disponibles para destino
                return fetch('@Url.Action("ListarRoles", "Roles")');
            })
            .then(response => response.json())
            .then(data => {
                if (data.success && data.roles) {
                    let select = '<option value="">Selecciona un rol...</option>';
                    data.roles.forEach(rol => {
                        if (rol.name !== roleName) {
                            select += `<option value="${rol.id}">${rol.name}</option>`;
                        }
                    });
                    document.getElementById('rolDestinoId').innerHTML = select;

                    const modal = new bootstrap.Modal(document.getElementById('modalReasignarRol'));
                    modal.show();
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error al cargar los datos');
            });
    }

    // Guardar reasignación de roles
    function guardarReasignacion() {
        const rolOrigenId = document.getElementById('rolOrigenId').value;
        const rolDestinoId = document.getElementById('rolDestinoId').value;
        const checkboxes = document.querySelectorAll('.usuario-checkbox:checked');
        const usuarioIds = Array.from(checkboxes).map(cb => cb.value);

        if (!rolDestinoId) {
            alert('⚠️ Por favor, selecciona un rol de destino');
            return;
        }

        if (usuarioIds.length === 0) {
            alert('⚠️ Por favor, selecciona al menos un usuario');
            return;
        }

        const datos = {
            rolOrigenId: rolOrigenId,
            rolDestinoId: rolDestinoId,
            usuarioIds: usuarioIds
        };

        const token = getAntiForgeryToken();
        if (!token) {
            alert('Token de seguridad no encontrado');
            return;
        }

        // Mostrar spinner
        const btnReasignar = document.querySelector('[onclick="guardarReasignacion()"]');
        const textOriginal = btnReasignar.innerHTML;
        btnReasignar.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span> Procesando...';
        btnReasignar.disabled = true;

        fetch('@Url.Action("ReasignarRol", "Roles")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            body: JSON.stringify(datos)
        })
        .then(response => response.json())
        .then(data => {
            btnReasignar.innerHTML = textOriginal;
            btnReasignar.disabled = false;

            if (data.success) {
                alert('✅ ' + data.message);
                const modal = bootstrap.Modal.getInstance(document.getElementById('modalReasignarRol'));
                modal.hide();
                setTimeout(() => {
                    location.reload();
                }, 1000);
            } else {
                alert('❌ ' + data.message);
            }
        })
        .catch(error => {
            btnReasignar.innerHTML = textOriginal;
            btnReasignar.disabled = false;
            console.error('Error:', error);
            alert('❌ Error al reasignar roles');
        });
    }
</script>
