@{
    ViewData["Title"] = "Permisos y Vacaciones";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("RRHH", Url.Action("RRHH", "Modules")),
        ("Permisos y Vacaciones", Url.Action("PermisosVacaciones", "Modules"))
    };
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">@ViewData["Title"]</h1>
        <button class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Nueva Solicitud
        </button>
    </div>

    <div class="card shadow">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">
                <i class="fas fa-calendar me-2"></i>Solicitudes Registradas
            </h6>
        </div>
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Empleado</th>
                        <th>Tipo</th>
                        <th>Desde</th>
                        <th>Hasta</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="5" class="text-center text-muted">Sin solicitudes disponibles</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
