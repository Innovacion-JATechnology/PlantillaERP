@{
    ViewData["Title"] = "Beneficios";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("RRHH", Url.Action("RRHH", "Modules")),
        ("Beneficios", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-gift"></i>
            Gestión de Beneficios
        </h1>
        <p>Administra los beneficios y prestaciones para tus empleados</p>
    </div>

    <!-- Toolbar con botón de acción -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-primary">
            <i class="fas fa-plus"></i>
            Nuevo Beneficio
        </button>
    </div>

    <!-- Tabla de Beneficios -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-hands-helping"></i>
                Beneficios Disponibles
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>Beneficio</th>
                        <th>Descripción</th>
                        <th>Tipo</th>
                        <th>Valor</th>
                        <th>N° Beneficiarios</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="fas fa-award"></i>
                                <h5>No hay beneficios disponibles</h5>
                                <p>Agrega beneficios para motivar a tu equipo</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
