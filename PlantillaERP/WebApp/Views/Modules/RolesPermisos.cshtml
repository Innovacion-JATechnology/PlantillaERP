@{
    ViewData["Title"] = "Roles y Permisos";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Administración", Url.Action("Administracion", "Modules")),
        ("Roles y Permisos", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-user-shield"></i>
            Roles y Permisos
        </h1>
        <p>Define y administra los roles de usuario y sus permisos de acceso al sistema</p>
    </div>

    <!-- Toolbar con botón de acción -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-primary">
            <i class="fas fa-plus"></i>
            Nuevo Rol
        </button>
    </div>

    <!-- Tabla de Roles -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-lock"></i>
                Gestión de Roles y Permisos
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>Rol</th>
                        <th>Descripción</th>
                        <th>N° Usuarios</th>
                        <th>Permisos Asignados</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="6">
                            <div class="empty-state">
                                <i class="fas fa-users-cog"></i>
                                <h5>No hay roles disponibles</h5>
                                <p>Crea roles y asigna permisos a los usuarios</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
