@{
    ViewData["Title"] = "Recursos de Producción";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Inicio" asp-controller="Home">Inicio</a></li>
            <li class="breadcrumb-item"><a asp-action="Produccion" asp-controller="Modules">Producción</a></li>
            <li class="breadcrumb-item active">@ViewData["Title"]</li>
        </ol>
    </nav>

    <h1 class="h3 mb-4">@ViewData["Title"]</h1>

    <div class="card shadow">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">
                <i class="fas fa-cog me-2"></i>Recursos Disponibles
            </h6>
        </div>
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Recurso</th>
                        <th>Tipo</th>
                        <th>Estado</th>
                        <th>Capacidad</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="4" class="text-center text-muted">Sin recursos disponibles</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
