@{
    ViewData["Title"] = "Categorías";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Dashboard", Url.Action("Index", "Home")),
        ("Inventario", Url.Action("Inventario", "Modules")),
        ("Categorías", Url.Action("Categorias", "Modules"))
    };
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">@ViewData["Title"]</h1>
        <button class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Nueva Categoría
        </button>
    </div>

    <div class="card shadow">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">
                <i class="fas fa-sitemap me-2"></i>Categorías de Productos
            </h6>
        </div>
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Productos</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="4" class="text-center text-muted">Sin categorías disponibles</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
