@{
    ViewData["Title"] = "Nómina";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("RRHH", Url.Action("RRHH", "Modules")),
        ("Nómina", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-money-check-alt"></i>
            Gestión de Nómina
        </h1>
        <p>Procesa y administra los pagos del personal de manera eficiente</p>
    </div>

    <!-- Toolbar con botón de acción -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-success">
            <i class="fas fa-calculator"></i>
            Procesar Nómina
        </button>
    </div>

    <!-- Tarjetas de Estadísticas -->
    <div class="stats-container">
        <div class="row g-4">
            <div class="col-lg-3 col-md-6">
                <div class="stat-card stat-info">
                    <div class="card-body">
                        <div class="stat-label">Total Salarios</div>
                        <div class="stat-value">$0</div>
                        <i class="fas fa-dollar-sign stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="stat-card stat-warning">
                    <div class="card-body">
                        <div class="stat-label">Deducciones</div>
                        <div class="stat-value">$0</div>
                        <i class="fas fa-minus-circle stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="stat-card stat-success">
                    <div class="card-body">
                        <div class="stat-label">Bonificaciones</div>
                        <div class="stat-value">$0</div>
                        <i class="fas fa-plus-circle stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="stat-card stat-danger">
                    <div class="card-body">
                        <div class="stat-label">Neto a Pagar</div>
                        <div class="stat-value">$0</div>
                        <i class="fas fa-wallet stat-icon"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de Nómina -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-file-invoice-dollar"></i>
                Procesamiento de Nómina
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>Empleado</th>
                        <th>Período</th>
                        <th>Salario Base</th>
                        <th>Deducciones</th>
                        <th>Bonos</th>
                        <th>Total Neto</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="8">
                            <div class="empty-state">
                                <i class="fas fa-file-contract"></i>
                                <h5>No hay nóminas procesadas</h5>
                                <p>Procesa la primera nómina para ver los registros aquí</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
