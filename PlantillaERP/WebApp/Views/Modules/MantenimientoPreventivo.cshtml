@{
    ViewData["Title"] = "Mantenimiento Preventivo";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Mantenimiento", Url.Action("Mantenimiento", "Modules")),
        ("Preventivo", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-shield-alt"></i>
            Mantenimiento Preventivo
        </h1>
        <p>Programa y gestiona las tareas preventivas para mantener tus equipos en óptimas condiciones</p>
    </div>

    <!-- Toolbar con botón de acción -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-primary">
            <i class="fas fa-plus"></i>
            Nueva Tarea
        </button>
    </div>

    <!-- Tabla de Mantenimiento -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-calendar-check"></i>
                Tareas Preventivas
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>Equipo</th>
                        <th>Tipo de Tarea</th>
                        <th>Frecuencia</th>
                        <th>Próxima Fecha</th>
                        <th>Responsable</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="fas fa-calendar-plus"></i>
                                <h5>No hay tareas disponibles</h5>
                                <p>Programa tu primera tarea de mantenimiento preventivo</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
