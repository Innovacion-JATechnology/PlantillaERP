@{
    ViewData["Title"] = "Empleados";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Dashboard", Url.Action("Index", "Home")),
        ("RRHH", Url.Action("Empleados", "Modules")),
        ("Empleados", Url.Action("Empleados", "Modules"))
    };
}

<div class="container-fluid">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Dashboard" asp-controller="Home">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="RRHH" asp-controller="Modules">Recursos Humanos</a></li>
            <li class="breadcrumb-item active">@ViewData["Title"]</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">@ViewData["Title"]</h1>
        <button class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Nuevo Empleado
        </button>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="text-primary text-uppercase mb-1">Total Empleados</div>
                    <div class="h3 mb-0">0</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="text-success text-uppercase mb-1">Activos</div>
                    <div class="h3 mb-0">0</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="text-warning text-uppercase mb-1">En Licencia</div>
                    <div class="h3 mb-0">0</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">
                <i class="fas fa-user-tie me-2"></i>Nómina de Empleados
            </h6>
        </div>
        <div class="card-body">
            <div class="alert alert-info">Sin empleados registrados</div>
        </div>
    </div>
</div>
