@{
    ViewData["Title"] = "Órdenes de Mantenimiento";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Mantenimiento", Url.Action("Mantenimiento", "Modules")),
        ("Órdenes", Url.Action("OrdenesMantenimiento", "Mantenimiento"))
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-list-check"></i>
            Órdenes de Mantenimiento
        </h1>
        <p>Gestiona y da seguimiento a todas las órdenes de trabajo de mantenimiento</p>
    </div>

    <!-- Toolbar con botón de acción -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-primary">
            <i class="fas fa-plus"></i>
            Nueva Orden
        </button>
    </div>

    <!-- Tabla de Órdenes -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-clipboard-list"></i>
                Órdenes de Trabajo
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>Número</th>
                        <th>Equipo</th>
                        <th>Descripción</th>
                        <th>Fecha Creación</th>
                        <th>Responsable</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="fas fa-tasks"></i>
                                <h5>No hay órdenes disponibles</h5>
                                <p>Crea tu primera orden de mantenimiento</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
