@{
    ViewData["Title"] = "Capacitación";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("RRHH", Url.Action("RRHH", "Modules")),
        ("Capacitación", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-graduation-cap"></i>
            Programas de Capacitación
        </h1>
        <p>Gestiona y organiza las capacitaciones para el desarrollo del personal</p>
    </div>

    <!-- Toolbar con botón de acción -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-primary">
            <i class="fas fa-plus"></i>
            Nuevo Programa
        </button>
    </div>

    <!-- Tabla de Capacitación -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-chalkboard-teacher"></i>
                Programas de Capacitación
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>Programa</th>
                        <th>Instructor</th>
                        <th>Fecha Inicio</th>
                        <th>Fecha Fin</th>
                        <th>Participantes</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="fas fa-book-open"></i>
                                <h5>No hay programas disponibles</h5>
                                <p>Crea tu primer programa de capacitación</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
