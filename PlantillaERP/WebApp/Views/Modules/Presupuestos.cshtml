@{
    ViewData["Title"] = "Presupuestos";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Finanzas", Url.Action("Finanzas", "Modules")),
        ("Presupuestos", Url.Action("Presupuestos", "Modules"))
    };
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">@ViewData["Title"]</h1>
        <button class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Nuevo Presupuesto
        </button>
    </div>

    <div class="card shadow">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">
                <i class="fas fa-calculator me-2"></i>Presupuestos Registrados
            </h6>
        </div>
        <div class="card-body">
            <div class="alert alert-info">Sin presupuestos disponibles</div>
        </div>
    </div>
</div>
