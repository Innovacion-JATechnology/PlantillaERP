@{
    ViewData["Title"] = "Compras";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Compras", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-shopping-cart"></i>
            Gestión de Compras
        </h1>
        <p>Administra proveedores, órdenes, contratos y todas tus compras</p>
    </div>

    <!-- Tarjetas de Estadísticas -->
    <div class="stats-container">
        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <div class="stat-card stat-info">
                    <div class="card-body">
                        <div class="stat-label">Órdenes Pendientes</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-file-invoice stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="stat-card stat-success">
                    <div class="card-body">
                        <div class="stat-label">Órdenes Completadas</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-check-circle stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="stat-card stat-warning">
                    <div class="card-body">
                        <div class="stat-label">Proveedores Activos</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-truck stat-icon"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Opciones del Módulo -->
    <div class="row g-4 mt-2">
        <div class="col-lg-3 col-md-6">
            <div class="stat-card stat-success">
                <div class="card-body">
                    <div class="stat-label"><i class="fas fa-truck me-2"></i>Proveedores</div>
                    <p class="mb-3">Gestión de proveedores</p>
                    <a asp-action="Proveedores" asp-controller="Modules" class="professional-btn professional-btn-sm professional-btn-success">
                        <i class="fas fa-arrow-right"></i>
                        Acceder
                    </a>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="stat-card stat-info">
                <div class="card-body">
                    <div class="stat-label"><i class="fas fa-file-invoice me-2"></i>Órdenes Compra</div>
                    <p class="mb-3">Gestión de órdenes</p>
                    <a href="#" class="professional-btn professional-btn-sm professional-btn-info">
                        <i class="fas fa-arrow-right"></i>
                        Acceder
                    </a>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="stat-card stat-warning">
                <div class="card-body">
                    <div class="stat-label"><i class="fas fa-file-signature me-2"></i>Contratos</div>
                    <p class="mb-3">Gestión de contratos</p>
                    <a asp-action="Contratos" asp-controller="Modules" class="professional-btn professional-btn-sm professional-btn-warning">
                        <i class="fas fa-arrow-right"></i>
                        Acceder
                    </a>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="stat-card stat-danger">
                <div class="card-body">
                    <div class="stat-label"><i class="fas fa-globe me-2"></i>Compras Int.</div>
                    <p class="mb-3">Compras internacionales</p>
                    <a asp-action="ComprasInternacionales" asp-controller="Modules" class="professional-btn professional-btn-sm professional-btn-danger">
                        <i class="fas fa-arrow-right"></i>
                        Acceder
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
