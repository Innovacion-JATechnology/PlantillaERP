@{
    ViewData["Title"] = "Facturas";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Finanzas", Url.Action("Finanzas", "Modules")),
        ("Facturas", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-file-invoice"></i>
            Gestión de Facturas
        </h1>
        <p>Administra y controla todas las facturas de tu empresa</p>
    </div>

    <!-- Toolbar con botón de acción -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-primary">
            <i class="fas fa-plus"></i>
            Nueva Factura
        </button>
    </div>

    <!-- Tarjetas de Estadísticas -->
    <div class="stats-container">
        <div class="row g-4">
            <div class="col-lg-3 col-md-6">
                <div class="stat-card stat-success">
                    <div class="card-body">
                        <div class="stat-label">Total Facturas</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-file-invoice stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="stat-card stat-info">
                    <div class="card-body">
                        <div class="stat-label">Monto Total</div>
                        <div class="stat-value">$0</div>
                        <i class="fas fa-coins stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="stat-card stat-warning">
                    <div class="card-body">
                        <div class="stat-label">Pendientes</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-clock stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="stat-card stat-danger">
                    <div class="card-body">
                        <div class="stat-label">Vencidas</div>
                        <div class="stat-value">0</div>
                        <i class="fas fa-exclamation-triangle stat-icon"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de Facturas -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-receipt"></i>
                Facturas Registradas
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>N° Factura</th>
                        <th>Cliente</th>
                        <th>Fecha Emisión</th>
                        <th>Fecha Vencimiento</th>
                        <th>Monto</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="fas fa-receipt"></i>
                                <h5>No hay facturas disponibles</h5>
                                <p>Emite tu primera factura para comenzar</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
