@{
    ViewData["Title"] = "Usuarios";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Administración", Url.Action("Administracion", "Modules")),
        ("Usuarios", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-users"></i>
            Gestión de Usuarios
        </h1>
        <p>Administra los usuarios y accesos del sistema</p>
    </div>

    <!-- Toolbar con botón de acción -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-primary">
            <i class="fas fa-plus"></i>
            Nuevo Usuario
        </button>
    </div>

    <!-- Tabla de Usuarios -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-table"></i>
                Nómina de Usuarios
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>Usuario</th>
                        <th>Email</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="5">
                            <div class="empty-state">
                                <i class="fas fa-user-slash"></i>
                                <h5>No hay usuarios registrados</h5>
                                <p>Comienza agregando el primer usuario al sistema</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
