@{
    ViewData["Title"] = "Presupuesto de Proyectos";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Proyectos", Url.Action("Proyectos", "Modules")),
        ("Presupuesto", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-coins"></i>
            Presupuesto de Proyectos
        </h1>
        <p>Controla y monitorea el presupuesto asignado a cada proyecto</p>
    </div>

    <!-- Tarjetas de Estadísticas -->
    <div class="stats-container">
        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <div class="stat-card stat-info">
                    <div class="card-body">
                        <div class="stat-label">Total Presupuesto</div>
                        <div class="stat-value">$0</div>
                        <i class="fas fa-wallet stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="stat-card stat-warning">
                    <div class="card-body">
                        <div class="stat-label">Invertido</div>
                        <div class="stat-value">$0</div>
                        <i class="fas fa-money-bill-wave stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="stat-card stat-success">
                    <div class="card-body">
                        <div class="stat-label">Disponible</div>
                        <div class="stat-value">$0</div>
                        <i class="fas fa-piggy-bank stat-icon"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de Presupuestos -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-table"></i>
                Presupuestos de Proyectos
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>Proyecto</th>
                        <th>Presupuesto</th>
                        <th>Gastado</th>
                        <th>Disponible</th>
                        <th>% Utilizado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="6">
                            <div class="empty-state">
                                <i class="fas fa-chart-pie"></i>
                                <h5>No hay presupuestos disponibles</h5>
                                <p>Los presupuestos de proyectos aparecerán aquí</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
