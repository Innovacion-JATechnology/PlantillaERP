@{
    ViewData["Title"] = "Auditoría de Inventario";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Inicio", Url.Action("Index", "Home")),
        ("Inventario", Url.Action("Inventario", "Modules")),
        ("Auditoría", null)
    };
}

<link rel="stylesheet" href="~/css/professional-tables.css" />

<div class="professional-page-container">
    <!-- Header Profesional -->
    <div class="professional-header fade-in-up">
        <h1>
            <i class="fas fa-search"></i>
            Auditoría de Inventario
        </h1>
        <p>Revisa el historial completo de cambios y movimientos del inventario</p>
    </div>

    <!-- Toolbar con filtros -->
    <div class="professional-toolbar">
        <div></div>
        <button class="professional-btn professional-btn-outline">
            <i class="fas fa-filter"></i>
            Filtrar
        </button>
    </div>

    <!-- Tabla de Auditoría -->
    <div class="professional-table-card">
        <div class="card-header">
            <h6>
                <i class="fas fa-history"></i>
                Registro de Cambios
            </h6>
        </div>
        <div class="card-body">
            <table class="professional-table">
                <thead>
                    <tr>
                        <th>Fecha y Hora</th>
                        <th>Usuario</th>
                        <th>Acción</th>
                        <th>Módulo</th>
                        <th>Detalles</th>
                        <th>IP</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="fas fa-clipboard-list"></i>
                                <h5>No hay registros disponibles</h5>
                                <p>El historial de auditoría aparecerá aquí</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
