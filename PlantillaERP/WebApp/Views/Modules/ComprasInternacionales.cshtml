                $('#txtETD').val(etd);
                $('#txtETA').val(eta);
                $('#ddlCruce').val(cruce);
                $('#ddlIncoterm').val(incoterm);
                $('#txtInvoice').val(invoice);
                $('#txtPedimento').val(pedimento);
                $('#txtConexionesDemoras').val(conexionesDemoras);
                $('#txtFechaEstimDestino').val(fechaEstimDestino);
                $('#txtUltimoDiaLibre').val(ultimoDiaLibre);
                $('#txtEntregaVacio').val(entregaVacio);
                $('#txtDiasDemoras').val(diasDemoras);
                $('#txtFacturaDemoras').val(facturaDemoras);
                $('#txtMontoUSDDemoras').val(montoUSDDemoras);
                $('#txtTCDemoras').val(tcDemoras);
                $('#txtMontoDemorasMXN').val(montoDemorasMXN);
                $('#txtFacturaComercializadora').val(facturaComercializadora);
                $('#txtFechaDespacho').val(fechaDespacho);
                $('#txtFechaPagoPedimento').val(fechaPagoPedimento);
                $('#txtPlanta').val(planta);
