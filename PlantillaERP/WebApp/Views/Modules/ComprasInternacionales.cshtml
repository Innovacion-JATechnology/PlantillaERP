                var producto = $(this).data('producto');
                var marca = $(this).data('marca');
                var talla = $(this).data('talla');
                var kgs = $(this).data('kgs');
                var cajas = $(this).data('cajas');

                $('#hfOriginalId').val(id);
                $('#txtFechaCompra').val(fechacompra);
                $('#txtContract').val(contract);
                $('#txtContainer').val(container);
                $('#txtSello').val(sello);
                $('#txtProveedor').val(proveedor);
                $('#txtOrigen').val(origen);
                $('#txtPuerto').val(puerto);
