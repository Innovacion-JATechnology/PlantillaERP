                $('#txtFechaProduccion').val(fechaProduccion);
                $('#txtFechaCaducidad').val(fechaCaducidad);
                $('#ddlEmpresa').val(empresa);
                $('#txtCodigo').val(codigo);
                $('#txtDescripcionProducto').val(descripcionProducto);
                $('#txtProducto').val(producto);
                $('#ddlMarca').val(marca);
                $('#ddlTalla').val(talla);
                $('#txtKgs').val(kgs);
                $('#txtCajas').val(cajas);

                $('#formTitulo').text('Editar Compra Internacional');
                $('#btnGuardarTexto').text('Actualizar');
                $('#btnEliminarForm').removeClass('d-none');

                $('#formContainer').slideDown();
                $('html, body').animate({ scrollTop: $('#formContainer').offset().top - 100 }, 300);
            });

            // Eliminar compra desde el formulario
            $('#btnEliminarForm').click(function () {
                var id = $('#hfOriginalId').val();
                if (!id) return;

                if (confirm('¿Está seguro de que desea eliminar esta compra internacional?')) {
                    $.ajax({
                        url: '@Url.Action("EliminarCompra", "Compras")',
                        type: 'POST',
                        data: { id: id },
                        success: function (response) {
                            if (response.success) {
                                mostrarMensaje(response.message, 'success');
                                $('#formContainer').slideUp();
                                setTimeout(function () {
                                    window.location.reload();
                                }, 1500);
                            } else {
                                mostrarMensaje(response.message, 'danger');
                            }
                        },
                        error: function () {
                            mostrarMensaje('Error al eliminar la compra.', 'danger');
                        }
                    });
                }
            });

