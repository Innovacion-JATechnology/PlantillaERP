@{
    ViewData["Title"] = "Solicitudes de Compra";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Inicio" asp-controller="Home">Inicio</a></li>
            <li class="breadcrumb-item"><a asp-action="Compras" asp-controller="Modules">Compras</a></li>
            <li class="breadcrumb-item active">@ViewData["Title"]</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">@ViewData["Title"]</h1>
        <button class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Nueva Solicitud
        </button>
    </div>

    <div class="card shadow">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">
                <i class="fas fa-file-alt me-2"></i>Solicitudes Registradas
            </h6>
        </div>
        <div class="card-body">
            <div class="alert alert-info">Sin solicitudes disponibles</div>
        </div>
    </div>
</div>
