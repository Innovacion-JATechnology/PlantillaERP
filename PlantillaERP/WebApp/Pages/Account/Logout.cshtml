@page
@model WebApp.Pages.Account.LogoutModel
@{
    ViewData["Title"] = "Confirmar Cerrar Sesión";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg">
                <div class="card-body p-5 text-center">
                    <div class="mb-4">
                        <i class="fas fa-question-circle text-warning" style="font-size: 3rem;"></i>
                    </div>
                    <h2 class="mb-3">¿Estás Seguro?</h2>
                    <p class="text-muted mb-4">¿Realmente deseas cerrar tu sesión?</p>

                    <form method="post" asp-antiforgery="true" class="d-flex gap-2 justify-content-center">
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-check"></i> Sí, Cerrar Sesión
                        </button>
                        <a href="/Dashboard" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Cancelar
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
