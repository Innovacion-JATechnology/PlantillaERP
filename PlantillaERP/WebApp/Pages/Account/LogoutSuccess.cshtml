@page
@model WebApp.Pages.Account.LogoutSuccessModel
@{
    ViewData["Title"] = "Sesión Cerrada - ERP";
}

<div class="logout-success-container">
    <div class="logout-success-wrapper">
        <div class="logout-success-card">
            <!-- Success Icon Animation -->
            <div class="success-icon-wrapper mb-5">
                <div class="success-checkmark">
                    <i class="fas fa-check-circle"></i>
                </div>
            </div>

            <!-- Content Section -->
            <div class="logout-content text-center">
                <h1 class="logout-title mb-3">
                    Sesión Cerrada Exitosamente
                </h1>
                <p class="logout-subtitle mb-2">
                    Has cerrado sesión correctamente
                </p>
                <p class="logout-message text-muted mb-5">
                    Tu sesión ha terminado de forma segura. Esperamos verte pronto en nuestro sistema.
                </p>
            </div>

            <!-- Actions Section -->
            <div class="logout-actions">
                <div class="action-buttons">
                    <a href="/Home" class="btn btn-primary btn-lg btn-action">
                        <i class="fas fa-home me-2"></i> Volver al Inicio
                    </a>
                    <a asp-page="/Account/Login" class="btn btn-outline-secondary btn-lg btn-action">
                        <i class="fas fa-sign-in-alt me-2"></i> Iniciar Sesión Nuevamente
                    </a>
                </div>
            </div>

            <!-- Footer Info -->
            <div class="logout-footer mt-5">
                <small class="text-muted d-block">
                    <i class="fas fa-shield-alt"></i> Sesión segura finalizada
                </small>
            </div>
        </div>
    </div>
</div>

<style>
    .logout-success-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 20px;
    }

    .logout-success-wrapper {
        width: 100%;
        max-width: 500px;
    }

    .logout-success-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
        padding: 50px 40px;
        animation: slideUp 0.5s ease-out;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Success Icon */
    .success-icon-wrapper {
        display: flex;
        justify-content: center;
    }

    .success-checkmark {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        animation: scaleIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @@keyframes scaleIn {
        from {
            transform: scale(0);
        }
        to {
            transform: scale(1);
        }
    }

    .success-checkmark i {
        font-size: 2.5rem;
        color: white;
    }

    /* Content */
    .logout-content {
        margin-bottom: 2rem;
    }

    .logout-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 0.5rem;
    }

    .logout-subtitle {
        font-size: 1.1rem;
        color: #34495e;
        font-weight: 500;
    }

    .logout-message {
        font-size: 0.95rem;
        line-height: 1.6;
        color: #7f8c8d !important;
    }

    /* Buttons */
    .action-buttons {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .btn-action {
        padding: 0.875rem 1.5rem;
        font-size: 1rem;
        font-weight: 600;
        border-radius: 8px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 2px solid transparent;
    }

    .btn-primary.btn-action {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-color: transparent;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
    }

    .btn-primary.btn-action:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 25px rgba(102, 126, 234, 0.4);
        color: white;
        text-decoration: none;
    }

    .btn-primary.btn-action:active {
        transform: translateY(0);
    }

    .btn-outline-secondary.btn-action {
        background: white;
        color: #34495e;
        border-color: #ecf0f1;
        border-width: 2px;
    }

    .btn-outline-secondary.btn-action:hover {
        background: #f8f9fa;
        border-color: #34495e;
        color: #34495e;
        text-decoration: none;
        transform: translateY(-2px);
    }

    .btn-outline-secondary.btn-action:active {
        transform: translateY(0);
    }

    /* Footer */
    .logout-footer {
        text-align: center;
        padding-top: 1.5rem;
        border-top: 1px solid #ecf0f1;
    }

    .logout-footer small {
        font-size: 0.85rem;
    }

    .logout-footer i {
        margin-right: 0.5rem;
        color: #667eea;
    }

    /* Responsive */
    @@media (max-width: 576px) {
        .logout-success-card {
            padding: 40px 25px;
        }

        .logout-title {
            font-size: 1.5rem;
        }

        .success-checkmark {
            width: 70px;
            height: 70px;
        }

        .success-checkmark i {
            font-size: 2rem;
        }

        .btn-action {
            padding: 0.75rem 1.25rem;
            font-size: 0.95rem;
        }
    }
</style>

