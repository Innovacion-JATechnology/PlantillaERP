@page
@model WebApp.Pages.Account.AccessDeniedModel

@{
    ViewData["Title"] = "Acceso Denegado - ERP";
}

<div class="access-denied-container">
    <div class="access-denied-wrapper">
        <!-- Icon Section -->
        <div class="denied-icon-section mb-5">
            <i class="fas fa-lock"></i>
        </div>

        <!-- Message Section -->
        <div class="denied-message-section text-center">
            <h1 class="denied-title mb-3">
                <strong>403 - Acceso Denegado</strong>
            </h1>
            
            <p class="denied-subtitle mb-4">
                <i class="fas fa-exclamation-triangle"></i> 
                No tienes los permisos necesarios para acceder a esta página
            </p>

            <div class="denied-explanation mb-5">
                <p class="text-muted">
                    Tu rol actual no incluye los permisos requeridos para realizar esta acción.
                </p>
                <p class="text-muted">
                    Si crees que esto es un error, contacta al administrador del sistema.
                </p>
            </div>

            <!-- Return URL Display -->
            @if (!string.IsNullOrEmpty(ViewContext.HttpContext.Request.Query["ReturnUrl"]))
            {
                <div class="alert alert-info mb-4" role="alert">
                    <i class="fas fa-info-circle"></i>
                    <strong>Página solicitada:</strong> 
                    <code>@ViewContext.HttpContext.Request.Query["ReturnUrl"]</code>
                </div>
            }

            <!-- Action Buttons -->
            <div class="denied-actions">
                <a href="javascript:history.back()" class="btn btn-secondary me-3">
                    <i class="fas fa-arrow-left"></i> Volver Atrás
                </a>
                <a href="/Home/Index" class="btn btn-primary">
                    <i class="fas fa-home"></i> Ir al Inicio
                </a>
            </div>

            <!-- Additional Help -->
            <div class="denied-help mt-5 pt-4 border-top">
                <p class="text-muted small">
                    <i class="fas fa-question-circle"></i>
                    ¿Necesitas ayuda? 
                    <a href="/Home/Index#contact" class="text-decoration-none">Contactar Soporte</a>
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    .access-denied-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 20px;
    }

    .access-denied-wrapper {
        background: white;
        border-radius: 10px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
        padding: 60px 40px;
        max-width: 500px;
        width: 100%;
        animation: slideUp 0.5s ease-out;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .denied-icon-section i {
        font-size: 80px;
        color: #dc3545;
        opacity: 0.3;
    }

    .denied-title {
        color: #333;
        font-size: 28px;
        margin-bottom: 10px;
    }

    .denied-subtitle {
        color: #666;
        font-size: 16px;
        margin-bottom: 20px;
    }

    .denied-explanation {
        background-color: #f8f9fa;
        padding: 20px;
        border-radius: 8px;
        border-left: 4px solid #ffc107;
    }

    .denied-actions .btn {
        min-width: 140px;
        font-weight: 500;
        border-radius: 5px;
    }

    .denied-help {
        margin-top: 40px;
    }

    .denied-help a {
        color: #667eea;
        font-weight: 500;
    }

    .denied-help a:hover {
        color: #764ba2;
    }

    @@media (max-width: 768px) {
        .access-denied-wrapper {
            padding: 40px 25px;
        }

        .denied-title {
            font-size: 24px;
        }

        .denied-subtitle {
            font-size: 14px;
        }

        .denied-actions {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .denied-actions .btn {
            width: 100%;
            margin: 0 !important;
        }
    }
</style>
