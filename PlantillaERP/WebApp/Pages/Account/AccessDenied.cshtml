@page
@model WebApp.Pages.Account.AccessDeniedModel

@{
    ViewData["Title"] = "Acceso Denegado - ERP";
}

<div class="access-denied-container">
    <div class="access-denied-card">
        <!-- Decorative Background -->
        <div class="denied-decoration-top"></div>

        <!-- Main Content -->
        <div class="access-denied-content">
            <!-- Icon Section with Animation -->
            <div class="denied-icon-wrapper mb-4">
                <div class="denied-icon-circle">
                    <i class="fas fa-shield-alt"></i>
                </div>
            </div>

            <!-- Error Code and Title -->
            <div class="text-center mb-3">
                <div class="error-code">403</div>
                <h1 class="denied-title">Acceso Denegado</h1>
            </div>

            <!-- Description -->
            <div class="denied-description text-center mb-5">
                <p class="denied-text">
                    Lamentablemente, no tienes los permisos necesarios para acceder a este recurso.
                </p>
                <p class="denied-subtext">
                    Tu rol actual no incluye las autorizaciones requeridas para esta acción.
                </p>
            </div>

            <!-- Return URL Display -->
            @if (!string.IsNullOrEmpty(ViewContext.HttpContext.Request.Query["ReturnUrl"]))
            {
                <div class="denied-url-info mb-5">
                    <div class="url-info-header">
                        <i class="fas fa-link"></i> 
                        <span>Recurso solicitado</span>
                    </div>
                    <code class="url-info-code">@ViewContext.HttpContext.Request.Query["ReturnUrl"]</code>
                </div>
            }

            <!-- Action Buttons -->
            <div class="denied-actions-container mb-4">
                <a href="javascript:history.back()" class="btn btn-outline-secondary denied-btn-secondary">
                    <i class="fas fa-arrow-left me-2"></i> Volver Atrás
                </a>
                <a href="/Home/Index" class="btn btn-primary denied-btn-primary">
                    <i class="fas fa-home me-2"></i> Ir al Inicio
                </a>
            </div>

            <!-- Help Section -->
            <div class="denied-help-section">
                <div class="help-header">
                    <i class="fas fa-lightbulb"></i>
                    <span>¿Qué puedo hacer?</span>
                </div>
                <ul class="help-list">
                    <li>Verifica que estés iniciando sesión con la cuenta correcta</li>
                    <li>Contacta al administrador para solicitar acceso a este módulo</li>
                    <li>Revisa los módulos disponibles en tu panel de inicio</li>
                </ul>
            </div>

            <!-- Support Contact -->
            <div class="denied-support-section">
                <p class="support-text">
                    <i class="fas fa-envelope me-2"></i>
                    ¿Necesitas ayuda? Contacta al 
                    <a href="mailto:soporte@jatechnology.com" class="support-link">equipo de soporte</a>
                </p>
            </div>
        </div>

        <!-- Decorative Background -->
        <div class="denied-decoration-bottom"></div>
    </div>
</div>

<style>
    html, body {
        margin: 0;
        padding: 0;
        height: 100%;
    }

    :root {
        --primary-color: #667eea;
        --primary-dark: #764ba2;
        --danger-color: #dc3545;
        --text-dark: #2c3e50;
        --text-light: #7f8c8d;
        --bg-light: #f8f9fa;
    }

    .access-denied-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
        padding: 20px;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        margin: 0;
    }

    .access-denied-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
        max-width: 550px;
        width: 100%;
        overflow: hidden;
        animation: slideIn 0.6s ease-out;
        position: relative;
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .denied-decoration-top {
        height: 5px;
        background: linear-gradient(90deg, var(--primary-color), var(--primary-dark));
    }

    .access-denied-content {
        padding: 60px 40px;
    }

    .denied-icon-wrapper {
        display: flex;
        justify-content: center;
    }

    .denied-icon-circle {
        width: 100px;
        height: 100px;
        background: linear-gradient(135deg, rgba(220, 53, 69, 0.1), rgba(220, 53, 69, 0.05));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        animation: bounce 2s infinite;
    }

    .denied-icon-circle i {
        font-size: 50px;
        color: var(--danger-color);
    }

    @@keyframes bounce {
        0%, 100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-10px);
        }
    }

    .error-code {
        font-size: 72px;
        font-weight: 900;
        background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 10px;
        letter-spacing: -2px;
    }

    .denied-title {
        color: var(--text-dark);
        font-size: 32px;
        font-weight: 700;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .denied-description {
        margin: 25px 0 20px 0;
    }

    .denied-text {
        color: var(--text-dark);
        font-size: 16px;
        font-weight: 500;
        margin-bottom: 12px;
    }

    .denied-subtext {
        color: var(--text-light);
        font-size: 14px;
        margin: 0;
    }

    .denied-url-info {
        background: var(--bg-light);
        border-left: 4px solid var(--primary-color);
        border-radius: 8px;
        padding: 16px;
        margin: 30px 0;
    }

    .url-info-header {
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--text-dark);
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .url-info-code {
        display: block;
        background: white;
        color: var(--primary-color);
        padding: 10px 12px;
        border-radius: 4px;
        font-size: 12px;
        overflow-wrap: break-word;
        word-break: break-all;
        font-family: 'Courier New', monospace;
        border: 1px solid #e0e0e0;
    }

    .denied-actions-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin: 20px 0;
    }

    .denied-btn-primary,
    .denied-btn-secondary {
        padding: 12px 20px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 14px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: none;
    }

    .denied-btn-primary {
        background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
        color: white;
    }

    .denied-btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(102, 126, 234, 0.3);
        color: white;
        text-decoration: none;
    }

    .denied-btn-secondary {
        background: white;
        color: var(--text-dark);
        border: 2px solid #e0e0e0;
    }

    .denied-btn-secondary:hover {
        border-color: var(--primary-color);
        color: var(--primary-color);
        text-decoration: none;
        background: var(--bg-light);
    }

    .denied-help-section {
        background: var(--bg-light);
        border-radius: 12px;
        padding: 20px;
        margin: 20px 0 0 0;
    }

    .help-header {
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--text-dark);
        font-weight: 600;
        font-size: 14px;
        margin-bottom: 15px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .help-header i {
        color: var(--primary-color);
        font-size: 16px;
    }

    .help-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .help-list li {
        color: var(--text-light);
        font-size: 13px;
        padding: 8px 0;
        padding-left: 28px;
        position: relative;
    }

    .help-list li:before {
        content: "✓";
        position: absolute;
        left: 0;
        color: var(--primary-color);
        font-weight: bold;
    }

    .denied-support-section {
        border-top: 1px solid #e0e0e0;
        padding-top: 16px;
        margin-top: 16px;
        text-align: center;
    }

    .support-text {
        color: var(--text-light);
        font-size: 13px;
        margin: 0;
    }

    .support-link {
        color: var(--primary-color);
        font-weight: 600;
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .support-link:hover {
        color: var(--primary-dark);
        text-decoration: underline;
    }

    .denied-decoration-bottom {
        height: 5px;
        background: linear-gradient(90deg, var(--primary-color), var(--primary-dark));
    }

    /* Responsive Design */
    @@media (max-width: 600px) {
        .access-denied-content {
            padding: 40px 25px;
        }

        .error-code {
            font-size: 56px;
        }

        .denied-title {
            font-size: 26px;
        }

        .denied-text {
            font-size: 15px;
        }

        .denied-actions-container {
            grid-template-columns: 1fr;
            gap: 10px;
        }

        .denied-btn-primary,
        .denied-btn-secondary {
            padding: 11px 18px;
            font-size: 13px;
        }

        .help-list li {
            font-size: 12px;
        }
    }
</style>
