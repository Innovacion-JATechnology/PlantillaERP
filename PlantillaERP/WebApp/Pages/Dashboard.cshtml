@page
@using System.Security.Claims
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <h1>Bienvenido, @User.FindFirst(ClaimTypes.Name)?.Value!</h1>
            <p class="lead">Has iniciado sesión correctamente en el ERP.</p>

            <div class="alert alert-info">
                <h4>Información del Usuario</h4>
                <ul class="list-unstyled">
                    <li><strong>Usuario:</strong> @User.FindFirst(ClaimTypes.NameIdentifier)?.Value</li>
                    <li><strong>Email:</strong> @User.FindFirst(ClaimTypes.Email)?.Value</li>
                    <li>
                        <strong>Roles:</strong> 
                        @{
                            var roles = User.FindAll(ClaimTypes.Role);
                            if (roles.Any())
                            {
                                <span>@string.Join(", ", roles.Select(r => r.Value))</span>
                            }
                            else
                            {
                                <span>Sin roles asignados</span>
                            }
                        }
                    </li>
                </ul>
            </div>

            <hr />

            <div class="row">
                <div class="col-md-6">
                    <a href="/Home/Index" class="btn btn-primary btn-lg w-100">
                        <i class="fas fa-home"></i> Ir al Inicio
                    </a>
                </div>
                <div class="col-md-6">
                    <form method="post" asp-page-handler="logout" class="d-inline w-100">
                        <button type="submit" class="btn btn-danger btn-lg w-100">
                            <i class="fas fa-sign-out-alt"></i> Cerrar Sesión
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
