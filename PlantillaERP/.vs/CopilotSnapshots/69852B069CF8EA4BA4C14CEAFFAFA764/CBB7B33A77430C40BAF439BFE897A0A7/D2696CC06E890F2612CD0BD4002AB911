/* Wrapping element */
/* Set some basic padding to keep content from hitting the edges */
.body-content {
    margin-top: 15px;
    padding-left: 15px;
    padding-right: 15px;
}

/* Set widths on the form inputs since otherwise they're 100% wide */
input,
select,
textarea {
    max-width: 280px;
}

/* Responsive: Portrait tablets and up */
@media screen and (min-width: 768px) {
    .body-content {
        padding: 0;
    }
}

/*Cambio de tema de la barra de arriba y el menu */
/* ============================================
   GLOBAL THEME COLOR
   ============================================ */
:root {
    --erp-blue: #008CCC;
}

/* ============================================
   TOP NAVBAR


   ============================================ */

.sb-topnav {
    background: linear-gradient(90deg, #57B3FC, #A55FFD, #1037A1);
}


.sb-topnav {
    animation: colorCycle 10s infinite alternate;
}

@keyframes colorCycle {
    0% {
        background-color: #57B3FC;
    }

    50% {
        background-color: #A55FFD;
    }

    100% {
        background-color: #1037A1;
    }
}





/* ============================================
   SIDEBAR
   ============================================ */
.sb-sidenav,
.sb-sidenav.sb-sidenav-dark,
#layoutSidenav_nav,
.sb-sidenav .sb-sidenav-menu,
.sb-sidenav .sb-sidenav-menu .nav-link {
    /*  background-color: #57B3FC; /*   Azul cepesmar para el sidebar */
    background: linear-gradient(90deg, #57B3FC, #829DF5);
    
        color: #ffffff;
}


/* Sidebar headings */
    .sb-sidenav-menu-heading {
        color: #171796; /*  #0008c5; Azul cepesmar para el sidebar */
    }

    .sb-sidenav-dark .nav-link:hover {
        background-color: #008CCC;
    }

.sb-sidenav-footer {
    /* background-color: #57B3FC !important; */
    background: linear-gradient(90deg, #57B3FC, #829DF5);
    color: #ffffff !important; /* #008CCC azul cepesmar text white */
}

    /* ============================================
   LAYOUT FIX FOR FIXED NAVBAR
   ============================================ */
    body.sb-nav-fixed {
        overflow-y: scroll;
    }

    .sb-nav-fixed #layoutSidenav {
        margin-top: 56px !important;
        padding-top: 0 !important;
    }
