/* Wrapping element */
/* Set some basic padding to keep content from hitting the edges */
.body-content {
    margin-top: 15px;
    padding-left: 15px;
    padding-right: 15px;
}

/* Set widths on the form inputs since otherwise they're 100% wide */
input,
select,
textarea {
    max-width: 280px;
}

/* Responsive: Portrait tablets and up */
@media screen and (min-width: 768px) {
    .body-content {
        padding: 0;
    }
}

/*Cambio de tema de la barra de arriba y el menu */




/* ============================================
   GLOBAL THEME COLOR
   ============================================ */
:root {
    --erp-blue: #008CCC;
}

/* ============================================
   TOP NAVBAR
   ============================================ */
 

/* Top navbar */
.sb-topnav {
    background-color: #171796; /* Azul Cepesmar*/
}



/* ============================================
   SIDEBAR
   ============================================ */
.sb-sidenav,
.sb-sidenav.sb-sidenav-dark,
#layoutSidenav_nav,
.sb-sidenav .sb-sidenav-menu,
.sb-sidenav .sb-sidenav-menu .nav-link {
    background-color: #171796; /*  #0008c5; Azul cepesmar para el sidebar */
    color: #ffffff;
}

 


/* Sidebar headings */
.sb-sidenav-menu-heading {
    color: #171796; /*  #0008c5; Azul cepesmar para el sidebar */
}

 

.sb-sidenav-dark .nav-link:hover {
    background-color: #008CCC;
}




.sb-sidenav-footer {
    background-color: #0008c5 !important; /* strong red */
    color: #008CCC !important; /* text white */
}

/* ============================================
   LAYOUT FIX FOR FIXED NAVBAR
   ============================================ */
body.sb-nav-fixed {
    overflow-y: scroll;
}

.sb-nav-fixed #layoutSidenav {
    margin-top: 56px !important;
    padding-top: 0 !important;
}

/* ============================================
   FOOTER que ya no se esta usando
   ============================================ */
footer.footer-custom {
    background-color: #171796; /*  #0008c5; Azul cepesmar para el sidebar */
    color: #008CCC;
}

