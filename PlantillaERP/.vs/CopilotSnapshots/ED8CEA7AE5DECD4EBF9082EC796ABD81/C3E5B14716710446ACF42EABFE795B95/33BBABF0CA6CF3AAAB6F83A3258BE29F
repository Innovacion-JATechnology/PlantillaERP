/* ============================================
   CUSTOM SIDEBAR - PARTIAL COLLAPSE WITH ICONS ONLY
   ============================================ */

/* When sidebar is toggled (collapsed to show only icons) */

/* Sidebar width and structure - applies to all screen sizes */
.sb-sidenav-toggled #layoutSidenav_nav .sb-sidenav {
    width: 60px !important; 
}

/* Fix padding for both regular and fixed navbar modes */
.sb-sidenav-toggled #layoutSidenav #layoutSidenav_content {
    margin-left: 0 !important;
    padding-left: 60px !important;
    top: auto !important;
}

/* Override the transform that hides the sidebar completely - large screens */
@media (min-width: 992px) {
    .sb-sidenav-toggled #layoutSidenav #layoutSidenav_nav {
        transform: translateX(0) !important;
        width: 60px !important;
    }
}

/* Ensure consistent width even with fixed navbar */
.sb-nav-fixed.sb-sidenav-toggled #layoutSidenav #layoutSidenav_nav {
    width: 60px !important; 
    
}

/* Nav links styling when collapsed */
.sb-sidenav-toggled #layoutSidenav_nav .sb-sidenav .nav-link {
    width: 60px !important;
    padding: 0 !important;
    display: flex !important;
    justify-content: center !important;
    align-items: center !important;
    min-height: 45px;
}

/* Hide text content in nav links */
.sb-sidenav-toggled #layoutSidenav_nav .sb-sidenav .nav-link span {
    display: none !important;
    visibility: hidden !important;
    width: 0 !important;
    height: 0 !important;
    overflow: hidden !important;
}

/* Icon styling */
.sb-sidenav-toggled #layoutSidenav_nav .sb-sidenav .sb-nav-link-icon {
    margin-right: 0 !important;
    display: flex !important;
    justify-content: center !important;
    align-items: center !important;
    width: 100% !important;
    color: white !important;
}

/* Hide menu headings */
.sb-sidenav-toggled #layoutSidenav_nav .sb-sidenav .sb-sidenav-menu-heading {
    display: none !important;
}

/* Footer styling */
.sb-sidenav-toggled #layoutSidenav_nav .sb-sidenav .sb-sidenav-footer {
    width: 60px !important;
    min-height: 45px;
    display: flex !important;
    justify-content: center !important;
    align-items: center !important;
    padding: 0 !important;
}

.sb-sidenav-toggled #layoutSidenav_nav .sb-sidenav .sb-sidenav-footer .small {
    display: none !important;
}

.sb-sidenav-toggled #layoutSidenav_nav .sb-sidenav .sb-sidenav-footer > div:not(.sb-nav-link-icon) {
    display: none !important;
}

/* Smooth transitions */
.sb-sidenav-toggled #layoutSidenav_nav,
.sb-sidenav-toggled #layoutSidenav_nav .sb-sidenav {
    transition: width 0.3s ease, transform 0.3s ease !important;
}
