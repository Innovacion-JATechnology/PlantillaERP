<script>
    // Initialize color pickers
    document.addEventListener('DOMContentLoaded', function () {
        initializeColorPickers();
        updatePreviews();
    });

    function initializeColorPickers() {
        // Navbar color pickers
        ['Navbar1', 'Navbar2', 'Navbar3', 'Sidebar1', 'Sidebar2', 'Module1', 'Module2'].forEach(prefix => {
            const picker = document.getElementById(`colorPicker${prefix}`);
            const rInput = document.getElementById(`${prefix.charAt(0).toLowerCase()}${prefix.slice(1)}R`.replace('C', 'Color'));
            if (rInput && picker) {
                rInput.addEventListener('input', function () {
                    updateColorPickerAndPreview(prefix);
                });
                updateColorPickerFromInputs(prefix);
            }
        });
    }

    function updateColorPickerFromInputs(prefix) {
        const r = parseInt(document.getElementById(`${prefix.charAt(0).toLowerCase() + prefix.slice(1)}R`)) || 0;
        const g = parseInt(document.getElementById(`${prefix.charAt(0).toLowerCase() + prefix.slice(1)}G`)) || 0;
        const b = parseInt(document.getElementById(`${prefix.charAt(0).toLowerCase() + prefix.slice(1)}B`)) || 0;
        const picker = document.getElementById(`colorPicker${prefix}`);
        
        if (picker) {
            picker.value = rgbToHex(r, g, b);
            picker.addEventListener('change', function () {
                const hex = this.value;
                const rgb = hexToRgb(hex);
                document.getElementById(`${prefix.charAt(0).toLowerCase() + prefix.slice(1)}R`).value = rgb.r;
                document.getElementById(`${prefix.charAt(0).toLowerCase() + prefix.slice(1)}G`).value = rgb.g;
                document.getElementById(`${prefix.charAt(0).toLowerCase() + prefix.slice(1)}B`).value = rgb.b;
                updatePreviews();
            });
        }
    }

    function updateColorPickerAndPreview(prefix) {
        updateColorPickerFromInputs(prefix);
        updatePreviews();
    }

    function updatePreviews() {
        updateSinglePreview('Navbar1', 'previewNavbar1');
        updateSinglePreview('Navbar2', 'previewNavbar2');
        updateSinglePreview('Navbar3', 'previewNavbar3');
        updateSinglePreview('Sidebar1', 'previewSidebar1');
        updateSinglePreview('Sidebar2', 'previewSidebar2');
        updateSinglePreview('Module1', 'previewModule1');
        updateSinglePreview('Module2', 'previewModule2');

        updateNavbarPreview();
        updateSidebarPreview();
        updateModulePreview();
    }

    function updateSinglePreview(prefix, elementId) {
        const r = document.getElementById(prefix.charAt(0).toLowerCase() + prefix.slice(1) + 'R').value;
        const g = document.getElementById(prefix.charAt(0).toLowerCase() + prefix.slice(1) + 'G').value;
        const b = document.getElementById(prefix.charAt(0).toLowerCase() + prefix.slice(1) + 'B').value;
        document.getElementById(elementId).style.backgroundColor = `rgb(${r}, ${g}, ${b})`;
    }

    function updateNavbarPreview() {
        const r1 = document.getElementById('navbarColor1R').value;
        const g1 = document.getElementById('navbarColor1G').value;
        const b1 = document.getElementById('navbarColor1B').value;
        const r2 = document.getElementById('navbarColor2R').value;
        const g2 = document.getElementById('navbarColor2G').value;
        const b2 = document.getElementById('navbarColor2B').value;
        const r3 = document.getElementById('navbarColor3R').value;
        const g3 = document.getElementById('navbarColor3G').value;
        const b3 = document.getElementById('navbarColor3B').value;

        const preview = document.getElementById('previewNavbarFull');
        preview.style.background = `linear-gradient(45deg, rgb(${r1}, ${g1}, ${b1}), rgb(${r2}, ${g2}, ${b2}), rgb(${r3}, ${g3}, ${b3}))`;
    }

    function updateSidebarPreview() {
        const r1 = document.getElementById('sidebarColor1R').value;
        const g1 = document.getElementById('sidebarColor1G').value;
        const b1 = document.getElementById('sidebarColor1B').value;
        const r2 = document.getElementById('sidebarColor2R').value;
        const g2 = document.getElementById('sidebarColor2G').value;
        const b2 = document.getElementById('sidebarColor2B').value;

        const preview = document.getElementById('previewSidebarFull');
        preview.style.background = `linear-gradient(180deg, rgb(${r1}, ${g1}, ${b1}), rgb(${r2}, ${g2}, ${b2}))`;
    }

    function updateModulePreview() {
        const r1 = document.getElementById('moduleColor1R').value;
        const g1 = document.getElementById('moduleColor1G').value;
        const b1 = document.getElementById('moduleColor1B').value;
        const r2 = document.getElementById('moduleColor2R').value;
        const g2 = document.getElementById('moduleColor2G').value;
        const b2 = document.getElementById('moduleColor2B').value;

        const moduleFull = document.getElementById('previewModuleFull');
        const moduleHover = document.getElementById('previewModuleHover');
        moduleFull.style.borderColor = `rgb(${r1}, ${g1}, ${b1})`;
        moduleHover.style.borderColor = `rgb(${r2}, ${g2}, ${b2})`;
    }

    function rgbToHex(r, g, b) {
        return "#" + ((1 << 24) + (r << 16) + (g << 8) + b).toString(16).slice(1);
    }

    function hexToRgb(hex) {
        const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
        return result ? {
            r: parseInt(result[1], 16),
            g: parseInt(result[2], 16),
            b: parseInt(result[3], 16)
        } : { r: 0, g: 0, b: 0 };
    }

    function saveColors() {
        const colors = {
            navbarColor1R: document.getElementById('navbarColor1R').value,
            navbarColor1G: document.getElementById('navbarColor1G').value,
            navbarColor1B: document.getElementById('navbarColor1B').value,
            navbarColor2R: document.getElementById('navbarColor2R').value,
            navbarColor2G: document.getElementById('navbarColor2G').value,
            navbarColor2B: document.getElementById('navbarColor2B').value,
            navbarColor3R: document.getElementById('navbarColor3R').value,
            navbarColor3G: document.getElementById('navbarColor3G').value,
            navbarColor3B: document.getElementById('navbarColor3B').value,
            sidebarColor1R: document.getElementById('sidebarColor1R').value,
            sidebarColor1G: document.getElementById('sidebarColor1G').value,
            sidebarColor1B: document.getElementById('sidebarColor1B').value,
            sidebarColor2R: document.getElementById('sidebarColor2R').value,
            sidebarColor2G: document.getElementById('sidebarColor2G').value,
            sidebarColor2B: document.getElementById('sidebarColor2B').value,
            moduleColor1R: document.getElementById('moduleColor1R').value,
            moduleColor1G: document.getElementById('moduleColor1G').value,
            moduleColor1B: document.getElementById('moduleColor1B').value,
            moduleColor2R: document.getElementById('moduleColor2R').value,
            moduleColor2G: document.getElementById('moduleColor2G').value,
            moduleColor2B: document.getElementById('moduleColor2B').value
        };

        fetch('/Settings/SaveColors', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(colors)
        })
        .then(response => response.json())
        .then(data => {
            showMessage(data.message, data.success ? 'success' : 'danger');
        })
        .catch(error => {
            console.error('Error:', error);
            showMessage('Error al guardar los colores', 'danger');
        });
    }

    function resetColors() {
        if (confirm('¿Está seguro de que desea restablecer los valores predeterminados?')) {
            document.getElementById('navbarColor1R').value = '87';
            document.getElementById('navbarColor1G').value = '179';
            document.getElementById('navbarColor1B').value = '252';
            document.getElementById('navbarColor2R').value = '165';
            document.getElementById('navbarColor2G').value = '95';
            document.getElementById('navbarColor2B').value = '253';
            document.getElementById('navbarColor3R').value = '16';
            document.getElementById('navbarColor3G').value = '55';
            document.getElementById('navbarColor3B').value = '161';
            document.getElementById('sidebarColor1R').value = '87';
            document.getElementById('sidebarColor1G').value = '179';
            document.getElementById('sidebarColor1B').value = '252';
            document.getElementById('sidebarColor2R').value = '130';
            document.getElementById('sidebarColor2G').value = '157';
            document.getElementById('sidebarColor2B').value = '245';
            document.getElementById('moduleColor1R').value = '87';
            document.getElementById('moduleColor1G').value = '179';
            document.getElementById('moduleColor1B').value = '252';
            document.getElementById('moduleColor2R').value = '165';
            document.getElementById('moduleColor2G').value = '95';
            document.getElementById('moduleColor2B').value = '253';

            updatePreviews();
            showMessage('Valores restablecidos a valores predeterminados', 'success');
        }
    }

    function showMessage(message, type) {
        const alert = document.getElementById('messageAlert');
        const messageText = document.getElementById('messageText');
        alert.className = `alert alert-${type}`;
        messageText.textContent = message;
        alert.style.display = 'block';
        setTimeout(() => {
            alert.style.display = 'none';
        }, 5000);
    }
</script>
