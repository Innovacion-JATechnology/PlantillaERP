<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@ViewData["Title"] - PlantillaERP</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/custom-sidebar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sidebar-collapse.css" asp-append-version="true" />
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>
</head>
<body class="sb-nav-fixed">
    <!-- Top Navigation Bar -->
    <nav class="sb-topnav navbar navbar-expand navbar-dark">
        <a class="navbar-brand ps-3" asp-area="" asp-controller="Home" asp-action="Index">
            <i class="fas fa-briefcase me-2"></i><span class="brand-text">ERP</span>
        </a>
        <div class="ms-auto d-flex align-items-center gap-2">
            <button class="btn btn-link btn-sm text-white" id="sidebarCollapseToggle" type="button" title="Contraer/Expandir sidebar">
                <i class="fas fa-arrow-left"></i>
            </button>
            <button class="btn btn-link btn-sm" id="sidebarToggle" type="button" title="Mostrar/Ocultar sidebar">
                <i class="fas fa-bars"></i>
            </button>
        </div>
    </nav>

    <!-- Layout Container with Sidebar -->
    <div id="layoutSidenav">
        <div id="layoutSidenav_nav">
            <nav class="sb-sidenav accordion sb-sidenav-dark" id="sidenavAccordion">
                <div class="sb-sidenav-menu">
                    <div class="nav">
                        <div class="sb-sidenav-menu-heading">Modulos</div>

                        <!-- Compras Module -->
                        <a class="nav-link" asp-action="Compras" asp-controller="Modules" data-bs-toggle="tooltip" data-bs-placement="right" title="Compras">
                            <div class="sb-nav-link-icon"><i class="fas fa-shopping-cart"></i></div>
                            <span>Compras</span>
                        </a>

                        <!-- Inventario Module -->
                        <a class="nav-link" asp-action="Inventario" asp-controller="Modules" data-bs-toggle="tooltip" data-bs-placement="right" title="Inventario">
                            <div class="sb-nav-link-icon"><i class="fas fa-box"></i></div>
                            <span>Inventario</span>
                        </a>

                        <!-- Finanzas Module -->
                        <a class="nav-link" asp-action="Finanzas" asp-controller="Modules" data-bs-toggle="tooltip" data-bs-placement="right" title="Finanzas">
                            <div class="sb-nav-link-icon"><i class="fas fa-money-bill-wave"></i></div>
                            <span>Finanzas</span>
                        </a>

                        <!-- Mantenimiento Module -->
                        <a class="nav-link" asp-action="Mantenimiento" asp-controller="Modules" data-bs-toggle="tooltip" data-bs-placement="right" title="Mantenimiento">
                            <div class="sb-nav-link-icon"><i class="fas fa-wrench"></i></div>
                            <span>Mantenimiento</span>
                        </a>

                        <!-- Produccion Module -->
                        <a class="nav-link" asp-action="Produccion" asp-controller="Modules" data-bs-toggle="tooltip" data-bs-placement="right" title="Produccion">
                            <div class="sb-nav-link-icon"><i class="fas fa-cog"></i></div>
                            <span>Produccion</span>
                        </a>

                        <!-- RRHH Module -->
                        <a class="nav-link" asp-action="RRHH" asp-controller="Modules" data-bs-toggle="tooltip" data-bs-placement="right" title="RRHH">
                            <div class="sb-nav-link-icon"><i class="fas fa-users"></i></div>
                            <span>RRHH</span>
                        </a>

                        <!-- Proyectos Module -->
                        <a class="nav-link" asp-action="Proyectos" asp-controller="Modules" data-bs-toggle="tooltip" data-bs-placement="right" title="Proyectos">
                            <div class="sb-nav-link-icon"><i class="fas fa-building"></i></div>
                            <span>Proyectos</span>
                        </a>

                        <!-- Reporteador Module -->
                        <a class="nav-link" asp-action="Reporteador" asp-controller="Modules" data-bs-toggle="tooltip" data-bs-placement="right" title="Reporteador">
                            <div class="sb-nav-link-icon"><i class="fas fa-chart-line"></i></div>
                            <span>Reporteador</span>
                        </a>

                        <!-- Administracion Module -->
                        <a class="nav-link" asp-action="Administracion" asp-controller="Modules" data-bs-toggle="tooltip" data-bs-placement="right" title="Administracion">
                            <div class="sb-nav-link-icon"><i class="fas fa-sliders-h"></i></div>
                            <span>Administración</span>
                        </a>

                        <div class="sb-sidenav-menu-heading">Opciones</div>

                        <!-- Dashboard -->
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index" data-bs-toggle="tooltip" data-bs-placement="right" title="Dashboard">
                            <div class="sb-nav-link-icon"><i class="fas fa-tachometer-alt"></i></div>
                            <span>Dashboard</span>
                        </a>

                        <!-- Color Settings -->
                        <a class="nav-link" asp-action="ColorSettings" asp-controller="Settings" data-bs-toggle="tooltip" data-bs-placement="right" title="Configuración de Colores">
                            <div class="sb-nav-link-icon"><i class="fas fa-palette"></i></div>
                            <span>Colores</span>
                        </a>
                    </div>
                </div>
                <div class="sb-sidenav-footer">
                    <div class="small">Conectado como:</div>
                    <div>Administrador</div>
                </div>
            </nav>
        </div>

        <div id="layoutSidenav_content">
            <main>
                <div class="container-fluid px-4">
                    @RenderBody()
                </div>
            </main>

            <footer class="border-top footer text-muted">
                <div class="container">
                    &copy; 2024 - PlantillaERP - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                </div>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize tooltips
            const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(tooltipTriggerEl => new bootstrap.Tooltip(tooltipTriggerEl));

            const layoutNav = document.getElementById('layoutSidenav_nav');
            const layoutContent = document.getElementById('layoutSidenav_content');
            const sidebarNav = document.querySelector('.sb-sidenav');
            const sidebarCollapseBtn = document.getElementById('sidebarCollapseToggle');
            const sidebarToggleBtn = document.getElementById('sidebarToggle');

            console.log('Elements found:', { layoutNav, layoutContent, sidebarNav, sidebarCollapseBtn });

            // Collapse button
            if (sidebarCollapseBtn) {
                console.log('Collapse button found, attaching click event');
                sidebarCollapseBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    console.log('Collapse button CLICKED');

                    const isCollapsed = document.body.classList.contains('sb-sidenav-collapsed');
                    console.log('Is currently collapsed:', isCollapsed);

                    if (isCollapsed) {
                        console.log('Expanding...');
                        document.body.classList.remove('sb-sidenav-collapsed');
                        if (layoutNav) { 
                            layoutNav.style.width = '225px'; 
                            layoutNav.style.flex = '0 0 225px'; 
                        }
                        if (sidebarNav) {
                            sidebarNav.style.width = '225px';
                        }
                        if (layoutContent) { 
                            layoutContent.style.marginLeft = '225px';
                        }
                        console.log('Expanded to 225px');
                    } else {
                        console.log('Collapsing...');
                        document.body.classList.add('sb-sidenav-collapsed');
                        if (layoutNav) { 
                            layoutNav.style.width = '70px'; 
                            layoutNav.style.flex = '0 0 70px'; 
                        }
                        if (sidebarNav) {
                            sidebarNav.style.width = '70px';
                        }
                        if (layoutContent) { 
                            layoutContent.style.marginLeft = '70px';
                        }
                        console.log('Collapsed to 70px');
                    }

                    localStorage.setItem('sb|sidebar-collapsed', !isCollapsed);
                    updateIcon();
                });
            } else {
                console.error('Collapse button NOT found!');
            }

            // Toggle button (show/hide)
            if (sidebarToggleBtn) {
                sidebarToggleBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    document.body.classList.toggle('sb-sidenav-toggled');
                    localStorage.setItem('sb|sidebar-toggle', document.body.classList.contains('sb-sidenav-toggled'));
                });
            }

            // Restore states
            if (localStorage.getItem('sb|sidebar-collapsed') === 'true') {
                console.log('Restoring collapsed state');
                document.body.classList.add('sb-sidenav-collapsed');
                if (layoutNav) { layoutNav.style.width = '70px'; layoutNav.style.flex = '0 0 70px'; }
                if (sidebarNav) { sidebarNav.style.width = '70px'; }
                if (layoutContent) { layoutContent.style.marginLeft = '70px'; }
            }

            if (localStorage.getItem('sb|sidebar-toggle') === 'true') {
                console.log('Restoring toggle state');
                document.body.classList.add('sb-sidenav-toggled');
            }

            updateIcon();
        });

        function updateIcon() {
            const icon = document.querySelector('#sidebarCollapseToggle i');
            if (icon) {
                if (document.body.classList.contains('sb-sidenav-collapsed')) {
                    icon.className = 'fas fa-arrow-right';
                    console.log('Icon updated to arrow-right');
                } else {
                    icon.className = 'fas fa-arrow-left';
                    console.log('Icon updated to arrow-left');
                }
            }
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
