@{
    ViewData["Title"] = "Dashboard";
}

<div class="modules-container">
    <div class="text-center mb-4">
        <h1 class="display-4">Bienvenido a PlantillaERP</h1>
        <p class="lead">Selecciona un módulo para comenzar</p>
    </div>

    <div class="modules-grid">
        <!-- Compras Module -->
        <a asp-action="Compras" asp-controller="Modules" class="module-card compras">
            <div class="module-icon">
                <i class="fas fa-shopping-cart"></i>
            </div>
            <h3 class="module-title">Compras</h3>
            <p class="module-description">Gestión de compras e importaciones</p>
        </a>

        <!-- Inventario Module -->
        <a asp-action="Inventario" asp-controller="Modules" class="module-card inventario">
            <div class="module-icon">
                <i class="fas fa-box"></i>
            </div>
            <h3 class="module-title">Inventario</h3>
            <p class="module-description">Control de productos y stock</p>
        </a>

        <!-- Finanzas Module -->
        <a asp-action="Finanzas" asp-controller="Modules" class="module-card finanzas">
            <div class="module-icon">
                <i class="fas fa-money-bill-wave"></i>
            </div>
            <h3 class="module-title">Finanzas</h3>
            <p class="module-description">Gestión financiera y contable</p>
        </a>

        <!-- Mantenimiento Module -->
        <a asp-action="Mantenimiento" asp-controller="Modules" class="module-card mantenimiento">
            <div class="module-icon">
                <i class="fas fa-wrench"></i>
            </div>
            <h3 class="module-title">Mantenimiento</h3>
            <p class="module-description">Mantenimiento de equipos</p>
        </a>

        <!-- Produccion Module -->
        <a asp-action="Produccion" asp-controller="Modules" class="module-card produccion">
            <div class="module-icon">
                <i class="fas fa-cog"></i>
            </div>
            <h3 class="module-title">Producción</h3>
            <p class="module-description">Control de producción</p>
        </a>

        <!-- RRHH Module -->
        <a asp-action="RRHH" asp-controller="Modules" class="module-card rrhh">
            <div class="module-icon">
                <i class="fas fa-users"></i>
            </div>
            <h3 class="module-title">RRHH</h3>
            <p class="module-description">Recursos humanos</p>
        </a>

        <!-- Proyectos Module -->
        <a asp-action="Proyectos" asp-controller="Modules" class="module-card proyectos">
            <div class="module-icon">
                <i class="fas fa-building"></i>
            </div>
            <h3 class="module-title">Proyectos</h3>
            <p class="module-description">Gestión de proyectos</p>
        </a>

        <!-- Reporteador Module -->
        <a asp-action="Reporteador" asp-controller="Modules" class="module-card reporteador">
            <div class="module-icon">
                <i class="fas fa-chart-line"></i>
            </div>
            <h3 class="module-title">Reporteador</h3>
            <p class="module-description">Generación de reportes</p>
        </a>

        <!-- Administracion Module -->
        <a asp-action="Administracion" asp-controller="Modules" class="module-card administracion">
            <div class="module-icon">
                <i class="fas fa-sliders-h"></i>
            </div>
            <h3 class="module-title">Administración</h3>
            <p class="module-description">Configuración del sistema</p>
        </a>
    </div>
</div>
