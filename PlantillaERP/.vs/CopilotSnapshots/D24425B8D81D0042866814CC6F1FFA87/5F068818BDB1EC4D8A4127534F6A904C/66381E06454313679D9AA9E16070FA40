/* ============================================
   SIDEBAR COLLAPSE - STYLES FOR COLLAPSED STATE
   This file MUST be loaded LAST to ensure maximum specificity
   ============================================ */

/* FORCE COLLAPSE STYLES - ABSOLUTE PRIORITY */

/* 1. Sidebar navigation container */
body.sb-sidenav-collapsed #layoutSidenav_nav {
    width: 70px !important;
    flex: 0 0 70px !important;
    transition: width 0.3s ease !important;
}

/* 2. Sidebar element itself */
body.sb-sidenav-collapsed .sb-sidenav {
    width: 70px !important;
    transition: width 0.3s ease !important;
}

/* 3. Main content area - with all possible selectors */
body.sb-sidenav-collapsed #layoutSidenav_content {
    margin-left: 70px !important;
    padding-top: 2rem !important;
    padding-left: 0 !important;
    transition: margin-left 0.3s ease !important;
}

body.sb-nav-fixed.sb-sidenav-collapsed #layoutSidenav_content {
    margin-left: 70px !important;
    padding-top: 2rem !important;
    padding-left: 0 !important;
    transition: margin-left 0.3s ease !important;
}

body.sb-nav-fixed#layoutSidenav.sb-sidenav-collapsed #layoutSidenav_content {
    margin-left: 70px !important;
}

/* 4. Navigation links in collapsed state */
body.sb-sidenav-collapsed .sb-sidenav .nav-link {
    padding: 0.75rem 0 !important;
    justify-content: center !important;
    align-items: center !important;
    flex-direction: column !important;
    text-align: center !important;
    border-left: none !important;
    height: auto !important;
    min-height: 50px !important;
    display: flex !important;
}

/* 5. Hide text in collapsed state */
body.sb-sidenav-collapsed .sb-sidenav .nav-link span {
    display: none !important;
    visibility: hidden !important;
}

/* 6. Icon styling in collapsed state */
body.sb-sidenav-collapsed .sb-sidenav .nav-link .sb-nav-link-icon {
    margin-right: 0 !important;
    margin-bottom: 0 !important;
    font-size: 1.5rem !important;
    width: auto !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    flex-shrink: 0 !important;
}

/* 7. Hide menu headings */
body.sb-sidenav-collapsed .sb-sidenav-menu-heading {
    display: none !important;
    visibility: hidden !important;
}

/* 8. Hide nested menus */
body.sb-sidenav-collapsed .sb-sidenav-menu-nested {
    display: none !important;
    visibility: hidden !important;
}

body.sb-sidenav-collapsed .collapse {
    display: none !important;
    visibility: hidden !important;
}

/* 9. Footer styling in collapsed state */
body.sb-sidenav-collapsed .sb-sidenav-footer {
    padding: 0.5rem !important;
    font-size: 0.65rem !important;
    overflow: hidden !important;
}

body.sb-sidenav-collapsed .sb-sidenav-footer .small,
body.sb-sidenav-collapsed .sb-sidenav-footer div {
    white-space: nowrap !important;
    overflow: hidden !important;
    text-overflow: ellipsis !important;
    display: none !important;
    visibility: hidden !important;
}

/* 10. Collapsed + Toggled combination */
body.sb-sidenav-toggled.sb-sidenav-collapsed #layoutSidenav_content {
    margin-left: 0 !important;
}

body.sb-sidenav-toggled.sb-sidenav-collapsed #layoutSidenav_nav {
    width: 70px !important;
    flex: 0 0 70px !important;
    margin-left: 0 !important;
}

body.sb-sidenav-toggled.sb-sidenav-collapsed .sb-sidenav {
    width: 70px !important;
    display: flex !important;
    left: 0 !important;
}

/* 11. Ensure menu structure stays visible but icons only */
body.sb-sidenav-collapsed .sb-sidenav .nav {
    display: flex !important;
    flex-direction: column !important;
    padding-bottom: 1rem !important;
}

/* 12. Smooth transitions */
body.sb-sidenav-collapsed #layoutSidenav_nav,
body.sb-sidenav-collapsed .sb-sidenav,
body.sb-sidenav-collapsed #layoutSidenav_content {
    transition: all 0.3s ease !important;
}

/* Mobile/Tablet responsive */
@media (max-width: 991px) {
    body.sb-sidenav-collapsed #layoutSidenav_nav {
        width: 70px !important;
        left: 0 !important;
        position: fixed !important;
    }

    body.sb-sidenav-collapsed .sb-sidenav {
        width: 70px !important;
        position: fixed !important;
        left: 0 !important;
        top: 56px !important;
    }

    body.sb-sidenav-collapsed #layoutSidenav_content {
        margin-left: 0 !important;
    }

    body.sb-sidenav-collapsed.sb-sidenav-toggled .sb-sidenav {
        width: 70px !important;
        left: 0 !important;
    }

    body.sb-sidenav-collapsed.sb-sidenav-toggled #layoutSidenav_nav {
        width: 70px !important;
        left: 0 !important;
    }
}

/* Print styles */
@media print {
    body.sb-sidenav-collapsed #layoutSidenav_nav,
    body.sb-sidenav-collapsed .sb-sidenav {
        display: none !important;
    }

    body.sb-sidenav-collapsed #layoutSidenav_content {
        margin-left: 0 !important;
    }
}
