@{
    ViewData["Title"] = "Inventario";
}

<link rel="stylesheet" href="~/css/modules-layout.css" />

<div class="module-container">
    <div class="page-header-module">
        <h1><i class="fas fa-boxes me-2"></i>@ViewData["Title"]</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-action="Dashboard" asp-controller="Home">Dashboard</a></li>
                <li class="breadcrumb-item active">@ViewData["Title"]</li>
            </ol>
        </nav>
    </div>

    <div class="row g-4">
        <div class="col-lg-4 col-md-6 mb-3">
            <div class="card module-card card-primary shadow">
                <div class="card-body">
                    <i class="fas fa-shopping-bag module-card-icon"></i>
                    <div class="module-card-title">Productos</div>
                    <div class="module-card-desc">Ver catálogo completo</div>
                    <a asp-action="Productos" asp-controller="Modules" class="module-card-btn">
                        <i class="fas fa-arrow-right me-2"></i>Acceder
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-4 col-md-6 mb-3">
            <div class="card module-card card-info shadow">
                <div class="card-body">
                    <i class="fas fa-boxes module-card-icon"></i>
                    <div class="module-card-title">Stock</div>
                    <div class="module-card-desc">Gestionar inventario</div>
                    <a href="#" class="module-card-btn">
                        <i class="fas fa-arrow-right me-2"></i>Acceder
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-4 col-md-6 mb-3">
            <div class="card module-card card-warning shadow">
                <div class="card-body">
                    <i class="fas fa-arrows-alt module-card-icon"></i>
                    <div class="module-card-title">Movimientos</div>
                    <div class="module-card-desc">Historial de movimientos</div>
                    <a href="#" class="module-card-btn">
                        <i class="fas fa-arrow-right me-2"></i>Acceder
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-4 col-md-6 mb-3">
            <div class="card module-card card-danger shadow">
                <div class="card-body">
                    <i class="fas fa-warehouse module-card-icon"></i>
                    <div class="module-card-title">Almacenes</div>
                    <div class="module-card-desc">Gestionar almacenes</div>
                    <a href="#" class="module-card-btn">
                        <i class="fas fa-arrow-right me-2"></i>Acceder
                    </a>
                </div>
            </div>
