@{
    ViewData["Title"] = "Contabilidad";
}

<link rel="stylesheet" href="~/css/modules-layout.css" />

<div class="module-container">
    <div class="page-header-module">
        <h1><i class="fas fa-calculator me-2"></i>@ViewData["Title"]</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-action="Dashboard" asp-controller="Home">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-action="Finanzas" asp-controller="Modules">Finanzas</a></li>
                <li class="breadcrumb-item active">@ViewData["Title"]</li>
            </ol>
        </nav>
    </div>

    <div class="row g-4">
        <div class="col-lg-4 col-md-6 mb-3">
            <div class="card module-card card-success shadow">
                <div class="card-body">
                    <i class="fas fa-arrow-up module-card-icon"></i>
                    <div class="module-card-title">Ingresos</div>
                    <div class="module-card-desc">Registrar ingresos</div>
                    <a href="#" class="module-card-btn">
                        <i class="fas fa-arrow-right me-2"></i>Acceder
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-4 col-md-6 mb-3">
            <div class="card module-card card-danger shadow">
                <div class="card-body">
                    <i class="fas fa-arrow-down module-card-icon"></i>
                    <div class="module-card-title">Egresos</div>
                    <div class="module-card-desc">Registrar egresos</div>
                    <a href="#" class="module-card-btn">
                        <i class="fas fa-arrow-right me-2"></i>Acceder
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-4 col-md-6 mb-3">
            <div class="card module-card card-info shadow">
                <div class="card-body">
                    <i class="fas fa-balance-scale module-card-icon"></i>
                    <div class="module-card-title">Saldo</div>
                    <div class="module-card-desc">Ver balance actual</div>
                    <a href="#" class="module-card-btn">
                        <i class="fas fa-arrow-right me-2"></i>Acceder
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-4 col-md-6 mb-3">
            <div class="card module-card card-warning shadow">
                <div class="card-body">
                    <i class="fas fa-clock module-card-icon"></i>
                    <div class="module-card-title">Pendiente</div>
                    <div class="module-card-desc">Cuentas por cobrar</div>
                    <a href="#" class="module-card-btn">
                        <i class="fas fa-arrow-right me-2"></i>Acceder
                    </a>
                </div>
            </div>
        </div>
    </div>

    </div>

    <div class="card mt-5">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="fas fa-book me-2"></i>Registros Contables</h5>
        </div>
        <div class="card-body">
            <p class="text-muted mb-0">Sin registros disponibles</p>
        </div>
    </div>
</div>
