/* Responsive adjustments */
@media (max-width: 1024px) {
    .modules-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
    }

    .module-card {
        min-height: 150px;
    }

    .module-icon {
        width: 75px;
        height: 75px;
        font-size: 2.2rem;
        margin-bottom: 0.7rem;
    }

    .module-title {
        font-size: 1.1rem;
    }
}

@media (max-width: 768px) {
    .modules-container {
        padding: 1.5rem;
    }

    .modules-grid {
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    .module-card {
        padding: 1.5rem 2rem;
        min-height: 140px;
    }

    .module-icon {
        width: 70px;
        height: 70px;
        font-size: 2rem;
        margin-bottom: 0.6rem;
        border-width: 2.5px;
    }

    .module-title {
        font-size: 1rem;
    }

    .module-description {
        font-size: 0.8rem;
    }

    .option-card-footer {
        opacity: 1;
        margin-top: 0.5rem;
        padding-top: 0.5rem;
    }
}

@media (max-width: 480px) {
    .modules-container {
        padding: 1rem;
    }

    .modules-grid {
        grid-template-columns: 1fr;
        gap: 1rem;
    }

    .module-card {
        padding: 1.2rem 1.5rem;
        min-height: 130px;
    }

    .module-icon {
        width: 65px;
        height: 65px;
        font-size: 1.8rem;
        margin-bottom: 0.5rem;
        border-width: 2px;
    }

    .module-title {
        font-size: 0.95rem;
    }

    .module-description {
        font-size: 0.75rem;
    }
}
