/* Estilos para módulos en recuadros */
.modules-container {
    padding: 2rem;
    max-width: 1600px;
    margin: 0 auto;
    width: 100%;
    box-sizing: border-box;
}

.modules-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
    margin-top: 2rem;
    width: 100%;
}

.module-card {
    background: #fff;
    border-radius: 12px;
    padding: 3rem 2.5rem;
    text-align: center;
    transition: all 0.3s ease;
    border: 1px solid #e0e0e0;
    border-bottom: 4px solid #0d6efd;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: visible;
    min-height: 200px;
}

.module-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 0;
    background: transparent;
    transition: all 0.3s ease;
}

.module-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15);
    text-decoration: none;
}

.module-card:hover::before {
    height: 0;
}

.module-icon {
    font-size: 2.8rem;
    margin-bottom: 1rem;
    color: #0d6efd;
    transition: all 0.3s ease;
    width: 100px;
    height: 100px;
    border: 3px solid #0d6efd;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
}

.module-card:hover .module-icon {
    color: #0a58ca;
    border-color: #0a58ca;
    transform: scale(1.1);
}

.module-title {
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: #212529;
}

.module-description {
    font-size: 0.9rem;
    color: #6c757d;
    margin: 0;
}

/* Estilos específicos para tarjetas de opciones */
.option-card {
    position: relative;
}

.option-card-footer {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid #e0e0e0;
    opacity: 0;
    transition: opacity 0.3s ease;
}

.option-card:hover .option-card-footer {
    opacity: 1;
}

