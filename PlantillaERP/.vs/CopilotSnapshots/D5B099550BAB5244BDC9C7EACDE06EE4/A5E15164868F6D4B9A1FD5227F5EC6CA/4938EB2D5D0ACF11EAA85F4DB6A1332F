@{
    ViewData["Title"] = "Histórico de Mantenimiento";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Dashboard" asp-controller="Home">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Mantenimiento" asp-controller="Modules">Mantenimiento</a></li>
            <li class="breadcrumb-item active">@ViewData["Title"]</li>
        </ol>
    </nav>

    <h1 class="h3 mb-4">@ViewData["Title"]</h1>

    <div class="card shadow">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">
                <i class="fas fa-archive me-2"></i>Historial de Trabajos
            </h6>
        </div>
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Fecha</th>
                        <th>Equipo</th>
                        <th>Tipo</th>
                        <th>Técnico</th>
                        <th>Duración</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="5" class="text-center text-muted">Sin registros disponibles</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
