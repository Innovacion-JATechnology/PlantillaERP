@{
    ViewData["Title"] = "Exportar Reportes";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Dashboard" asp-controller="Home">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Reporteador" asp-controller="Modules">Reporteador</a></li>
            <li class="breadcrumb-item active">@ViewData["Title"]</li>
        </ol>
    </nav>

    <h1 class="h3 mb-4">@ViewData["Title"]</h1>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card shadow h-100">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Exportar a Excel</h6>
                </div>
                <div class="card-body">
                    <p class="text-muted">Descargar reportes en formato Excel</p>
                    <button class="btn btn-primary btn-sm">
                        <i class="fas fa-download me-2"></i>Exportar
                    </button>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-4">
            <div class="card shadow h-100">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Exportar a PDF</h6>
                </div>
                <div class="card-body">
                    <p class="text-muted">Descargar reportes en formato PDF</p>
                    <button class="btn btn-primary btn-sm">
                        <i class="fas fa-download me-2"></i>Exportar
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
