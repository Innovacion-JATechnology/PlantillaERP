@{
    var breadcrumbs = ViewData["Breadcrumbs"] as List<(string Title, string Url)> ?? new List<(string, string)>();
}

@if (breadcrumbs.Count > 0)
{
    <nav aria-label="breadcrumb" class="d-none d-md-flex align-items-center ms-3">
        <ol class="breadcrumb breadcrumb-nav mb-0">
            @foreach (var (index, breadcrumb) in breadcrumbs.Select((b, i) => (i, b)))
            {
                @if (index < breadcrumbs.Count - 1)
                {
                    <li class="breadcrumb-item">
                        <a href="@breadcrumb.Url" class="text-white text-decoration-none">
                            @breadcrumb.Title
                        </a>
                    </li>
                }
                else
                {
                    <li class="breadcrumb-item active text-white">@breadcrumb.Title</li>
                }
            }
        </ol>
    </nav>
}
