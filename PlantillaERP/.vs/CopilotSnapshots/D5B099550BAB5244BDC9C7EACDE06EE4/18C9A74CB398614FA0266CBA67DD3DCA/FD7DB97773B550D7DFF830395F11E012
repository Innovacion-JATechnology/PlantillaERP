@{
    ViewData["Title"] = (string)ViewData["Title"];
    var moduleOptions = (List<Dictionary<string, string>>)ViewData["ModuleOptions"];
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-md-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Dashboard" asp-controller="Home">Dashboard</a></li>
                    <li class="breadcrumb-item active">@ViewData["Title"]</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center">
                <h1 class="h3 mb-0">@ViewData["Title"]</h1>
                <a asp-action="Dashboard" asp-controller="Home" class="btn btn-secondary btn-sm">
                    <i class="fas fa-arrow-left me-2"></i>Volver al Dashboard
                </a>
            </div>
        </div>
    </div>

    @if (moduleOptions != null && moduleOptions.Count > 0)
    {
        <div class="row">
            <div class="col-md-12">
                <div class="modules-grid">
                    @foreach (var option in moduleOptions)
                    {
                        var moduleName = option.ContainsKey("Name") ? option["Name"] : "Opción";
                        var action = option.ContainsKey("Action") ? option["Action"] : "#";
                        var icon = option.ContainsKey("Icon") ? option["Icon"] : "fas fa-folder";
                        var description = option.ContainsKey("Description") ? option["Description"] : "";

                        <a asp-action="@action" asp-controller="Modules" class="module-card option-card">
                            <div class="module-icon">
                                <i class="@icon"></i>
                            </div>
                            <h3 class="module-title">@moduleName</h3>
                            <p class="module-description">@description</p>
                            <div class="option-card-footer">
                                <small class="text-muted">
                                    <i class="fas fa-arrow-right me-2"></i>Acceder
                                </small>
                            </div>
                        </a>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-12">
                <div class="alert alert-info" role="alert">
                    <i class="fas fa-info-circle me-2"></i>
                    <strong>Información:</strong> Este módulo aún no tiene opciones disponibles.
                </div>
            </div>
        </div>
    }
</div>
