/* Responsive adjustments */
@media (max-width: 1024px) {
    .modules-grid,
    .options-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 2.5rem;
        padding: 0 1.5rem;
        width: fit-content;
        max-width: 1200px;
    }

    .module-card,
    .option-item {
        min-height: 220px;
        padding: 3rem 2.5rem;
    }

    .module-icon,
    .option-icon {
        width: 100px;
        height: 100px;
        font-size: 2.7rem;
        margin-bottom: 0.9rem;
    }

    .module-title,
    .option-title {
        font-size: 1.25rem;
    }
}

@media (max-width: 768px) {
    .modules-container,
    .options-container {
        padding: 1.5rem 0;
    }

    .modules-container > div:not(.modules-grid),
    .options-container > div:not(.options-grid) {
        padding: 0 1.5rem;
    }

    .modules-grid,
    .options-grid {
        grid-template-columns: 1fr;
        gap: 1.5rem;
        padding: 0 1.5rem;
        width: fit-content;
        max-width: 600px;
    }

    .module-card,
    .option-item {
        padding: 2.5rem 2rem;
        min-height: 200px;
    }

    .module-icon,
    .option-icon {
        width: 90px;
        height: 90px;
        font-size: 2.4rem;
        margin-bottom: 0.8rem;
        border-width: 2.5px;
    }

    .module-title,
    .option-title {
        font-size: 1.15rem;
    }

    .module-description,
    .option-description {
        font-size: 0.9rem;
    }

    .option-card-footer {
        opacity: 1;
        margin-top: 0.5rem;
        padding-top: 0.5rem;
    }
}

@media (max-width: 480px) {
    .modules-container,
    .options-container {
        padding: 1rem 0;
    }

    .modules-container > div:not(.modules-grid),
    .options-container > div:not(.options-grid) {
        padding: 0 1rem;
    }

    .modules-grid,
    .options-grid {
        grid-template-columns: 1fr;
        gap: 1rem;
        padding: 0 1rem;
        width: fit-content;
        max-width: 500px;
    }

    .module-card,
    .option-item {
        padding: 1.5rem 1rem;
        min-height: 140px;
    }

    .module-icon,
    .option-icon {
        width: 70px;
        height: 70px;
        font-size: 2rem;
        margin-bottom: 0.5rem;
        border-width: 2px;
    }

    .module-title,
    .option-title {
        font-size: 1rem;
    }

    .module-description,
    .option-description {
        font-size: 0.8rem;
    }
}
