/* Estilos para módulos en recuadros */
.modules-container {
    width: 100%;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
    box-sizing: border-box;
}

.modules-container > div:not(.modules-grid) {
    width: 100%;
    text-align: center;
}

.modules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 3.5rem;
    padding: 0;
    box-sizing: border-box;
    margin-top: 2rem;
    margin-left: auto;
    margin-right: auto;
    width: 100%;
    max-width: 1200px;
}





.module-card {
    background: #fff;
    border-radius: 12px;
    padding: 3.5rem 3.2rem;
    text-align: center;
    transition: all 0.3s ease;
    border: 1px solid #e0e0e0;
    border-bottom: 4px solid #0d6efd;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.08);
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: visible;
    min-height: 240px;
}

.module-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 0;
    background: transparent;
    transition: all 0.3s ease;
}

.module-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15);
    text-decoration: none;
}

.module-card:hover::before {
    height: 0;
}

.module-icon {
    font-size: 3rem;
    margin-bottom: 1.2rem;
    color: #0d6efd;
    transition: all 0.3s ease;
    width: 110px;
    height: 110px;
    border: 3px solid #0d6efd;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
}

.module-card:hover .module-icon {
    color: #0a58ca;
    border-color: #0a58ca;
    transform: scale(1.1);
}

.module-title {
    font-size: 1.4rem;
    font-weight: 600;
    margin-bottom: 0.7rem;
    color: #212529;
}

.module-description {
    font-size: 0.95rem;
    color: #6c757d;
    margin: 0;
}

/* Estilos específicos para tarjetas de opciones */
.option-card {
    position: relative;
}

.option-card-footer {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid #e0e0e0;
    opacity: 0;
    transition: opacity 0.3s ease;
}

.option-card:hover .option-card-footer {
    opacity: 1;
}

/* Grid de opciones para cada módulo */
.options-container {
    width: 100%;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
    box-sizing: border-box;
}

.options-container > div:not(.options-grid) {
    width: 100%;
    text-align: center;
}

.options-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 3.5rem;
    padding: 0;
    box-sizing: border-box;
    margin-top: 2rem;
    margin-left: auto;
    margin-right: auto;
    width: 100%;
    max-width: 1900px;
}

.option-item {
    background: #fff;
    border-radius: 12px;
    padding: 3.5rem 3.2rem;
    text-align: center;
    transition: all 0.3s ease;
    border: 1px solid #e0e0e0;
    border-bottom: 4px solid #0d6efd;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: visible;
    min-height: 240px;
}

.option-item:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15);
    text-decoration: none;
}

.option-icon {
    font-size: 2.8rem;
    margin-bottom: 1rem;
    color: #0d6efd;
    transition: all 0.3s ease;
    width: 100px;
    height: 100px;
    border: 3px solid #0d6efd;
