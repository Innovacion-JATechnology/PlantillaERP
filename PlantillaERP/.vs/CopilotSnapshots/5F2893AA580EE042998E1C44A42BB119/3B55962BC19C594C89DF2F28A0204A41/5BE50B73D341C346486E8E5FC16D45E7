/* ============================================
   CUSTOM SIDEBAR - PARTIAL COLLAPSE WITH ICONS ONLY
   ============================================ */

/* Main layout structure */
#layoutSidenav {
    display: flex;
    height: calc(100vh - 56px);
}

#layoutSidenav_nav {
    flex: 0 0 auto;
}

#layoutSidenav_content {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
}

/* Navbar styling */
.sb-topnav {
    background-color: #212529 !important;
    box-shadow: 0 0.15rem 1.75rem 0 rgba(33, 37, 41, 0.15);
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
    height: 56px;
    align-items: center;
}

.sb-topnav .navbar-brand {
    color: #ffffff !important;
    font-weight: 600;
    font-size: 1.2rem;
}

/* Sidebar styling */
.sb-sidenav {
    background: linear-gradient(180deg, #343a40 10%, #23282d 100%);
    color: #ffffff;
    width: 225px;
    box-shadow: 0 0.15rem 1.75rem 0 rgba(33, 37, 41, 0.15);
    transition: width 0.3s ease;
    display: flex;
    flex-direction: column;
    height: calc(100vh - 56px);
    position: relative;
}

.sb-sidenav .sb-sidenav-menu {
    flex: 1;
    overflow-y: auto;
}

.sb-sidenav .sb-sidenav-footer {
    background-color: rgba(0, 0, 0, 0.2);
    padding: 1rem;
    text-align: center;
    font-size: 0.875rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
}

/* Nav items */
.sb-sidenav .nav {
    padding-top: 1rem;
    padding-bottom: 1rem;
}

.sb-sidenav .nav-link {
    color: rgba(255, 255, 255, 0.7);
    padding: 0.75rem 1rem;
    cursor: pointer;
    transition: color 0.15s ease-in-out, background-color 0.15s ease-in-out;
    display: flex;
    align-items: center;
    font-size: 0.95rem;
}

.sb-sidenav .nav-link:hover,
.sb-sidenav .nav-link.active {
    color: #ffffff;
    background-color: rgba(255, 255, 255, 0.1);
}

.sb-sidenav .nav-link.active {
    font-weight: 600;
}

/* Menu heading */
.sb-sidenav-menu-heading {
    padding: 1rem 1rem 0.5rem 1rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05rem;
    color: rgba(255, 255, 255, 0.5);
}

/* Icon styling */
.sb-nav-link-icon {
    margin-right: 0.75rem;
    width: 1.25rem;
    display: inline-flex;
    justify-content: center;
    align-items: center;
}

/* Collapse arrow */
.sb-sidenav-collapse-arrow {
    margin-left: auto;
    transition: transform 0.3s ease;
}

.sb-sidenav .nav-link[aria-expanded="true"] .sb-sidenav-collapse-arrow {
    transform: rotate(-180deg);
}

/* Submenu styling */
.sb-sidenav .collapse {
    padding-left: 1rem;
}

.sb-sidenav-menu-nested {
    padding: 0.5rem 0;
    list-style: none;
    padding-left: 0;
}

.sb-sidenav-menu-nested .nav-link {
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.6);
}

.sb-sidenav-menu-nested .nav-link:hover {
    color: #ffffff;
    background-color: rgba(255, 255, 255, 0.05);
    border-radius: 0.375rem;
}

/* Ensure consistent top positioning for content area */
#layoutSidenav #layoutSidenav_content {
    margin-top: 0 !important;
    top: 0 !important;
    padding-top: 30px !important;
}

/* When sidebar is toggled (collapsed to show only icons) */

/* Sidebar width and structure - applies to all screen sizes */
.sb-sidenav-toggled #layoutSidenav_nav .sb-sidenav {
    width: 60px !important;
}

/* Fix padding for both regular and fixed navbar modes */
.sb-sidenav-toggled #layoutSidenav #layoutSidenav_content {
    margin-left: 0 !important;
    padding-left: 60px !important;
}

/* Override the transform that hides the sidebar completely - large screens */
@media (min-width: 992px) {
    .sb-sidenav-toggled #layoutSidenav #layoutSidenav_nav {
        transform: translateX(0) !important;
        width: 60px !important;
    }
}

/* Ensure consistent width even with fixed navbar */
.sb-nav-fixed.sb-sidenav-toggled #layoutSidenav #layoutSidenav_nav {
    width: 60px !important;
    color: white !important;
}

/* Nav links styling when collapsed */
.sb-sidenav-toggled #layoutSidenav_nav .sb-sidenav .nav-link {
    width: 60px !important;
    padding: 0 !important;
    display: flex !important;
    justify-content: center !important;
    align-items: center !important;
    min-height: 45px;
}

/* Hide text content in nav links */
.sb-sidenav-toggled #layoutSidenav_nav .sb-sidenav .nav-link span {
    display: none !important;
    visibility: hidden !important;
    width: 0 !important;
    height: 0 !important;
    overflow: hidden !important;
}

/* Icon styling */
.sb-sidenav-toggled #layoutSidenav_nav .sb-sidenav .sb-nav-link-icon {
    margin-right: 0 !important;
    display: flex !important;
    justify-content: center !important;
    align-items: center !important;
    width: 100% !important;
    color: white !important;
}

/* Hide menu headings */
.sb-sidenav-toggled #layoutSidenav_nav .sb-sidenav .sb-sidenav-menu-heading {
    display: none !important;
}

/* Footer styling */
.sb-sidenav-toggled #layoutSidenav_nav .sb-sidenav .sb-sidenav-footer {
    width: 60px !important;
    min-height: 45px;
    display: flex !important;
    justify-content: center !important;
    align-items: center !important;
    padding: 0 !important;
}

.sb-sidenav-toggled #layoutSidenav_nav .sb-sidenav .sb-sidenav-footer .small {
    display: none !important;
}

.sb-sidenav-toggled #layoutSidenav_nav .sb-sidenav .sb-sidenav-footer > div:not(.sb-nav-link-icon) {
    display: none !important;
}

/* Ensure consistent layout for expanded sidebar */
#layoutSidenav #layoutSidenav_content {
    transition: padding-left 0.3s ease !important;
}

/* Smooth transitions */
.sb-sidenav-toggled #layoutSidenav_nav,
.sb-sidenav-toggled #layoutSidenav_nav .sb-sidenav {
    transition: width 0.3s ease, transform 0.3s ease !important;
}

/* Hide submenu text when sidebar is collapsed */
.sb-sidenav-toggled .sb-sidenav-menu-nested .nav-link {
    display: none !important;
}

.sb-sidenav-toggled .collapse {
    display: none !important;
    padding-left: 0 !important;
}

/* Main collapsed nav-link arrow */
.sb-sidenav-toggled .sb-sidenav-collapse-arrow {
    display: none !important;
}

.sb-sidenav .sb-nav-link-icon {
    color: #ffffff !important;
}

/* Fixed navbar adjustments */
.sb-nav-fixed {
    padding-top: 56px;
}

.sb-nav-fixed .sb-topnav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1030;
}

.sb-nav-fixed #layoutSidenav {
    margin-top: 56px;
}

.sb-nav-fixed #layoutSidenav_nav {
    position: fixed;
    top: 56px;
    left: 0;
    height: calc(100vh - 56px);
    width: 225px;
    overflow-y: auto;
    z-index: 1020;
}

.sb-nav-fixed #layoutSidenav_content {
    margin-left: 225px;
    width: calc(100% - 225px);
}

/* Responsive adjustments */
@media (max-width: 991px) {
    .sb-sidenav {
        width: 100%;
        position: fixed;
        top: 56px;
        left: 0;
        height: calc(100vh - 56px);
        z-index: 1000;
        transform: translateX(-100%);
        transition: transform 0.3s ease;
    }

    .sb-nav-fixed #layoutSidenav_content {
        margin-left: 0;
        width: 100%;
    }

    .sb-sidenav-toggled .sb-sidenav {
        transform: translateX(0);
    }
}
