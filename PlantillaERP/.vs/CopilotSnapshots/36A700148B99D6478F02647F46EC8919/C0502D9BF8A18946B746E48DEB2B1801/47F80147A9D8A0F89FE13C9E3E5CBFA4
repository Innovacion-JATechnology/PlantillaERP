@{
    ViewData["Title"] = "Productos";
    List<dynamic> productos = ViewData["Productos"] != null ? (List<dynamic>)ViewData["Productos"] : new List<dynamic>();
    int currentPage = (int?)ViewData["CurrentPage"] ?? 1;
    int totalPages = (int?)ViewData["TotalPages"] ?? 1;
    string searchTerm = ViewData["SearchTerm"]?.ToString() ?? string.Empty;
    string sortBy = ViewData["SortBy"]?.ToString() ?? "Id";
    string sortDirection = ViewData["SortDirection"]?.ToString() ?? "ASC";
}

<div class="container-fluid px-4">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 mt-3">
        <div>
            <h2 class="mb-1"><i class="fas fa-box text-primary"></i> Catálogo de Productos</h2>
            <small class="text-muted">Gestiona el inventario de productos</small>
        </div>
        <button type="button" class="btn btn-primary btn-lg" data-bs-toggle="modal" data-bs-target="#addModal">
            <i class="fas fa-plus"></i> Nuevo Producto
        </button>
    </div>

    <!-- Search and Filter Section -->
    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-body">
            <form method="get" action="@Url.Action("Productos", "Inventario")" class="row g-2 align-items-end">
                <div class="col-md-10">
                    <input type="text" 
                           class="form-control form-control-lg" 
                           name="searchTerm" 
                           placeholder="🔍 Buscar por Id, producto o talla..." 
                           value="@searchTerm">
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search"></i> Buscar
                    </button>
                    @if (!string.IsNullOrEmpty(searchTerm))
                    {
                        <a href="@Url.Action("Productos", "Inventario")" class="btn btn-outline-secondary" title="Limpiar búsqueda">
                            <i class="fas fa-times"></i>
                        </a>
                    }
                </div>
            </form>
        </div>
    </div>

    <!-- Products Table Section -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-list text-primary"></i> Productos
                    @if (productos.Count > 0)
                    {
                        <span class="badge bg-primary">@productos.Count</span>
                    }
                </h5>
                @if (totalPages > 1)
                {
                    <small class="text-muted">Página @currentPage de @totalPages</small>
                }
            </div>
        </div>

        <!-- Products Table -->
        <div class="table-responsive">
            @if (productos != null && productos.Count > 0)
            {
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr class="text-uppercase small">
                            <th style="width: 12%;">
                                <a href="@Url.Action("Productos", "Inventario", new { searchTerm = searchTerm, page = 1, sortBy = "Id", sortDirection = (sortBy == "Id" && sortDirection == "ASC") ? "DESC" : "ASC" })" 
                                   class="text-decoration-none text-dark fw-bold">
                                    Id
                                    @if (sortBy == "Id")
                                    {
                                        <i class="fas fa-@(sortDirection == "ASC" ? "arrow-up" : "arrow-down") ms-1 text-primary"></i>
                                    }
                                </a>
                            </th>
                            <th style="width: 55%;">
                                <a href="@Url.Action("Productos", "Inventario", new { searchTerm = searchTerm, page = 1, sortBy = "Producto", sortDirection = (sortBy == "Producto" && sortDirection == "ASC") ? "DESC" : "ASC" })" 
                                   class="text-decoration-none text-dark fw-bold">
                                    Producto
                                    @if (sortBy == "Producto")
                                    {
                                        <i class="fas fa-@(sortDirection == "ASC" ? "arrow-up" : "arrow-down") ms-1 text-primary"></i>
                                    }
                                </a>
                            </th>
                            <th style="width: 18%;">Talla</th>
                            <th style="width: 15%; text-align: center;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var producto in productos)
                        {
                            <tr class="border-bottom">
                                <td>
                                    <span class="badge bg-light text-dark">@(((IDictionary<string, object>)producto)["Id"])</span>
                                </td>
                                <td>
                                    <strong>@(((IDictionary<string, object>)producto)["Producto"])</strong>
                                </td>
                                <td>
                                    <span class="text-muted">@(((IDictionary<string, object>)producto)["Talla"] ?? "—")</span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <button type="button" 
                                                class="btn btn-outline-primary" 
                                                data-bs-toggle="modal" 
                                                data-bs-target="#editModal"
                                                data-id="@(((IDictionary<string, object>)producto)["Id"])"
                                                data-producto="@(((IDictionary<string, object>)producto)["Producto"])"
                                                data-talla="@(((IDictionary<string, object>)producto)["Talla"])"
                                                title="Editar producto">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button type="button" 
                                                class="btn btn-outline-danger" 
                                                data-bs-toggle="modal" 
                                                data-bs-target="#deleteModal"
                                                data-id="@(((IDictionary<string, object>)producto)["Id"])"
                                                data-producto="@(((IDictionary<string, object>)producto)["Producto"])"
                                                title="Eliminar producto">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="p-5 text-center">
                    <div class="mb-3">
                        <i class="fas fa-inbox" style="font-size: 3rem; color: #ddd;"></i>
                    </div>
                    <h5 class="text-muted">No hay productos para mostrar</h5>
                    <p class="text-muted mb-0">
                        @if (!string.IsNullOrEmpty(searchTerm))
                        {
                            <span>No se encontraron resultados para "<strong>@searchTerm</strong>". <a href="@Url.Action("Productos", "Inventario")">Borrar búsqueda</a></span>
                        }
                        else
                        {
                            <span>Comienza <button type="button" class="btn btn-link p-0" data-bs-toggle="modal" data-bs-target="#addModal">agregando un producto</button></span>
                        }
                    </p>
                </div>
            }
        </div>
    </div>

    <!-- Pagination -->
    @if (totalPages > 1)
    {
        <nav aria-label="Page navigation" class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <small class="text-muted">Total de páginas: <strong>@totalPages</strong></small>
            
            <ul class="pagination pagination-sm mb-0" style="gap: 5px; flex-wrap: wrap; justify-content: center;">
                @{
                    int startPage = Math.Max(1, currentPage - 2);
                    int endPage = Math.Min(totalPages, currentPage + 2);
                }

                @if (currentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Productos", "Inventario", new { searchTerm = searchTerm, page = 1, sortBy = sortBy, sortDirection = sortDirection })" title="Primera página">
                            <i class="fas fa-chevron-left"></i> Anterior
                        </a>
                    </li>
                }

                @if (startPage > 1)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                @for (int i = startPage; i <= endPage; i++)
                {
                    if (i == currentPage)
                    {
                        <li class="page-item active">
                            <span class="page-link">@i</span>
                        </li>
                    }
                    else
                    {
                        <li class="page-item">
                            <a class="page-link" 
                               href="@Url.Action("Productos", "Inventario", new { searchTerm = searchTerm, page = i, sortBy = sortBy, sortDirection = sortDirection })">
                                @i
                            </a>
                        </li>
                    }
                }

                @if (endPage < totalPages)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                @if (currentPage < totalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Productos", "Inventario", new { searchTerm = searchTerm, page = totalPages, sortBy = sortBy, sortDirection = sortDirection })" title="Última página">
                            Siguiente <i class="fas fa-chevron-right"></i>
                        </a>
                    </li>
                }
            </ul>

            <small class="text-muted">Página <strong>@currentPage</strong></small>
        </nav>
    }

    <!-- Messages -->
    @if (ViewData["Message"] != null)
    {
        <div class="alert alert-@(ViewData["MessageType"]?.ToString() == "danger" ? "danger" : "success") alert-dismissible fade show" role="alert">
            <i class="fas fa-@(ViewData["MessageType"]?.ToString() == "danger" ? "exclamation-circle" : "check-circle")"></i>
            @ViewData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
</div>

<!-- Modal: Agregar Nuevo Producto -->
<div class="modal fade" id="addModal" tabindex="-1" aria-labelledby="addModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="modal-title" id="addModalLabel">
                    <i class="fas fa-plus-circle"></i> Nuevo Producto
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="@Url.Action("Productos", "Inventario")">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="addId" class="form-label fw-bold">Id / SKU <span class="text-danger">*</span></label>
                        <input type="text" class="form-control form-control-lg" id="addId" name="id" placeholder="Ej. SKU-001" required>
                        <small class="text-muted d-block mt-1">Identificador único del producto</small>
                    </div>
                    <div class="mb-3">
                        <label for="addProducto" class="form-label fw-bold">Nombre del Producto <span class="text-danger">*</span></label>
                        <input type="text" class="form-control form-control-lg" id="addProducto" name="producto" placeholder="Nombre del producto" required>
                    </div>
                    <div class="mb-3">
                        <label for="addTalla" class="form-label fw-bold">Talla</label>
                        <input type="text" class="form-control form-control-lg" id="addTalla" name="talla" placeholder="Ej. M, L, XL, 36, etc.">
                        <small class="text-muted d-block mt-1">Opcional: tamaño o variante del producto</small>
                    </div>
                </div>
                <div class="modal-footer bg-light border-top">
                    <input type="hidden" name="action" value="save" />
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times"></i> Cancelar
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-check"></i> Guardar Producto
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Editar Producto -->
<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="modal-title" id="editModalLabel">
                    <i class="fas fa-edit"></i> Editar Producto
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="@Url.Action("Productos", "Inventario")">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="editId" class="form-label fw-bold">Id / SKU</label>
                        <input type="text" class="form-control form-control-lg" id="editId" name="id" readonly style="background-color: #f8f9fa;">
                    </div>
                    <div class="mb-3">
                        <label for="editProducto" class="form-label fw-bold">Nombre del Producto <span class="text-danger">*</span></label>
                        <input type="text" class="form-control form-control-lg" id="editProducto" name="producto" required>
                    </div>
                    <div class="mb-3">
                        <label for="editTalla" class="form-label fw-bold">Talla</label>
                        <input type="text" class="form-control form-control-lg" id="editTalla" name="talla">
                    </div>
                </div>
                <div class="modal-footer bg-light border-top">
                    <input type="hidden" name="action" value="update" />
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times"></i> Cancelar
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Confirmar Eliminación -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-danger text-white border-0">
                <h5 class="modal-title" id="deleteModalLabel">
                    <i class="fas fa-trash-alt"></i> Eliminar Producto
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="@Url.Action("Productos", "Inventario")">
                <div class="modal-body">
                    <div class="alert alert-warning" role="alert">
                        <i class="fas fa-exclamation-triangle"></i> Esta acción no se puede deshacer.
                    </div>
                    <p><strong id="deleteProductName">Producto</strong></p>
                    <p class="mb-0">¿Estás seguro de que deseas eliminar este producto?</p>
                </div>
                <div class="modal-footer bg-light border-top">
                    <input type="hidden" name="id" id="deleteId" />
                    <input type="hidden" name="action" value="delete" />
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times"></i> Cancelar
                    </button>
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash"></i> Eliminar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Handle edit modal population
        const editModal = document.getElementById('editModal');
        if (editModal) {
            editModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                const id = button.getAttribute('data-id');
                const producto = button.getAttribute('data-producto');
                const talla = button.getAttribute('data-talla');

                document.getElementById('editId').value = id;
                document.getElementById('editProducto').value = producto;
                document.getElementById('editTalla').value = talla || '';
            });
        }

        // Handle delete modal population
        const deleteModal = document.getElementById('deleteModal');
        if (deleteModal) {
            deleteModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                const id = button.getAttribute('data-id');
                const producto = button.getAttribute('data-producto');
                
                document.getElementById('deleteId').value = id;
                document.getElementById('deleteProductName').textContent = producto;
            });
        }

        // Auto-dismiss alerts after 5 seconds
        document.querySelectorAll('.alert').forEach(alert => {
            setTimeout(() => {
                const bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            }, 5000);
        });
    </script>
}
