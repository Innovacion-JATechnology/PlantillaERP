@{
    ViewData["Title"] = "Productos";
    List<dynamic> productos = ViewData["Productos"] != null ? (List<dynamic>)ViewData["Productos"] : new List<dynamic>();
    int currentPage = (int?)ViewData["CurrentPage"] ?? 1;
    int totalPages = (int?)ViewData["TotalPages"] ?? 1;
    string searchTerm = ViewData["SearchTerm"]?.ToString() ?? string.Empty;
    string sortBy = ViewData["SortBy"]?.ToString() ?? "Id";
    string sortDirection = ViewData["SortDirection"]?.ToString() ?? "ASC";
}

<link rel="stylesheet" href="~/css/productos.css" asp-append-version="true" />

<div class="productos-container">
    <div class="container-fluid px-4 py-4">
        <div class="productos-content">

            <!-- HEADER SECTION -->
            <div class="productos-header">
                <div class="productos-header-title">
                    <h1>
                        <i class="fas fa-box"></i> Catálogo de Productos
                    </h1>
                    <p>Gestiona el inventario completo de productos</p>
                </div>
                <button type="button" class="btn btn-primary btn-new-producto btn-lg" data-bs-toggle="modal" data-bs-target="#addModal">
                    <i class="fas fa-plus"></i> Nuevo Producto
                </button>
            </div>

            <!-- SEARCH SECTION -->
            <div class="search-section">
                <form method="get" action="@Url.Action("Productos", "Inventario")" class="search-form">
                    <input type="text" 
                           class="form-control flex-grow-1" 
                           name="searchTerm" 
                           placeholder="🔍 Buscar por Id, producto o talla..." 
                           value="@searchTerm">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-search"></i> Buscar
                    </button>
                    @if (!string.IsNullOrEmpty(searchTerm))
                    {
                        <a href="@Url.Action("Productos", "Inventario")" class="btn btn-outline-secondary" title="Limpiar búsqueda">
                            <i class="fas fa-times"></i> Limpiar
                        </a>
                    }
                </form>
            </div>

            <!-- ALERTS -->
            @if (ViewData["Message"] != null)
            {
                <div class="alert-custom @(ViewData["MessageType"]?.ToString() == "danger" ? "alert-custom-danger" : "alert-custom-success") mx-3 mt-3" role="alert">
                    <i class="fas fa-@(ViewData["MessageType"]?.ToString() == "danger" ? "exclamation-circle" : "check-circle")"></i>
                    <span>@ViewData["Message"]</span>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Message"] != null)
            {
                <div class="alert-custom @(TempData["MessageType"]?.ToString() == "danger" ? "alert-custom-danger" : "alert-custom-success") mx-3 mt-3" role="alert">
                    <i class="fas fa-@(TempData["MessageType"]?.ToString() == "danger" ? "exclamation-circle" : "check-circle")"></i>
                    <span>@TempData["Message"]</span>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <!-- TABLE SECTION -->
            <div class="table-section">
                <div class="table-header">
                    <h5 class="table-title">
                        <i class="fas fa-list"></i> Productos
                        @if (productos.Count > 0)
                        {
                            <span class="badge bg-primary">@productos.Count</span>
                        }
                    </h5>
                    @if (totalPages > 1)
                    {
                        <small class="table-info">Página @currentPage de @totalPages</small>
                    }
                </div>

                <!-- PRODUCTS TABLE -->
                <div class="table-responsive-wrapper">
                    @if (productos != null && productos.Count > 0)
                    {
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th style="width: 12%;">
                                        <a href="@Url.Action("Productos", "Inventario", new { searchTerm = searchTerm, page = 1, sortBy = "Id", sortDirection = (sortBy == "Id" && sortDirection == "ASC") ? "DESC" : "ASC" })">
                                            Id
                                            @if (sortBy == "Id")
                                            {
                                                <i class="fas fa-@(sortDirection == "ASC" ? "arrow-up" : "arrow-down")"></i>
                                            }
                                        </a>
                                    </th>
                                    <th style="width: 55%;">
                                        <a href="@Url.Action("Productos", "Inventario", new { searchTerm = searchTerm, page = 1, sortBy = "Producto", sortDirection = (sortBy == "Producto" && sortDirection == "ASC") ? "DESC" : "ASC" })">
                                            Producto
                                            @if (sortBy == "Producto")
                                            {
                                                <i class="fas fa-@(sortDirection == "ASC" ? "arrow-up" : "arrow-down")"></i>
                                            }
                                        </a>
                                    </th>
                                    <th style="width: 18%;">Talla</th>
                                    <th style="width: 15%; text-align: center;">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var producto in productos)
                                {
                                    <tr>
                                        <td>
                                            <span class="badge-id">@(((IDictionary<string, object>)producto)["Id"])</span>
                                        </td>
                                        <td>
                                            <span class="producto-name">@(((IDictionary<string, object>)producto)["Producto"])</span>
                                        </td>
                                        <td>
                                            <span class="producto-talla">@(((IDictionary<string, object>)producto)["Talla"] ?? "—")</span>
                                        </td>
                                        <td class="actions-cell">
                                            <div class="btn-action-group">
                                                <button type="button" 
                                                        class="btn btn-sm btn-action btn-action-edit" 
                                                        data-bs-toggle="modal" 
                                                        data-bs-target="#editModal"
                                                        data-id="@(((IDictionary<string, object>)producto)["Id"])"
                                                        data-producto="@(((IDictionary<string, object>)producto)["Producto"])"
                                                        data-talla="@(((IDictionary<string, object>)producto)["Talla"])"
                                                        title="Editar este producto">
                                                    <i class="fas fa-edit"></i> <span class="d-none d-md-inline">Editar</span>
                                                </button>
                                                <button type="button" 
                                                        class="btn btn-sm btn-action btn-action-delete" 
                                                        data-bs-toggle="modal" 
                                                        data-bs-target="#deleteModal"
                                                        data-id="@(((IDictionary<string, object>)producto)["Id"])"
                                                        data-producto="@(((IDictionary<string, object>)producto)["Producto"])"
                                                        title="Eliminar este producto">
                                                    <i class="fas fa-trash"></i> <span class="d-none d-md-inline">Eliminar</span>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="fas fa-inbox empty-state-icon"></i>
                            <h4 class="empty-state-title">No hay productos para mostrar</h4>
                            <p class="empty-state-text">
                                @if (!string.IsNullOrEmpty(searchTerm))
                                {
                                    <span>No se encontraron resultados para "<strong>@searchTerm</strong>"</span>
                                }
                                else
                                {
                                    <span>Comienza agregando tu primer producto</span>
                                }
                            </p>
                            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addModal">
                                <i class="fas fa-plus"></i> Agregar Primer Producto
                            </button>
                        </div>
                    }
                </div>
            </div>

            <!-- PAGINATION -->
            @if (totalPages > 1)
            {
                <div class="pagination-section">
                    <div class="pagination-info">
                        <strong>Total de páginas:</strong> @totalPages
                    </div>

                    <nav aria-label="Page navigation">
                        <ul class="pagination">
                            @{
                                int startPage = Math.Max(1, currentPage - 2);
                                int endPage = Math.Min(totalPages, currentPage + 2);
                            }

                            @if (currentPage > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="@Url.Action("Productos", "Inventario", new { searchTerm = searchTerm, page = 1, sortBy = sortBy, sortDirection = sortDirection })" title="Primera página">
                                        <i class="fas fa-chevron-left"></i> Anterior
                                    </a>
                                </li>
                            }

                            @if (startPage > 1)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }

                            @for (int i = startPage; i <= endPage; i++)
                            {
                                if (i == currentPage)
                                {
                                    <li class="page-item active">
                                        <span class="page-link">@i</span>
                                    </li>
                                }
                                else
                                {
                                    <li class="page-item">
                                        <a class="page-link" 
                                           href="@Url.Action("Productos", "Inventario", new { searchTerm = searchTerm, page = i, sortBy = sortBy, sortDirection = sortDirection })">
                                            @i
                                        </a>
                                    </li>
                                }
                            }

                            @if (endPage < totalPages)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }

                            @if (currentPage < totalPages)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="@Url.Action("Productos", "Inventario", new { searchTerm = searchTerm, page = totalPages, sortBy = sortBy, sortDirection = sortDirection })" title="Última página">
                                        Siguiente <i class="fas fa-chevron-right"></i>
                                    </a>
                                </li>
                            }
                        </ul>
                    </nav>

                    <div class="pagination-info">
                        Página <strong>@currentPage</strong> / <strong>@totalPages</strong>
                    </div>
                </div>
            }

        </div> <!-- END productos-content -->
    </div> <!-- END container-fluid -->
</div> <!-- END productos-container -->

<!-- ========================================
     MODALS
     ======================================== -->

<!-- Modal: Agregar Nuevo Producto -->
<div class="modal fade" id="addModal" tabindex="-1" aria-labelledby="addModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header header-primary">
                <h5 class="modal-title" id="addModalLabel">
                    <i class="fas fa-plus-circle"></i> Nuevo Producto
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="@Url.Action("Productos", "Inventario")">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="addId" class="form-label">
                            Id / SKU <span class="required-label">*</span>
                        </label>
                        <input type="text" class="form-control" id="addId" name="id" placeholder="Ej. SKU-001" required autofocus>
                        <small class="form-text">Identificador único del producto</small>
                    </div>
                    <div class="mb-3">
                        <label for="addProducto" class="form-label">
                            Nombre del Producto <span class="required-label">*</span>
                        </label>
                        <input type="text" class="form-control" id="addProducto" name="producto" placeholder="Ej. Camiseta Azul" required>
                    </div>
                    <div class="mb-3">
                        <label for="addTalla" class="form-label">Talla</label>
                        <input type="text" class="form-control" id="addTalla" name="talla" placeholder="Ej. M, L, XL, 36">
                        <small class="form-text">Opcional: tamaño o variante del producto</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <input type="hidden" name="action" value="save" />
                    <button type="button" class="btn btn-modal btn-modal-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times"></i> Cancelar
                    </button>
                    <button type="submit" class="btn btn-modal btn-modal-primary">
                        <i class="fas fa-check"></i> Guardar Producto
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Editar Producto -->
<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header header-primary">
                <h5 class="modal-title" id="editModalLabel">
                    <i class="fas fa-edit"></i> Editar Producto
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="@Url.Action("Productos", "Inventario")">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="editId" class="form-label">Id / SKU</label>
                        <input type="text" class="form-control" id="editId" name="id" disabled>
                        <small class="form-text">Este campo no puede ser modificado</small>
                    </div>
                    <div class="mb-3">
                        <label for="editProducto" class="form-label">
                            Nombre del Producto <span class="required-label">*</span>
                        </label>
                        <input type="text" class="form-control" id="editProducto" name="producto" required>
                    </div>
                    <div class="mb-3">
                        <label for="editTalla" class="form-label">Talla</label>
                        <input type="text" class="form-control" id="editTalla" name="talla">
                    </div>
                </div>
                <div class="modal-footer">
                    <input type="hidden" name="action" value="update" />
                    <input type="hidden" id="editIdHidden" name="id" />
                    <button type="button" class="btn btn-modal btn-modal-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times"></i> Cancelar
                    </button>
                    <button type="submit" class="btn btn-modal btn-modal-primary">
                        <i class="fas fa-save"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Confirmar Eliminación -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header header-danger">
                <h5 class="modal-title" id="deleteModalLabel">
                    <i class="fas fa-trash-alt"></i> Eliminar Producto
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="@Url.Action("Productos", "Inventario")">
                <div class="modal-body">
                    <div class="alert-warning-modal">
                        <i class="fas fa-exclamation-triangle"></i>
                        <span><strong>Advertencia:</strong> Esta acción no se puede deshacer.</span>
                    </div>
                    <p class="mb-2">¿Estás seguro de que deseas eliminar este producto?</p>
                    <p class="mb-0">
                        <strong>Producto:</strong> <span id="deleteProductName" style="color: #dc3545;">—</span>
                    </p>
                </div>
                <div class="modal-footer">
                    <input type="hidden" name="id" id="deleteId" />
                    <input type="hidden" name="producto" id="deleteProducto" />
                    <input type="hidden" name="action" value="delete" />
                    <button type="button" class="btn btn-modal btn-modal-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times"></i> Cancelar
                    </button>
                    <button type="submit" class="btn btn-modal btn-modal-danger">
                        <i class="fas fa-trash"></i> Sí, Eliminar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Wait for DOM and Bootstrap to be ready
        document.addEventListener('DOMContentLoaded', function () {
            console.log('=== Productos Page Loaded ===');
            console.log('Bootstrap available:', typeof bootstrap !== 'undefined');

            // Test: Try to manually open the modal when button is clicked
            document.querySelectorAll('[data-bs-toggle="modal"]').forEach(btn => {
                btn.addEventListener('click', function(e) {
                    console.log('Button clicked:', this.className);
                    console.log('Target modal:', this.getAttribute('data-bs-target'));

                    const modalId = this.getAttribute('data-bs-target');
                    if (modalId) {
                        const modal = document.querySelector(modalId);
                        console.log('Modal element found:', !!modal);

                        if (modal && typeof bootstrap !== 'undefined') {
                            const bsModal = new bootstrap.Modal(modal);
                            bsModal.show();
                            console.log('Modal shown via bootstrap');
                        }
                    }
                });
            });

            // Handle edit modal population
            const editModal = document.getElementById('editModal');
            if (editModal) {
                editModal.addEventListener('show.bs.modal', function (event) {
                    console.log('Edit modal show event triggered');
                    const button = event.relatedTarget;
                    if (button) {
                        const id = button.getAttribute('data-id');
                        const producto = button.getAttribute('data-producto');
                        const talla = button.getAttribute('data-talla');

                        console.log('Populating edit modal with:', { id, producto, talla });

                        document.getElementById('editId').value = id || '';
                        document.getElementById('editIdHidden').value = id || '';
                        document.getElementById('editProducto').value = producto || '';
                        document.getElementById('editTalla').value = talla || '';
                        document.getElementById('editProducto').focus();
                    }
                });

                // Clean up backdrop and body styles when modal is hidden
                editModal.addEventListener('hidden.bs.modal', function () {
                    console.log('Edit modal hidden - cleaning up');
                    // Remove any lingering backdrops
                    document.querySelectorAll('.modal-backdrop').forEach(backdrop => {
                        backdrop.remove();
                    });
                    // Restore body scrolling
                    document.body.style.overflow = '';
                    document.body.classList.remove('modal-open');
                });
            }

            // Handle delete modal population
            const deleteModal = document.getElementById('deleteModal');
            if (deleteModal) {
                deleteModal.addEventListener('show.bs.modal', function (event) {
                    console.log('Delete modal show event triggered');
                    const button = event.relatedTarget;
                    if (button) {
                        const id = button.getAttribute('data-id');
                        const producto = button.getAttribute('data-producto');

                        console.log('Populating delete modal with:', { id, producto });

                        document.getElementById('deleteId').value = id || '';
                        document.getElementById('deleteProductName').textContent = producto || '';
                    }
                });

                // Clean up backdrop and body styles when modal is hidden
                deleteModal.addEventListener('hidden.bs.modal', function () {
                    console.log('Delete modal hidden - cleaning up');
                    // Remove any lingering backdrops
                    document.querySelectorAll('.modal-backdrop').forEach(backdrop => {
                        backdrop.remove();
                    });
                    // Restore body scrolling
                    document.body.style.overflow = '';
                    document.body.classList.remove('modal-open');
                });
            }

            // Also handle add modal cleanup
            const addModal = document.getElementById('addModal');
            if (addModal) {
                addModal.addEventListener('hidden.bs.modal', function () {
                    console.log('Add modal hidden - cleaning up');
                    // Remove any lingering backdrops
                    document.querySelectorAll('.modal-backdrop').forEach(backdrop => {
                        backdrop.remove();
                    });
                    // Restore body scrolling
                    document.body.style.overflow = '';
                    document.body.classList.remove('modal-open');
                });
            }

            // Auto-dismiss alerts after 5 seconds
            document.querySelectorAll('.alert-custom').forEach(alert => {
                setTimeout(() => {
                    const bsAlert = new bootstrap.Alert(alert);
                    bsAlert.close();
                }, 5000);
            });
        });
    </script>
}
