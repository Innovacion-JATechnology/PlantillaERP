        public InventarioController(ILogger<InventarioController> logger, IConfiguration configuration)
        {
            _logger = logger;
            _configuration = configuration;
        }

        [HttpGet]
        public IActionResult Productos(string? searchTerm = null, int page = 1, string? sortBy = "ProductoCompleto", string? sortDirection = "ASC")
        {
            try
            {
                ViewData["Title"] = "Productos";
                ViewData["Breadcrumbs"] = new List<(string, string)>
                {
                    ("Dashboard", Url.Action("Index", "Home")),
                    ("Inventario", Url.Action("Inventario", "Modules")),
                    ("Catálogo", null)
                };
                ViewData["SearchTerm"] = searchTerm ?? string.Empty;
                ViewData["CurrentPage"] = page;
                ViewData["SortBy"] = sortBy ?? "ProductoCompleto";
                ViewData["SortDirection"] = sortDirection ?? "ASC";

                var connectionString = _configuration.GetConnectionString("DefaultConnection") ?? 
                    _configuration.GetConnectionString("ServerCon") ?? string.Empty;

                var productos = new List<dynamic>();
                int totalRows = 0;
                const int pageSize = 10;

                if (string.IsNullOrEmpty(connectionString))
                {
                    ViewData["Message"] = "No hay conexión a la base de datos configurada";
                    ViewData["MessageType"] = "danger";
                    ViewData["Productos"] = productos;
                    return View("~/Views/Modules/Productos.cshtml");
                }

                using (var con = new SqlConnection(connectionString))
                {
                    con.Open();

                    // Simple query to test connection
                    string testSql = "SELECT COUNT(*) FROM hd.Catalogo";
                    using (var cmd = new SqlCommand(testSql, con))
                    {
                        cmd.CommandTimeout = 30;
                        totalRows = (int)cmd.ExecuteScalar();
                    }

                    // Get paginated data
                    int offset = (page - 1) * pageSize;
                    string safeSortColumn = (sortBy == "Id" || sortBy == "ProductoCompleto") ? sortBy : "ProductoCompleto";
                    string safeSortDir = sortDirection == "DESC" ? "DESC" : "ASC";

                    string sql = $@"SELECT TOP {pageSize} Id, Producto, Talla, 
                        (CASE 
                            WHEN (Producto IS NULL OR LTRIM(RTRIM(Producto)) = '') AND (Talla IS NULL OR LTRIM(RTRIM(Talla)) = '') THEN ''
                            WHEN (Talla IS NULL OR LTRIM(RTRIM(Talla)) = '') THEN Producto
                            WHEN (Producto IS NULL OR LTRIM(RTRIM(Producto)) = '') THEN Talla
                            ELSE Producto + ' ' + Talla
                        END) AS ProductoCompleto
                        FROM (
                            SELECT Id, Producto, Talla, 
                                ROW_NUMBER() OVER (ORDER BY {safeSortColumn} {safeSortDir}) AS RowNum
                            FROM hd.Catalogo
                        ) AS Sorted
                        WHERE RowNum > {offset}
                        ORDER BY RowNum";

                    using (var cmd = new SqlCommand(sql, con))
                    {
                        cmd.CommandTimeout = 30;
                        using (var reader = cmd.ExecuteReader())
                        {
                            while (reader.Read())
                            {
                                dynamic item = new System.Dynamic.ExpandoObject();
                                item.Id = reader["Id"]?.ToString() ?? string.Empty;
                                item.Producto = reader["Producto"]?.ToString() ?? string.Empty;
                                item.Talla = reader["Talla"]?.ToString() ?? string.Empty;
                                item.ProductoCompleto = reader["ProductoCompleto"]?.ToString() ?? string.Empty;
                                productos.Add(item);
                            }
                        }
                    }
                }

                ViewData["Productos"] = productos;
                ViewData["TotalPages"] = totalRows > 0 ? (int)Math.Ceiling((double)totalRows / pageSize) : 1;

                return View("~/Views/Modules/Productos.cshtml");
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, $"Error: {ex.Message}");
                ViewData["Message"] = $"Error: {ex.Message}";
                ViewData["MessageType"] = "danger";
                ViewData["Productos"] = new List<dynamic>();
                return View("~/Views/Modules/Productos.cshtml");
            }
        }

