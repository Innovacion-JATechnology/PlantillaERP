@{
    ViewData["Title"] = "Productos";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Dashboard", Url.Action("Index", "Home")),
        ("Inventario", Url.Action("Inventario", "Modules")),
        ("Productos", Url.Action("Productos", "Modules"))
    };
}

<style>
    /* Contenedor angosto y centrado para la tabla y el formulario */
    .narrow-wrap {
        max-width: 720px;   /* ajusta: 520–820px  */
        margin-left: auto;
        margin-right: auto;
    }
    .search-bar .form-control { max-width: 360px; }
</style>

<div class="narrow-wrap">

    <!-- Título + Buscador -->
    <div class="d-flex flex-wrap align-items-center justify-content-between mb-3">
        <h4 class="section-title m-0">Catálogo</h4>

        <div class="search-bar">
            <form method="post" asp-action="Productos" class="d-inline">
                <div class="input-group">
                    <input type="text" name="searchTerm" class="form-control" placeholder="Buscar producto o talla..." value="@ViewData["SearchTerm"]" />
                    <button type="submit" class="btn btn-primary" name="command" value="search">Buscar</button>
                    <button type="submit" class="btn btn-outline-secondary" name="command" value="clear">Limpiar</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Mensajes -->
    @if (!string.IsNullOrEmpty(ViewData["Message"] as string))
    {
        <div class="alert alert-@ViewData["MessageType"] d-block mb-2" role="alert">
            @ViewData["Message"]
        </div>
    }

    <!-- Tabla de productos -->
    <div class="table-responsive mb-4">
        <table class="table table-sm table-hover">
            <thead class="table-light">
                <tr>
                    <th>
                        <a href="@Url.Action("Productos", new { sortBy = "Id", sortDirection = ViewData["SortDirection"].ToString() == "ASC" ? "DESC" : "ASC" })" 
                           class="text-decoration-none">
                            Id
                        </a>
                    </th>
                    <th>
                        <a href="@Url.Action("Productos", new { sortBy = "ProductoCompleto", sortDirection = ViewData["SortDirection"].ToString() == "ASC" ? "DESC" : "ASC" })" 
                           class="text-decoration-none">
                            Producto
                        </a>
                    </th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (ViewData["Productos"] is List<dynamic> productos && productos.Count > 0)
                {
                    @foreach (var producto in productos)
                    {
                        <tr>
                            <td>@producto.Id</td>
                            <td>@producto.ProductoCompleto</td>
                            <td>
                                <form method="post" asp-action="Productos" style="display: inline;">
                                    <input type="hidden" name="id" value="@producto.Id" />
                                    <input type="hidden" name="producto" value="@producto.Producto" />
                                    <input type="hidden" name="talla" value="@producto.Talla" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary me-1" name="command" value="edit">Editar</button>
                                    <button type="submit" class="btn btn-sm btn-outline-danger" name="command" value="delete" onclick="return confirm('¿Eliminar este producto?');">Eliminar</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted">No hay productos para mostrar.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Paginación -->
    @if (ViewData["TotalPages"] is int totalPages && totalPages > 1)
    {
        int currentPage = ViewData["CurrentPage"] as int? ?? 1;
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                @if (currentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Productos", new { page = currentPage - 1, searchTerm = ViewData["SearchTerm"], sortBy = ViewData["SortBy"], sortDirection = ViewData["SortDirection"] })">Anterior</a>
                    </li>
                }
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Productos", new { page = i, searchTerm = ViewData["SearchTerm"], sortBy = ViewData["SortBy"], sortDirection = ViewData["SortDirection"] })">@i</a>
                    </li>
                }
                @if (currentPage < totalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Productos", new { page = currentPage + 1, searchTerm = ViewData["SearchTerm"], sortBy = ViewData["SortBy"], sortDirection = ViewData["SortDirection"] })">Siguiente</a>
                    </li>
                }
            </ul>
        </nav>
    }

    <!-- Formulario para agregar/editar -->
    <div class="card mb-3">
        <div class="card-body">
            <h5>Modificar/Agregar Productos</h5>
            <form method="post" asp-action="Productos">
                <input type="hidden" id="hfId" name="hfId" value="@ViewData["EditingId"]" />

                <div class="row g-3 align-items-end">
                    <!-- Id -->
                    <div class="col-12 col-md-3">
                        <label class="form-label">Id</label>
                        <input type="text" id="txtId" name="txtId" class="form-control" maxlength="50" placeholder="Ej. SKU-001" 
                               value="@ViewData["FormId"]" @(string.IsNullOrEmpty(ViewData["EditingId"] as string) ? "" : "disabled") />
                    </div>

                    <div class="col-12 col-md-5">
                        <label class="form-label">Producto</label>
                        <input type="text" id="txtProducto" name="txtProducto" class="form-control" maxlength="150" value="@ViewData["FormProducto"]" />
                    </div>

                    <div class="col-6 col-md-2">
                        <label class="form-label">Talla</label>
                        <input type="text" id="txtTalla" name="txtTalla" class="form-control" maxlength="50" value="@ViewData["FormTalla"]" />
                    </div>

                    <div class="col-6 col-md-2 d-grid">
                        <button type="submit" class="btn btn-success" name="command" value="save">
                            @(string.IsNullOrEmpty(ViewData["EditingId"] as string) ? "Guardar" : "Actualizar")
                        </button>
                        <button type="submit" class="btn btn-outline-secondary mt-2" name="command" value="cancel">Cancelar</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

</div>
