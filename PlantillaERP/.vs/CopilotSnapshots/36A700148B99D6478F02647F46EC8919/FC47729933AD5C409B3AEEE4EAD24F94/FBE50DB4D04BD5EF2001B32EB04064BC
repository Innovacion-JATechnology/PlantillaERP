@{
    ViewData["Title"] = "Productos";
    ViewData["Breadcrumbs"] = new List<(string, string)>
    {
        ("Dashboard", Url.Action("Index", "Home")),
        ("Inventario", Url.Action("Inventario", "Modules")),
        ("Catálogo", null)
    };
}

<!-- Título -->
<h1 class="mt-4">Catálogo de Productos</h1>

<!-- Búsqueda -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" asp-action="Productos" class="row g-3">
            <div class="col-md-8">
                <input type="text" name="searchTerm" class="form-control" placeholder="Buscar producto o talla..." value="@ViewData["SearchTerm"]" />
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1" name="command" value="search">
                    <i class="fas fa-search me-1"></i>Buscar
                </button>
                <a href="@Url.Action("Productos")" class="btn btn-outline-secondary flex-grow-1">
                    <i class="fas fa-redo me-1"></i>Limpiar
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Mensajes -->
@if (!string.IsNullOrEmpty(ViewData["Message"] as string))
{
    <div class="alert alert-@ViewData["MessageType"] alert-dismissible fade show mb-4" role="alert">
        @ViewData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Tabla de productos -->
<div class="card mb-4">
    <div class="card-header">
        <i class="fas fa-table me-1"></i>
        Productos
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th style="width: 15%;">
                            <a href="@Url.Action("Productos", new { sortBy = "Id", sortDirection = ((string?)ViewData["SortDirection"] ?? "ASC") == "ASC" ? "DESC" : "ASC", searchTerm = ViewData["SearchTerm"], page = ViewData["CurrentPage"] })" 
                               class="text-decoration-none">
                                ID
                                @if ((string?)ViewData["SortBy"] == "Id")
                                {
                                    <i class="fas fa-sort-@(((string?)ViewData["SortDirection"] == "DESC") ? "down" : "up") ms-1"></i>
                                }
                            </a>
                        </th>
                        <th style="width: 60%;">
                            <a href="@Url.Action("Productos", new { sortBy = "ProductoCompleto", sortDirection = ((string?)ViewData["SortDirection"] ?? "ASC") == "ASC" ? "DESC" : "ASC", searchTerm = ViewData["SearchTerm"], page = ViewData["CurrentPage"] })" 
                               class="text-decoration-none">
                                Producto
                                @if ((string?)ViewData["SortBy"] == "ProductoCompleto")
                                {
                                    <i class="fas fa-sort-@(((string?)ViewData["SortDirection"] == "DESC") ? "down" : "up") ms-1"></i>
                                }
                            </a>
                        </th>
                        <th style="width: 25%;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewData["Productos"] is List<dynamic> productos && productos.Count > 0)
                    {
                        @foreach (var producto in productos)
                        {
                            <tr>
                                <td>@producto.Id</td>
                                <td>@producto.ProductoCompleto</td>
                                <td>
                                    <form method="post" asp-action="Productos" style="display: inline;">
                                        <input type="hidden" name="txtId" value="@producto.Id" />
                                        <input type="hidden" name="txtProducto" value="@producto.Producto" />
                                        <input type="hidden" name="txtTalla" value="@producto.Talla" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary" name="command" value="edit" title="Editar">
                                            <i class="fas fa-edit"></i> Editar
                                        </button>
                                        <button type="submit" class="btn btn-sm btn-outline-danger" name="command" value="delete" 
                                                onclick="return confirm('¿Eliminar este producto?');" title="Eliminar">
                                            <i class="fas fa-trash"></i> Eliminar
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted py-4">
                                <i class="fas fa-inbox me-2"></i>No hay productos para mostrar.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-light">
        <!-- Paginación -->
        @if (ViewData["TotalPages"] is int totalPages && totalPages > 1)
        {
            int currentPage = (int?)ViewData["CurrentPage"] ?? 1;
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center mb-0">
                    @if (currentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Productos", new { page = 1, searchTerm = ViewData["SearchTerm"] ?? "", sortBy = ViewData["SortBy"] ?? "", sortDirection = ViewData["SortDirection"] ?? "" })">
                                <i class="fas fa-step-backward"></i>
                            </a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Productos", new { page = currentPage - 1, searchTerm = ViewData["SearchTerm"] ?? "", sortBy = ViewData["SortBy"] ?? "", sortDirection = ViewData["SortDirection"] ?? "" })">Anterior</a>
                        </li>
                    }
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link" href="@Url.Action("Productos", new { page = i, searchTerm = ViewData["SearchTerm"] ?? "", sortBy = ViewData["SortBy"] ?? "", sortDirection = ViewData["SortDirection"] ?? "" })">@i</a>
                        </li>
                    }
                    @if (currentPage < totalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Productos", new { page = currentPage + 1, searchTerm = ViewData["SearchTerm"] ?? "", sortBy = ViewData["SortBy"] ?? "", sortDirection = ViewData["SortDirection"] ?? "" })">Siguiente</a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Productos", new { page = totalPages, searchTerm = ViewData["SearchTerm"] ?? "", sortBy = ViewData["SortBy"] ?? "", sortDirection = ViewData["SortDirection"] ?? "" })">
                                <i class="fas fa-step-forward"></i>
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        }

    <!-- Paginación -->
    @if (ViewData["TotalPages"] is int totalPages && totalPages > 1)
    {
        int currentPage = (int?)ViewData["CurrentPage"] ?? 1;
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                @if (currentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Productos", new { page = currentPage - 1, searchTerm = ViewData["SearchTerm"] ?? "", sortBy = ViewData["SortBy"] ?? "", sortDirection = ViewData["SortDirection"] ?? "" })">Anterior</a>
                    </li>
                }
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Productos", new { page = i, searchTerm = ViewData["SearchTerm"] ?? "", sortBy = ViewData["SortBy"] ?? "", sortDirection = ViewData["SortDirection"] ?? "" })">@i</a>
                    </li>
                }
                @if (currentPage < totalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Productos", new { page = currentPage + 1, searchTerm = ViewData["SearchTerm"] ?? "", sortBy = ViewData["SortBy"] ?? "", sortDirection = ViewData["SortDirection"] ?? "" })">Siguiente</a>
                    </li>
                }
            </ul>
        </nav>
    }

    <!-- Formulario para agregar/editar -->
    <div class="card mb-3">
        <div class="card-body">
            <h5>Modificar/Agregar Productos</h5>
            <form method="post" asp-action="Productos">
                <input type="hidden" id="hfId" name="hfId" value="@ViewData["EditingId"]" />

                <div class="row g-3 align-items-end">
                    <!-- Id -->
                    <div class="col-12 col-md-3">
                        <label class="form-label">Id</label>
                        <input type="text" id="txtId" name="txtId" class="form-control" maxlength="50" placeholder="Ej. SKU-001" 
                               value="@ViewData["FormId"]" @(string.IsNullOrEmpty(ViewData["EditingId"] as string) ? "" : "disabled") />
                    </div>

                    <div class="col-12 col-md-5">
                        <label class="form-label">Producto</label>
                        <input type="text" id="txtProducto" name="txtProducto" class="form-control" maxlength="150" value="@ViewData["FormProducto"]" />
                    </div>

                    <div class="col-6 col-md-2">
                        <label class="form-label">Talla</label>
                        <input type="text" id="txtTalla" name="txtTalla" class="form-control" maxlength="50" value="@ViewData["FormTalla"]" />
                    </div>

                    <div class="col-6 col-md-2 d-grid">
                        <button type="submit" class="btn btn-success" name="command" value="save">
                            @(string.IsNullOrEmpty(ViewData["EditingId"] as string) ? "Guardar" : "Actualizar")
                        </button>
                        <button type="submit" class="btn btn-outline-secondary mt-2" name="command" value="cancel">Cancelar</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

</div>
