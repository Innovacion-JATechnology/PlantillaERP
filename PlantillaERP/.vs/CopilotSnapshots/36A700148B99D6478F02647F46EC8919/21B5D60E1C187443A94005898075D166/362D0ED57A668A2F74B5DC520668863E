/* ========================================
   PRODUCTOS PAGE - CUSTOM STYLES
   ======================================== */

:root {
    --primary-color: #0d6efd;
    --secondary-color: #6c757d;
    --danger-color: #dc3545;
    --success-color: #198754;
    --spacing-base: 1rem;
}

/* PAGE LAYOUT */
.productos-container {
    background-color: #f8f9fa;
    min-height: 100vh;
    padding: 2rem 0;
}

.productos-content {
    background: white;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    overflow: hidden;
}

/* HEADER SECTION */
.productos-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 2rem;
    border-bottom: 1px solid #e9ecef;
    gap: 2rem;
}

.productos-header-title h1 {
    font-size: 2rem;
    font-weight: 700;
    color: #212529;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.productos-header-title p {
    color: #6c757d;
    margin: 0.5rem 0 0 0;
    font-size: 0.9rem;
}

.btn-new-producto {
    white-space: nowrap;
    box-shadow: 0 2px 4px rgba(13, 110, 253, 0.25);
    transition: all 0.3s ease;
}

.btn-new-producto:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(13, 110, 253, 0.4);
}

/* SEARCH SECTION */
.search-section {
    padding: 1.5rem 2rem;
    background: #f8f9fa;
}

.search-form {
    display: flex;
    gap: 1rem;
    align-items: center;
}

.search-form .form-control {
    border: 2px solid #e9ecef;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-size: 0.95rem;
    transition: border-color 0.3s ease;
}

.search-form .form-control:focus {
    border-color: var(--primary-color);
    box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.15);
}

.search-form .btn {
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-weight: 500;
    transition: all 0.3s ease;
}

/* TABLE SECTION */
.table-section {
    padding: 2rem;
}

.table-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #e9ecef;
}

.table-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: #212529;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.table-title .badge {
    font-size: 0.85rem;
    padding: 0.4rem 0.75rem;
}

.table-info {
    color: #6c757d;
    font-size: 0.9rem;
}

/* RESPONSIVE TABLE */
.table-responsive-wrapper {
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid #e9ecef;
}

.table {
    margin: 0;
}

.table thead {
    background-color: #f8f9fa;
    border-bottom: 2px solid #dee2e6;
}

.table thead th {
    font-weight: 600;
    color: #495057;
    padding: 1rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border: none;
}

.table thead th a {
    color: #495057;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: color 0.3s ease;
}

.table thead th a:hover {
    color: var(--primary-color);
}

.table tbody td {
    padding: 1rem;
    vertical-align: middle;
    border-color: #e9ecef;
    font-size: 0.95rem;
}

.table tbody tr {
    transition: background-color 0.3s ease;
    border-bottom: 1px solid #e9ecef;
}

.table tbody tr:hover {
    background-color: #f8f9fa;
}

.table tbody tr:last-child {
    border-bottom: none;
}

/* TABLE CELLS */
.badge-id {
    background-color: #e7f1ff;
    color: var(--primary-color);
    font-weight: 600;
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
}

.producto-name {
    font-weight: 600;
    color: #212529;
}

.producto-talla {
    color: #6c757d;
    font-size: 0.9rem;
}

/* ACTIONS */
.actions-cell {
    text-align: center;
}

.btn-action-group {
    display: inline-flex;
    gap: 0.5rem;
}

.btn-action {
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    border: 2px solid;
    font-size: 0.85rem;
    font-weight: 500;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    cursor: pointer;
}

.btn-action-edit {
    border-color: var(--primary-color);
    color: var(--primary-color);
    background: transparent;
}

.btn-action-edit:hover {
    background-color: var(--primary-color);
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 2px 6px rgba(13, 110, 253, 0.25);
}

.btn-action-delete {
    border-color: var(--danger-color);
    color: var(--danger-color);
    background: transparent;
}

.btn-action-delete:hover {
    background-color: var(--danger-color);
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 2px 6px rgba(220, 53, 69, 0.25);
}

/* EMPTY STATE */
.empty-state {
    text-align: center;
    padding: 4rem 2rem;
}

.empty-state-icon {
    font-size: 3.5rem;
    color: #dee2e6;
    margin-bottom: 1rem;
}

.empty-state-title {
    font-size: 1.25rem;
    color: #6c757d;
    margin-bottom: 0.5rem;
    font-weight: 600;
}

.empty-state-text {
    color: #adb5bd;
    margin-bottom: 1.5rem;
}

/* PAGINATION */
.pagination-section {
    padding: 2rem;
    background: #f8f9fa;
    border-top: 1px solid #e9ecef;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
}

.pagination-info {
    color: #6c757d;
    font-size: 0.9rem;
}

.pagination {
    margin: 0;
    gap: 0.25rem;
}

.page-link {
    color: var(--primary-color);
    background-color: white;
    border: 1px solid #dee2e6;
    border-radius: 6px;
    padding: 0.5rem 0.75rem;
    font-size: 0.9rem;
    transition: all 0.3s ease;
}

.page-link:hover:not(.active) {
    background-color: #f8f9fa;
    border-color: var(--primary-color);
    color: var(--primary-color);
}

.page-link.active {
    background-color: var(--primary-color);
    border-color: var(--primary-color);
    color: white;
}

.page-link.disabled {
    color: #6c757d;
    pointer-events: none;
}

/* ALERTS */
.alert-custom {
    border: none;
    border-radius: 8px;
    padding: 1rem 1.5rem;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    animation: slideIn 0.3s ease-out;
}

.alert-custom-success {
    background-color: #d1e7dd;
    color: #0f5132;
    border-left: 4px solid #198754;
}

.alert-custom-danger {
    background-color: #f8d7da;
    color: #842029;
    border-left: 4px solid #dc3545;
}

.alert-custom i {
    font-size: 1.1rem;
}

@keyframes slideIn {
    from {
        opacity: 0;
        transform: translateY(-10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* MODAL STYLES */
.modal-content {
    border: none;
    border-radius: 12px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
}

.modal-header {
    border-bottom: 2px solid #e9ecef;
    padding: 1.5rem;
}

.modal-header.header-primary {
    background: linear-gradient(135deg, #0d6efd 0%, #0b5ed7 100%);
    color: white;
}

.modal-header.header-danger {
    background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
    color: white;
}

.modal-title {
    font-weight: 600;
    font-size: 1.25rem;
}

.modal-body {
    padding: 2rem;
}

.modal-footer {
    background-color: #f8f9fa;
    border-top: 1px solid #e9ecef;
    padding: 1.5rem;
    gap: 1rem;
}

.form-label {
    font-weight: 600;
    color: #212529;
    margin-bottom: 0.5rem;
}

.form-control {
    border: 2px solid #e9ecef;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    transition: border-color 0.3s ease;
}

.form-control:focus {
    border-color: var(--primary-color);
    box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.15);
}

.form-control:disabled {
    background-color: #f8f9fa;
    border-color: #dee2e6;
    color: #6c757d;
}

.form-text {
    color: #6c757d;
    font-size: 0.85rem;
    margin-top: 0.25rem;
    display: block;
}

.required-label {
    color: var(--danger-color);
}

.btn-modal {
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-weight: 500;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
}

.btn-modal-primary {
    background-color: var(--primary-color);
    color: white;
}

.btn-modal-primary:hover {
    background-color: #0b5ed7;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(13, 110, 253, 0.35);
}

.btn-modal-secondary {
    background-color: #e9ecef;
    color: #495057;
}

.btn-modal-secondary:hover {
    background-color: #dee2e6;
}

.btn-modal-danger {
    background-color: var(--danger-color);
    color: white;
}

.btn-modal-danger:hover {
    background-color: #c82333;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(220, 53, 69, 0.35);
}

.alert-warning-modal {
    background-color: #fff3cd;
    color: #664d03;
    border: 1px solid #ffecb5;
    border-radius: 8px;
    padding: 1rem;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

/* RESPONSIVE */
@media (max-width: 768px) {
    .productos-header {
        flex-direction: column;
        text-align: center;
        align-items: stretch;
        gap: 1rem;
    }

    .productos-header-title h1 {
        font-size: 1.5rem;
        justify-content: center;
    }

    .btn-new-producto {
        width: 100%;
    }

    .search-form {
        flex-direction: column;
    }

    .search-form .form-control,
    .search-form .btn {
        width: 100%;
    }

    .table-responsive-wrapper {
        font-size: 0.85rem;
    }

    .table thead th,
    .table tbody td {
        padding: 0.75rem 0.5rem;
    }

    .btn-action {
        padding: 0.4rem 0.5rem;
        font-size: 0.75rem;
    }

    .pagination-section {
        flex-direction: column;
        align-items: center;
    }

    .modal-body {
        padding: 1.5rem;
    }

    .modal-header,
    .modal-footer {
        padding: 1rem;
    }
}

@media (max-width: 576px) {
    .productos-container {
        padding: 1rem 0;
    }

    .productos-header,
    .search-section,
    .table-section,
    .pagination-section {
        padding: 1rem;
    }

    .productos-header-title h1 {
        font-size: 1.25rem;
    }

    .table thead th {
        font-size: 0.75rem;
        padding: 0.5rem;
    }

    .table tbody td {
        padding: 0.5rem;
        font-size: 0.85rem;
    }

    .actions-cell {
        white-space: nowrap;
    }

    .btn-action {
        padding: 0.3rem 0.4rem;
        font-size: 0.7rem;
    }

    .btn-action i {
        display: none;
    }
}
