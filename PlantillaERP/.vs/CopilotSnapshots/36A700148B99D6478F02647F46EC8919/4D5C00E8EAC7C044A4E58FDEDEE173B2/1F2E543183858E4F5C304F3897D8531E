        [HttpGet]
        public IActionResult Productos(string? searchTerm = null, int page = 1, string? sortBy = "Id", string? sortDirection = "ASC")
        {
            try
            {
                ViewData["Title"] = "Productos";
                ViewData["Breadcrumbs"] = new List<(string, string)>
                {
                    ("Inicio", Url.Action("Index", "Home")),
                    ("Inventario", Url.Action("Inventario", "Modules")),
                    ("Catálogo", null)
                };
                ViewData["SearchTerm"] = searchTerm ?? string.Empty;
                ViewData["CurrentPage"] = page;
                ViewData["SortBy"] = sortBy ?? "Id";
                ViewData["SortDirection"] = sortDirection ?? "ASC";

                var connectionString = _configuration.GetConnectionString("DefaultConnection") ?? 
                    _configuration.GetConnectionString("ServerCon") ?? string.Empty;

                var productos = new List<dynamic>();
                int totalRows = 0;
                const int pageSize = 10;

                if (string.IsNullOrEmpty(connectionString))
                {
                    ViewData["Message"] = "No hay conexión a la base de datos configurada";
                    ViewData["MessageType"] = "danger";
                    ViewData["Productos"] = productos;
                    return View("~/Views/Modules/Productos.cshtml");
                }

                using (var con = new SqlConnection(connectionString))
                {
                    con.Open();

                    // Build WHERE clause based on search term
                    string whereClause = "";
                    if (!string.IsNullOrWhiteSpace(searchTerm))
                    {
                        whereClause = $" WHERE Id LIKE '%{searchTerm.Replace("'", "''")}%' OR Producto LIKE '%{searchTerm.Replace("'", "''")}%' OR Talla LIKE '%{searchTerm.Replace("'", "''")}%'";
                    }

                    // Count total rows with search filter
                    string countSql = $"SELECT COUNT(*) FROM hd.Catalogo{whereClause}";
                    using (var cmd = new SqlCommand(countSql, con))
                    {
                        cmd.CommandTimeout = 30;
                        totalRows = (int)cmd.ExecuteScalar();
                    }

                    // Get paginated data
                    int offset = (page - 1) * pageSize;
                    string safeSortColumn = (sortBy == "Id" || sortBy == "Producto") ? sortBy : "Id";
                    string safeSortDir = sortDirection == "DESC" ? "DESC" : "ASC";

                    string sql = $@"SELECT TOP {pageSize} Id, Producto, Talla, 
                        (CASE 
                            WHEN (Producto IS NULL OR LTRIM(RTRIM(Producto)) = '') AND (Talla IS NULL OR LTRIM(RTRIM(Talla)) = '') THEN ''
                            WHEN (Talla IS NULL OR LTRIM(RTRIM(Talla)) = '') THEN Producto
                            WHEN (Producto IS NULL OR LTRIM(RTRIM(Producto)) = '') THEN Talla
                            ELSE Producto + ' ' + Talla
                        END) AS ProductoCompleto
                        FROM (
                            SELECT Id, Producto, Talla, 
                                ROW_NUMBER() OVER (ORDER BY {safeSortColumn} {safeSortDir}) AS RowNum
                            FROM hd.Catalogo{whereClause}
                        ) AS Sorted
                        WHERE RowNum > {offset}
                        ORDER BY RowNum";

                    using (var cmd = new SqlCommand(sql, con))
                    {
                        cmd.CommandTimeout = 30;
                        using (var reader = cmd.ExecuteReader())
                        {
                            while (reader.Read())
                            {
                                dynamic item = new System.Dynamic.ExpandoObject();
                                item.Id = reader["Id"]?.ToString() ?? string.Empty;
                                item.Producto = reader["Producto"]?.ToString() ?? string.Empty;
                                item.Talla = reader["Talla"]?.ToString() ?? string.Empty;
                                item.ProductoCompleto = reader["ProductoCompleto"]?.ToString() ?? string.Empty;
                                productos.Add(item);
                            }
                        }
                    }
                }

                ViewData["Productos"] = productos;
                ViewData["TotalPages"] = totalRows > 0 ? (int)Math.Ceiling((double)totalRows / pageSize) : 1;

                return View("~/Views/Modules/Productos.cshtml");
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, $"Error: {ex.Message}");
                ViewData["Message"] = $"Error: {ex.Message}";
                ViewData["MessageType"] = "danger";
                ViewData["Productos"] = new List<dynamic>();
                return View("~/Views/Modules/Productos.cshtml");
            }
        }

        [HttpPost]
        public IActionResult Productos(string? id, string? producto, string? talla, string? action)
        {
            try
            {
                if (string.IsNullOrWhiteSpace(id) || string.IsNullOrWhiteSpace(producto))
                {
                    TempData["Message"] = "El Id y Nombre del producto son requeridos";
                    TempData["MessageType"] = "danger";
                    return RedirectToAction("Productos");
                }

                var connectionString = _configuration.GetConnectionString("DefaultConnection") ?? 
                    _configuration.GetConnectionString("ServerCon") ?? string.Empty;

                if (string.IsNullOrEmpty(connectionString))
                {
                    TempData["Message"] = "No hay conexión a la base de datos configurada";
                    TempData["MessageType"] = "danger";
                    return RedirectToAction("Productos");
                }

                using (var con = new SqlConnection(connectionString))
                {
                    con.Open();

                    if (action == "save")
                    {
                        // Insert new product
                        string sql = "INSERT INTO hd.Catalogo (Id, Producto, Talla) VALUES (@id, @producto, @talla)";
                        using (var cmd = new SqlCommand(sql, con))
                        {
                            cmd.CommandTimeout = 30;
                            cmd.Parameters.AddWithValue("@id", id);
                            cmd.Parameters.AddWithValue("@producto", producto ?? string.Empty);
                            cmd.Parameters.AddWithValue("@talla", talla ?? string.Empty);

                            try
                            {
                                cmd.ExecuteNonQuery();
                                TempData["Message"] = $"Producto '{producto}' agregado exitosamente";
                                TempData["MessageType"] = "success";
                            }
                            catch (SqlException ex) when (ex.Number == 2627)
                            {
                                TempData["Message"] = $"El Id '{id}' ya existe en la base de datos";
                                TempData["MessageType"] = "danger";
                            }
                        }
                    }
                    else if (action == "update")
                    {
                        // Update existing product
                        string sql = "UPDATE hd.Catalogo SET Producto = @producto, Talla = @talla WHERE Id = @id";
                        using (var cmd = new SqlCommand(sql, con))
                        {
                            cmd.CommandTimeout = 30;
                            cmd.Parameters.AddWithValue("@id", id);
                            cmd.Parameters.AddWithValue("@producto", producto ?? string.Empty);
                            cmd.Parameters.AddWithValue("@talla", talla ?? string.Empty);

                            int rowsAffected = cmd.ExecuteNonQuery();
                            if (rowsAffected > 0)
                            {
                                TempData["Message"] = $"Producto '{producto}' actualizado exitosamente";
                                TempData["MessageType"] = "success";
                            }
                            else
                            {
                                TempData["Message"] = $"No se encontró el producto con Id '{id}'";
                                TempData["MessageType"] = "danger";
                            }
                        }
                    }
                    else if (action == "delete")
                    {
                        // Delete product
                        string sql = "DELETE FROM hd.Catalogo WHERE Id = @id";
                        using (var cmd = new SqlCommand(sql, con))
                        {
                            cmd.CommandTimeout = 30;
                            cmd.Parameters.AddWithValue("@id", id);

                            int rowsAffected = cmd.ExecuteNonQuery();
                            if (rowsAffected > 0)
                            {
                                TempData["Message"] = $"Producto eliminado exitosamente";
                                TempData["MessageType"] = "success";
                            }
                            else
                            {
                                TempData["Message"] = $"No se encontró el producto para eliminar";
                                TempData["MessageType"] = "danger";
                            }
                        }
                    }
                }

                return RedirectToAction("Productos");
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, $"Error en operación de producto: {ex.Message}");
                TempData["Message"] = $"Error: {ex.Message}";
                TempData["MessageType"] = "danger";
                return RedirectToAction("Productos");
            }
        }

